      {
        "type": "mcq",
        "question": "In triangle ABC, $A = 30^\\circ$, $B = 50^\\circ$, and side $a = 12$. Find side $b$.",
        "options": [
          "18.38",
          "15.50",
          "12.00",
          "20.00"
        ],
        "answer": "A",
        "explanation": "$\\frac{a}{\\sin A} = \\frac{b}{\\sin B} \\implies \\frac{12}{\\sin 30^\\circ} = \\frac{b}{\\sin 50^\\circ} \\implies b = \\frac{12 \\cdot \\sin 50^\\circ}{\\sin 30^\\circ} = \\frac{12 \\cdot 0.7660}{0.5} = 18.384 \\approx 18.38$."
      },
      {
        "type": "mcq",
        "question": "Given triangle ABC with $A = 40^\\circ$, $a = 8$, and $b = 10$. Calculate the height $h$.",
        "options": [
          "6.43",
          "8.00",
          "5.14",
          "10.00"
        ],
        "answer": "A",
        "explanation": "$h = b \\sin A = 10 \\cdot \\sin 40^\\circ = 10 \\cdot 0.6428 = 6.428 \\approx 6.43$."
      },
      {
        "type": "mcq",
        "question": "In triangle ABC, $a = 7$, $b = 11$, and $C = 35^\\circ$. Find side $c$.",
        "options": [
          "6.62",
          "8.50",
          "5.75",
          "10.20"
        ],
        "answer": "A",
        "explanation": "$c^2 = a^2 + b^2 - 2ab \\cos C = 49 + 121 - 154(0.8192) = 170 - 126.16 = 43.84 \\implies c = \\sqrt{43.84} \\approx 6.62$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a triangle with sides $a = 8$, $b = 12$, and included angle $C = 45^\\circ$.",
        "options": [
          "$24\\sqrt{2}$",
          "$48$",
          "$24$",
          "$48\\sqrt{2}$"
        ],
        "answer": "A",
        "explanation": "$Area = \\frac{1}{2} ab \\sin C = \\frac{1}{2} \\cdot 8 \\cdot 12 \\cdot \\sin 45^\\circ = 48 \\cdot \\frac{\\sqrt{2}}{2} = 24\\sqrt{2}$."
      },
      {
        "type": "mcq",
        "question": "Find the magnitude of the vector $\\mathbf{v} = \\langle -5, 12 \\rangle$.",
        "options": [
          "13",
          "17",
          "7",
          "169"
        ],
        "answer": "A",
        "explanation": "$\\|\\mathbf{v}\\| = \\sqrt{(-5)^2 + 12^2} = \\sqrt{25 + 144} = \\sqrt{169} = 13$."
      },
      {
        "type": "mcq",
        "question": "Find the dot product of $\\mathbf{u} = \\langle 6, -2 \\rangle$ and $\\mathbf{v} = \\langle 3, 4 \\rangle$.",
        "options": [
          "10",
          "18",
          "14",
          "26"
        ],
        "answer": "A",
        "explanation": "$\\mathbf{u} \\cdot \\mathbf{v} = (6)(3) + (-2)(4) = 18 - 8 = 10$."
      },
      {
        "type": "mcq",
        "question": "A force of 50 N is applied at an angle of $60^\\circ$ to the horizontal. Find the horizontal component of the force.",
        "options": [
          "25 N",
          "43.3 N",
          "50 N",
          "100 N"
        ],
        "answer": "A",
        "explanation": "$F_x = F \\cos \\theta = 50 \\cdot \\cos 60^\\circ = 50 \\cdot 0.5 = 25$ N."
      },
      {
        "type": "mcq",
        "question": "Find the modulus $r$ and argument $\\theta$ for $z = 1 - i\\sqrt{3}$.",
        "options": [
          "$r = 2, \\theta = 300^\\circ$",
          "$r = 2, \\theta = 60^\\circ$",
          "$r = 4, \\theta = 300^\\circ$",
          "$r = 4, \\theta = 60^\\circ$"
        ],
        "answer": "A",
        "explanation": "$r = \\sqrt{1^2 + (-\\sqrt{3})^2} = \\sqrt{1 + 3} = 2$. $\\tan \\theta = -\\sqrt{3}$, Quadrant IV $\\implies \\theta = 300^\\circ$ (or $5\\pi/3$)."
      },
      {
        "type": "mcq",
        "question": "Multiply $z_1 = 4 \\text{ cis } 25^\\circ$ by $z_2 = 3 \\text{ cis } 40^\\circ$.",
        "options": [
          "$12 \\text{ cis } 65^\\circ$",
          "$12 \\text{ cis } 15^\\circ$",
          "$7 \\text{ cis } 65^\\circ$",
          "$7 \\text{ cis } 15^\\circ$"
        ],
        "answer": "A",
        "explanation": "$r = 4 \\times 3 = 12$, $\\theta = 25^\\circ + 40^\\circ = 65^\\circ$. So $z = 12 \\text{ cis } 65^\\circ = 12(\\cos 65^\\circ + i \\sin 65^\\circ)$."
      },
      {
        "type": "mcq",
        "question": "Find $(2 \\text{ cis } 15^\\circ)^4$.",
        "options": [
          "$8 + 8i\\sqrt{3}$",
          "$16 + 16i$",
          "$8 + 8i$",
          "$16 + 16i\\sqrt{3}$"
        ],
        "answer": "A",
        "explanation": "$r^4 = 2^4 = 16$, $\\theta = 4 \\times 15^\\circ = 60^\\circ$. $z^4 = 16 \\text{ cis } 60^\\circ = 16(\\cos 60^\\circ + i \\sin 60^\\circ) = 16(0.5 + i\\frac{\\sqrt{3}}{2}) = 8 + 8i\\sqrt{3}$."
      }
