{
  "quiz": {
    "title": "Pre-Calculus (Exam 24)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $b$ such that $x^2 + bx + 9 = 0$ has exactly one real solution, where $b < 0$.",
        "options": ["$b = -6$", "$b = 6$", "$b = -3$", "$b = 3$"],
        "answer": "A",
        "explanation": "For one solution, $b^2 - 4ac = 0$. $b^2 - 4(1)(9) = 0 \\implies b^2 = 36$. Since $b < 0$, $b = -6$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\sqrt{2x + 5} = x + 1$.",
        "options": ["$x = 2$", "$x = -2$", "$x = 2$ or $x = -2$", "No solution"],
        "answer": "A",
        "explanation": "Square both sides: $2x + 5 = x^2 + 2x + 1 \\implies x^2 = 4 \\implies x = \\pm 2$. $x = -2$ is extraneous, so $x = 2$."
      },
      {
        "type": "mcq",
        "question": "If $f(x)$ is an even function and $f(2) = 5$, evaluate $f(-2) - 10$.",
        "options": ["$-5$", "$5$", "$-15$", "$15$"],
        "answer": "A",
        "explanation": "Because $f$ is even, $f(-2) = f(2) = 5$. Thus, $5 - 10 = -5$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $f(f(0))$ if $f(x) = \\begin{cases} x + 2 & x \\le 1 \\\\ 3x & x > 1 \\end{cases}$.",
        "options": ["$6$", "$2$", "$8$", "$4$"],
        "answer": "A",
        "explanation": "$f(0) = 0 + 2 = 2$. Then $f(2) = 3(2) = 6$."
      },
      {
        "type": "mcq",
        "question": "Find the inverse of $f(x) = \\frac{x-1}{5}$.",
        "options": ["$f^{-1}(x) = 5x + 1$", "$f^{-1}(x) = 5x - 1$", "$f^{-1}(x) = \\frac{x+1}{5}$", "$f^{-1}(x) = \\frac{x-1}{5}$"],
        "answer": "A",
        "explanation": "$x = (y-1)/5 \\implies 5x = y - 1 \\implies y = 5x + 1$."
      },
      {
        "type": "mcq",
        "question": "Find the remainder when $x^4 - 2$ is divided by $x - 1$.",
        "options": ["$-1$", "$1$", "$0$", "$-2$"],
        "answer": "A",
        "explanation": "By the Remainder Theorem, $P(1) = 1^4 - 2 = -1$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to find the quotient of $(x^2 - 4) \\div (x + 2)$.",
        "options": ["$x - 2$", "$x + 2$", "$x - 4$", "$x + 4$"],
        "answer": "A",
        "explanation": "Coefficients [1, 0, -4] with divisor $-2$ gives [1, -2] and remainder $0$."
      },
      {
        "type": "mcq",
        "question": "How many sign changes are in $P(x) = x^3 - 4x^2 - 7x + 10$?",
        "options": ["$2$", "$3$", "$1$", "$0$"],
        "answer": "A",
        "explanation": "Changes occur from $+1$ to $-4$ and from $-7$ to $+10$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\frac{10}{x} = \\frac{5}{x-3}$.",
        "options": ["$x = 6$", "$x = 5$", "$x = 3$", "$x = 2$"],
        "answer": "A",
        "explanation": "$10(x-3) = 5x \\implies 10x - 30 = 5x \\implies 5x = 30 \\implies x = 6$."
      },
      {
        "type": "mcq",
        "question": "Solve the inequality $\\frac{x-2}{x} < 0$.",
        "options": ["$(0, 2)$", "$(-\\infty, 0) \\cup (2, \\infty)$", "$(2, \\infty)$", "$(-\\infty, 0)$"],
        "answer": "A",
        "explanation": "Critical values at $x = 0$ and $x = 2$. Testing intervals shows the fraction is negative between them."
      },
      {
        "type": "mcq",
        "question": "Find the horizontal asymptote of $f(x) = \\frac{3x + 1}{x - 5}$.",
        "options": ["$y = 3$", "$y = 0$", "$y = 1$", "$y = 5$"],
        "answer": "A",
        "explanation": "The degrees of the numerator and denominator are equal, so $y = 3/1 = 3$."
      },
      {
        "type": "mcq",
        "question": "Find $B$ in $\\frac{1}{x(x+1)} = \\frac{A}{x} + \\frac{B}{x+1}$.",
        "options": ["$B = -1$", "$B = 1$", "$B = 0$", "$B = 2$"],
        "answer": "A",
        "explanation": "Cover-up at $x = -1$: $B = \\frac{1}{-1} = -1$."
      },
      {
        "type": "mcq",
        "question": "Find the value of $f(0)$ for $f(x) = 2^{x+3} - 5$.",
        "options": ["$3$", "$8$", "$-3$", "$0$"],
        "answer": "A",
        "explanation": "$2^{0+3} - 5 = 2^3 - 5 = 8 - 5 = 3$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_{10}(0.1)$.",
        "options": ["$-1$", "$1$", "$0$", "$10$"],
        "answer": "A",
        "explanation": "$0.1 = 10^{-1}$, so $\\log_{10}(0.1) = -1$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_9 3$.",
        "options": ["$0.5$", "$2$", "$1$", "$3$"],
        "answer": "A",
        "explanation": "$\\log_9 3 = \\frac{\\log 3}{\\log 9} = \\frac{\\log 3}{2\\log 3} = 1/2 = 0.5$."
      },
      {
        "type": "mcq",
        "question": "Solve $3^{2x} = 81$.",
        "options": ["$x = 2$", "$x = 3$", "$x = 4$", "$x = 1$"],
        "answer": "A",
        "explanation": "$3^{2x} = 3^4 \\implies 2x = 4 \\implies x = 2$."
      },
      {
        "type": "mcq",
