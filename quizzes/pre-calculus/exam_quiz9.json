    "questions": [
      {
        "type": "mcq",
        "question": "If the quadratic equation $kx^2 + 4x + k = 0$ has exactly one real solution, find the positive value of $k$.",
        "options": ["$2$", "$4$", "$1$", "$3$"],
        "answer": "A",
        "explanation": "$b^2 - 4ac = 0 \\implies 16 - 4(k)(k) = 0 \\implies 16 = 4k^2 \\implies k^2 = 4 \\implies k = 2$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\sqrt{3x + 1} = x - 3$.",
        "options": ["$x = 8$", "$x = 1$", "$x = 8, 1$", "$x = 10$"],
        "answer": "A",
        "explanation": "$3x + 1 = (x - 3)^2 \\implies 3x + 1 = x^2 - 6x + 9 \\implies x^2 - 9x + 8 = 0 \\implies (x-8)(x-1) = 0$. $x=1$ is extraneous because $\\sqrt{4} \\neq -2$."
      },
      {
        "type": "mcq",
        "question": "If $g(x) = \\frac{x^2 - 4}{x}$, determine the value of $g(2) + g(-2)$.",
        "options": ["$0$", "$2$", "$-2$", "$4$"],
        "answer": "A",
        "explanation": "$g(2) = (4-4)/2 = 0$. $g(-2) = (4-4)/(-2) = 0$. $0 + 0 = 0$."
      },
      {
        "type": "mcq",
        "question": "Find the point of intersection between the two pieces of $f(x) = \\begin{cases} 2x + 1 & x < 3 \\\\ -x + 10 & x \\ge 3 \\end{cases}$.",
        "options": ["$(3, 7)$", "$(3, 5)$", "$(2, 5)$", "$(4, 6)$"],
        "answer": "A",
        "explanation": "At $x=3$, piece one gives $2(3)+1=7$ and piece two gives $-3+10=7$."
      },
      {
        "type": "mcq",
        "question": "Find $f^{-1}(x)$ for $f(x) = \\frac{x}{x + 5}$.",
