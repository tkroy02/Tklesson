    "questions": [
      {
        "type": "mcq",
        "question": "Determine the value of $k$ such that the quadratic $3x^2 - 6x + k = 0$ has two non-real complex roots.",
        "options": ["$k > 3$", "$k < 3$", "$k \\ge 3$", "$k \\le 3$"],
        "answer": "A",
        "explanation": "Discriminant $b^2 - 4ac < 0 \\implies 36 - 12k < 0 \\implies 36 < 12k \\implies k > 3$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\sqrt{2x + 15} = x$.",
        "options": ["$5$", "$-3$", "$5, -3$", "No solution"],
        "answer": "A",
        "explanation": "$2x + 15 = x^2 \\implies x^2 - 2x - 15 = 0 \\implies (x-5)(x+3) = 0$. $x=5$ checks, $x=-3$ is extraneous."
      },
      {
        "type": "mcq",
        "question": "If $f(x)$ is an even function and $f(-4) = 12$, find $2f(4) - 5$.",
