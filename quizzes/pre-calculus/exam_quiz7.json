    "questions": [
      {
        "type": "mcq",
        "question": "Find all values of $k$ such that $x^2 + 6x + k = 0$ has two distinct non-real complex solutions.",
        "options": ["$k > 9$", "$k < 9$", "$k \\ge 9$", "$k \\le 9$"],
        "answer": "A",
        "explanation": "For non-real solutions, the discriminant $b^2 - 4ac < 0$. $36 - 4k < 0 \\implies 36 < 4k \\implies k > 9$."
      },
      {
        "type": "mcq",
        "question": "Solve $|2x - 5| = |x + 4|$.",
        "options": ["$x = 9, x = 1/3$", "$x = 9, x = -1/3$", "$x = -9, x = 1/3$", "$x = -9, x = -1/3$"],
        "answer": "A",
        "explanation": "Case 1: $2x-5 = x+4 \\implies x=9$. Case 2: $2x-5 = -(x+4) \\implies 3x=1 \\implies x=1/3$."
      },
      {
        "type": "mcq",
        "question": "If $f(x)$ is an odd function and $f(3) = -4$, find the value of $2f(-3) + 5$.",
        "options": ["$13$", "$-13$", "$3$", "$-3$"],
        "answer": "A",
        "explanation": "Since $f$ is odd, $f(-3) = -f(3) = 4$. Thus, $2(4) + 5 = 13$."
      },
