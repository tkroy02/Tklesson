{
  "quiz": {
    "title": "Pre-Calculus (Exam 5)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "For what value of $k$ does $x^2 + kx + 16 = 0$ have exactly one real solution?",
        "options": ["$\\pm 8$", "$8$", "$-8$", "$16$"],
        "answer": "A",
        "explanation": "Set discriminant to zero: $k^2 - 4(1)(16) = 0 \\implies k^2 = 64 \\implies k = \\pm 8$."
      },
      {
        "type": "mcq",
        "question": "Solve the rational equation $\\frac{x^2-9}{x-3} = 4$.",
        "options": ["$x = 1$", "$x = 3$", "$x = -3$", "No solution"],
        "answer": "A",
        "explanation": "Simplify: $\\frac{(x-3)(x+3)}{x-3} = x+3$ for $x \\neq 3$. Then $x+3 = 4 \\implies x = 1$. Check: $1$ is valid."
      },
      {
        "type": "mcq",
        "question": "Determine the symmetry of $f(x) = x \\cos(x)$.",
        "options": ["Odd", "Even", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)\\cos(-x) = -x\\cos(x) = -f(x)$, so odd."
      },
      {
        "type": "mcq",
        "question": "Find the value of $c$ that makes $f(x) = \\begin{cases} cx + 1 & x \\le 2 \\\\ x^2 - 1 & x > 2 \\end{cases}$ continuous at $x=2$.",
        "options": ["$1$", "$2$", "$0$", "$-1$"],
        "answer": "A",
        "explanation": "$2c + 1 = 2^2 - 1 \\implies 2c + 1 = 3 \\implies c = 1$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\frac{x+1}{x-2}$, find the vertical asymptote of $f^{-1}(x)$.",
        "options": ["$x = 1$", "$x = 2$", "$x = -1$", "$x = 0$"],
        "answer": "A",
        "explanation": "The vertical asymptote of the inverse is the horizontal asymptote of the original: $y = 1/1 = 1$."
      },
      {
        "type": "mcq",
        "question": "What is the remainder when $x^{100} - 1$ is divided by $x - 1$?",
        "options": ["$0$", "$1$", "$-1$", "$2$"],
        "answer": "A",
        "explanation": "By the Remainder Theorem, $P(1) = 1^{100} - 1 = 0$."
      },
      {
        "type": "mcq",
        "question": "If synthetic division of $P(x)$ by $(x-2)$ yields a final row of $[1, 0, 4, 0]$, what is $P(x)$?",
        "options": ["$x^3 - 2x^2 + 4x - 8$", "$x^3 + 4x$", "$x^3 - 2x^2 + 4x$", "$x^3 + 4x - 8$"],
        "answer": "A",
        "explanation": "The coefficients give quotient $x^2 + 4$, remainder $0$. Multiply: $(x-2)(x^2+4) = x^3 - 2x^2 + 4x - 8$."
      },
      {
        "type": "mcq",
        "question": "Find the maximum number of negative real zeros for $P(x) = x^3 - x^2 - x - 1$.",
        "options": ["$2$", "$1$", "$3$", "$0$"],
        "answer": "A",
        "explanation": "$P(-x) = -x^3 - x^2 + x - 1$ has 2 sign changes, so maximum negative zeros = 2."
      },
      {
        "type": "mcq",
        "question": "Solve for $x$: $\\frac{1}{x} + \\frac{1}{2} = \\frac{1}{3}$.",
        "options": ["$x = -6$", "$x = 6$", "$x = -2$", "$x = 2$"],
        "answer": "A",
        "explanation": "$1/x = 1/3 - 1/2 = -1/6 \\implies x = -6$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{x-1}{x^2} > 0$.",
        "options": ["$x > 1$", "$x < 1$", "$x > 0$", "$x < 0$"],
        "answer": "A",
        "explanation": "$x^2 > 0$ for $x \\neq 0$, so inequality reduces to $x-1 > 0 \\implies x > 1$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\frac{4x^2-1}{2x^2+5}$, find the equation of the horizontal asymptote.",
        "options": ["$y = 2$", "$y = 4$", "$y = 1/2$", "$y = 0$"],
        "answer": "A",
        "explanation": "Ratio of leading coefficients: $4/2 = 2$."
      },
      {
        "type": "mcq",
        "question": "Find the value of $A$ in $\\frac{1}{(x-1)(x+2)} = \\frac{A}{x-1} + \\frac{B}{x+2}$.",
        "options": ["$1/3$", "$-1/3$", "$1/2$", "$-1/2$"],
        "answer": "A",
        "explanation": "Cover-up at $x=1$: $A = 1/(1+2) = 1/3$."
      },
      {
        "type": "mcq",
        "question": "Find the domain of $f(x) = 5^{1/x}$.",
        "options": ["$x \\neq 0$", "$x > 0$", "$x < 0$", "All real numbers"],
        "answer": "A",
        "explanation": "The exponent $1/x$ is undefined at $x=0$."
      },
      {
        "type": "mcq",
        "question": "Simplify $e^{2\\ln x}$.",
        "options": ["$x^2$", "$2x$", "$e^{2x}$", "$\\ln(x^2)$"],
        "answer": "A",
        "explanation": "$e^{2\\ln x} = e^{\\ln(x^2)} = x^2$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_{9} 27$.",
        "options": ["$3/2$", "$2/3$", "$3$", "$2$"],
        "answer": "A",
        "explanation": "$\\frac{\\log 27}{\\log 9} = \\frac{3\\log 3}{2\\log 3} = 3/2$."
      },
      {
        "type": "mcq",
        "question": "Solve $8^x = 4^{x+1}$.",
        "options": ["$x = 2$", "$x = 1$", "$x = 0$", "$x = -2$"],
        "answer": "A",
        "explanation": "$2^{3x} = 2^{2x+2} \\implies 3x = 2x + 2 \\implies x = 2$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log_x 64 = 3$.",
        "options": ["$4$", "$2$", "$8$", "$16$"],
        "answer": "A",
        "explanation": "$x^3 = 64 \\implies x = 4$."
      },
      {
        "type": "mcq",
        "question": "If a substance has a half-life of 10 years, find the decay constant $k$ in $A = A_0 e^{kt}$.",
        "options": ["$-\\ln 2 / 10$", "$\\ln 2 / 10$", "$-\\ln 10 / 2$", "$\\ln 10 / 2$"],
        "answer": "A",
        "explanation": "$0.5 = e^{10k} \\implies \\ln(0.5) = 10k \\implies k = -\\ln 2 / 10$."
      },
      {
        "type": "mcq",
        "question": "If $A$ is $3 \\times 2$ and $B$ is $2 \\times 3$, is $AB$ a square matrix?",
        "options": ["Yes", "No", "Only if $A = B$", "Only if $A$ and $B$ commute"],
        "answer": "A",
        "explanation": "Dimensions of $AB$ are $3 \\times 3$, so it is square."
      },
      {
        "type": "mcq",
        "question": "Apply $R_2 - 2R_1 \\to R_2$ to the matrix $\\begin{bmatrix} 1 & 2 \\\\ 2 & 5 \\end{bmatrix}$. What is the new second row?",
        "options": ["$[0, 1]$", "$[0, 0]$", "$[1, 1]$", "$[2, 5]$"],
        "answer": "A",
        "explanation": "$[2,5] - 2[1,2] = [2-2, 5-4] = [0,1]$."
      },
      {
        "type": "mcq",
        "question": "Find the inverse of $\\begin{bmatrix} 2 & 0 \\\\ 0 & 0.5 \\end{bmatrix}$.",
        "options": ["$\\begin{bmatrix} 0.5 & 0 \\\\ 0 & 2 \\end{bmatrix}$", "$\\begin{bmatrix} 2 & 0 \\\\ 0 & 0.5 \\end{bmatrix}$", "$\\begin{bmatrix} 1 & 0 \\\\ 0 & 1 \\end{bmatrix}$", "$\\begin{bmatrix} 0 & 2 \\\\ 0.5 & 0 \\end{bmatrix}$"],
        "answer": "A",
        "explanation": "For a diagonal matrix, the inverse is the reciprocal of each diagonal element."
      },
      {
        "type": "mcq",
        "question": "Find the determinant of $\\begin{bmatrix} \\cos\\theta & -\\sin\\theta \\\\ \\sin\\theta & \\cos\\theta \\end{bmatrix}$.",
        "options": ["$1$", "$0$", "$-1$", "$\\cos^2\\theta - \\sin^2\\theta$"],
        "answer": "A",
        "explanation": "$\\cos^2\\theta - (-\\sin^2\\theta) = \\cos^2\\theta + \\sin^2\\theta = 1$."
      },
      {
        "type": "mcq",
        "question": "Find the complement of $\\pi/6$ in radians.",
        "options": ["$\\pi/3$", "$\\pi/2$", "$\\pi/4$", "$2\\pi/3$"],
        "answer": "A",
        "explanation": "$\\pi/2 - \\pi/6 = 3\\pi/6 - \\pi/6 = 2\\pi/6 = \\pi/3$."
      },
      {
        "type": "mcq",
        "question": "If the arc length is $\\pi$ and the radius is 6, find the central angle in degrees.",
        "options": ["$30^\\circ$", "$60^\\circ$", "$45^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$\\theta = s/r = \\pi/6$ radians $= 30^\\circ$."
      },
      {
        "type": "mcq",
        "question": "A sector has an area of $12\\pi$ and a radius of 6. Find the central angle in radians.",
        "options": ["$2\\pi/3$", "$\\pi/3$", "$\\pi/2$", "$\\pi/4$"],
        "answer": "A",
        "explanation": "$12\\pi = \\frac{1}{2}(36)\\theta \\implies 12\\pi = 18\\theta \\implies \\theta = 2\\pi/3$."
      },
      {
        "type": "mcq",
        "question": "Find the reference angle for $-300^\\circ$.",
        "options": ["$60^\\circ$", "$30^\\circ$", "$45^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$-300^\\circ + 360^\\circ = 60^\\circ$, which is in Quadrant I."
      },
      {
        "type": "mcq",
        "question": "In a 30-60-90 triangle, if the shorter leg is 5, find the length of the altitude to the hypotenuse.",
        "options": ["$2.5\\sqrt{3}$", "$5\\sqrt{3}$", "$5$", "$10$"],
        "answer": "A",
        "explanation": "Hypotenuse = 10. Area = $\\frac{1}{2}(5)(5\\sqrt{3}) = \\frac{25\\sqrt{3}}{2}$. Also Area = $\\frac{1}{2}(10)h \\implies h = 2.5\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\csc(210^\\circ)$.",
        "options": ["$-2$", "$2$", "$-1/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\sin(210^\\circ) = -1/2$, so $\\csc = -2$."
      },
      {
        "type": "mcq",
        "question": "If the sun is at an angle of elevation of $60^\\circ$, how long is the shadow of a 10m pole?",
        "options": ["$10/\\sqrt{3}$", "$10\\sqrt{3}$", "$10$", "$5$"],
        "answer": "A",
        "explanation": "$\\tan 60^\\circ = 10/x \\implies \\sqrt{3} = 10/x \\implies x = 10/\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Find the period of $f(x) = \\tan(3x)$.",
        "options": ["$\\pi/3$", "$\\pi$", "$2\\pi/3$", "$2\\pi$"],
        "answer": "A",
        "explanation": "Period of $\\tan(bx) = \\pi/|b| = \\pi/3$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sin(\\arccos(3/5))$.",
        "options": ["$4/5$", "$3/5$", "$1/5$", "$2/5$"],
        "answer": "A",
        "explanation": "If $\\cos\\theta = 3/5$, then $\\sin\\theta = 4/5$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\tan(\\arctan(100))$.",
        "options": ["$100$", "$1$", "$0$", "$undefined$"],
        "answer": "A",
        "explanation": "$f(f^{-1}(x)) = x$ for the tangent domain."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sin(75^\\circ)$ using $\\sin(45^\\circ+30^\\circ)$.",
        "options": ["$(\\sqrt{6}+\\sqrt{2})/4$", "$(\\sqrt{6}-\\sqrt{2})/4$", "$\\sqrt{3}/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\sin45\\cos30 + \\cos45\\sin30 = (\\sqrt{2}/2)(\\sqrt{3}/2) + (\\sqrt{2}/2)(1/2) = (\\sqrt{6}+\\sqrt{2})/4$."
      },
      {
        "type": "mcq",
        "question": "If $\\tan A = 2$ and $\\tan B = 3$, find $\\tan(A+B)$.",
        "options": ["$-1$", "$1$", "$5$", "$-5$"],
        "answer": "A",
        "explanation": "$(2+3)/(1-2\\cdot3) = 5/(1-6) = 5/(-5) = -1$."
      },
      {
        "type": "mcq",
        "question": "If $\\cos\\theta = 1/3$, find $\\cos(2\\theta)$.",
        "options": ["$-7/9$", "$7/9$", "$-2/9$", "$2/9$"],
        "answer": "A",
        "explanation": "$2(1/3)^2 - 1 = 2/9 - 1 = -7/9$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sin(22.5^\\circ)$ using the half-angle formula.",
        "options": ["$\\sqrt{2-\\sqrt{2}}/2$", "$\\sqrt{2+\\sqrt{2}}/2$", "$\\sqrt{2}/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\sqrt{(1-\\cos45)/2} = \\sqrt{(1-\\sqrt{2}/2)/2} = \\sqrt{(2-\\sqrt{2})/4} = \\sqrt{2-\\sqrt{2}}/2$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\cos(75^\\circ) + \\cos(15^\\circ)$.",
        "options": ["$\\sqrt{6}/2$", "$\\sqrt{2}/2$", "$\\sqrt{3}/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$2\\cos45\\cos30 = 2(\\sqrt{2}/2)(\\sqrt{3}/2) = \\sqrt{6}/2$."
      },
      {
        "type": "mcq",
        "question": "Solve $2\\cos^2x + \\cos x = 0$ for $\\cos x$.",
        "options": ["$0, -1/2$", "$0, 1/2$", "$1, -1/2$", "$0, 1$"],
        "answer": "A",
        "explanation": "$\\cos x(2\\cos x + 1) = 0 \\implies \\cos x = 0$ or $\\cos x = -1/2$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\sin x = 0.2$ for $x$. (Express using inverse trig).",
        "options": ["$\\arcsin(0.2)$", "$\\arccos(0.2)$", "$\\arctan(0.2)$", "$\\sec^{-1}(0.2)$"],
        "answer": "A",
        "explanation": "Direct application of the inverse sine function."
      },
      {
        "type": "mcq",
        "question": "How many solutions are in $[0, 2\\pi)$ for $\\sin(2x) = 1$?",
        "options": ["$2$", "$1$", "$3$", "$4$"],
        "answer": "A",
        "explanation": "$2x = \\pi/2, 5\\pi/2 \\implies x = \\pi/4, 5\\pi/4$ → 2 solutions."
      },
      {
        "type": "mcq",
        "question": "Find the area of an equilateral triangle with side length 4.",
        "options": ["$4\\sqrt{3}$", "$8\\sqrt{3}$", "$16\\sqrt{3}$", "$2\\sqrt{3}$"],
        "answer": "A",
        "explanation": "$(s^2\\sqrt{3})/4 = (16\\sqrt{3})/4 = 4\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Convert $1 - i$ to polar form (using radians).",
        "options": ["$\\sqrt{2} \\text{ cis}(7\\pi/4)$", "$\\sqrt{2} \\text{ cis}(\\pi/4)$", "$2 \\text{ cis}(7\\pi/4)$", "$2 \\text{ cis}(\\pi/4)$"],
        "answer": "A",
        "explanation": "$r = \\sqrt{2}$, $\\theta = \\arctan(-1) = 7\\pi/4$."
      },
      {
        "type": "mcq",
        "question": "Find the argument of $z_1 / z_2$ if $\\arg(z_1) = \\pi$ and $\\arg(z_2) = \\pi/3$.",
        "options": ["$2\\pi/3$", "$\\pi/3$", "$4\\pi/3$", "$\\pi$"],
        "answer": "A",
        "explanation": "$\\arg(z_1/z_2) = \\arg(z_1) - \\arg(z_2) = \\pi - \\pi/3 = 2\\pi/3$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $(1+i)^8$.",
        "options": ["$16$", "$8$", "$4$", "$32$"],
        "answer": "A",
        "explanation": "$(\\sqrt{2} \\text{ cis }45)^8 = 16 \\text{ cis }360 = 16$."
      },
      {
        "type": "mcq",
        "question": "Find the 3rd coefficient in the expansion of $(x+y)^4$.",
        "options": ["$6$", "$4$", "$3$", "$2$"],
        "answer": "A",
        "explanation": "Pascal's triangle row 4: 1, 4, 6, 4, 1 → 3rd coefficient = 6."
      },
      {
        "type": "mcq",
        "question": "How many 5-letter 'words' can be formed from 'APPLE'?",
        "options": ["$60$", "$120$", "$30$", "$24$"],
        "answer": "A",
        "explanation": "$5! / 2! = 120 / 2 = 60$ (due to two P's)."
      },
      {
        "type": "mcq",
        "question": "Evaluate $nCr$ where $n=6, r=4$.",
        "options": ["$15$", "$20$", "$10$", "$5$"],
        "answer": "A",
        "explanation": "$\\binom{6}{4} = \\binom{6}{2} = (6 \\times 5)/2 = 15$."
      },
      {
        "type": "mcq",
        "question": "If two dice are rolled, what is the probability that the sum is 12?",
        "options": ["$1/36$", "$1/6$", "$1/12$", "$1/18$"],
        "answer": "A",
        "explanation": "Only one outcome (6,6) out of 36 possibilities."
      },
      {
        "type": "mcq",
        "question": "Find the coordinates of the focus for $y^2 = -8x$.",
        "options": ["$(-2, 0)$", "$(2, 0)$", "$(0, -2)$", "$(0, 2)$"],
        "answer": "A",
        "explanation": "$4p = -8 \\implies p = -2$. Parabola opens left, focus at $(-2,0)$."
      },
      {
        "type": "mcq",
        "question": "Find the distance between the foci of $\\frac{x^2}{25} + \\frac{y^2}{16} = 1$.",
        "options": ["$6$", "$8$", "$10$", "$4$"],
        "answer": "A",
        "explanation": "$c^2 = 25 - 16 = 9 \\implies c = 3$. Distance = $2c = 6$."
      }
    ]
  }
}
