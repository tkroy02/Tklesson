      {
        "type": "mcq",
        "question": "In triangle ABC, $A = 25^\\circ$, $B = 75^\\circ$, and side $a = 10$. Find side $b$.",
        "options": [
          "22.86",
          "15.50",
          "10.00",
          "18.38"
        ],
        "answer": "A",
        "explanation": "$\\frac{a}{\\sin A} = \\frac{b}{\\sin B} \\implies \\frac{10}{\\sin 25^\\circ} = \\frac{b}{\\sin 75^\\circ} \\implies b = \\frac{10 \\cdot 0.9659}{0.4226} \\approx 22.86$."
      },
      {
        "type": "mcq",
        "question": "Given triangle ABC with $A = 30^\\circ$, $a = 6$, and $b = 8$. Calculate the height $h$.",
        "options": [
          "4",
          "6.93",
          "5.66",
          "8.00"
        ],
        "answer": "A",
        "explanation": "$h = b \\sin A = 8 \\cdot \\sin 30^\\circ = 8 \\cdot 0.5 = 4$."
      },
      {
        "type": "mcq",
        "question": "In triangle ABC, $a = 9$, $b = 12$, and $C = 40^\\circ$. Find side $c$.",
        "options": [
          "7.72",
          "8.50",
          "6.62",
          "10.20"
        ],
        "answer": "A",
        "explanation": "$c^2 = a^2 + b^2 - 2ab \\cos C = 81 + 144 - 216(0.7660) = 225 - 165.46 = 59.54 \\implies c = \\sqrt{59.54} \\approx 7.72$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a triangle with sides $a = 10$, $b = 14$, and included angle $C = 30^\\circ$.",
        "options": [
          "35",
          "70",
          "35\\sqrt{3}",
          "70\\sqrt{3}"
        ],
        "answer": "A",
        "explanation": "$Area = \\frac{1}{2} ab \\sin C = \\frac{1}{2} \\cdot 10 \\cdot 14 \\cdot \\sin 30^\\circ = 70 \\cdot 0.5 = 35$."
      },
      {
        "type": "mcq",
        "question": "Find the magnitude of the vector $\\mathbf{v} = \\langle 8, -15 \\rangle$.",
        "options": [
          "17",
          "13",
          "23",
          "289"
        ],
        "answer": "A",
        "explanation": "$\\|\\mathbf{v}\\| = \\sqrt{8^2 + (-15)^2} = \\sqrt{64 + 225} = \\sqrt{289} = 17$."
      },
      {
        "type": "mcq",
        "question": "Find the dot product of $\\mathbf{u} = \\langle -3, 7 \\rangle$ and $\\mathbf{v} = \\langle 4, 2 \\rangle$.",
        "options": [
          "2",
          "-12",
          "14",
          "26"
        ],
        "answer": "A",
        "explanation": "$\\mathbf{u} \\cdot \\mathbf{v} = (-3)(4) + (7)(2) = -12 + 14 = 2$."
      },
      {
        "type": "mcq",
        "question": "A force of 100 N is applied at an angle of $30^\\circ$ to the horizontal. Find the vertical component of the force.",
        "options": [
          "50 N",
          "86.6 N",
          "100 N",
          "200 N"
        ],
        "answer": "A",
        "explanation": "$F_y = F \\sin \\theta = 100 \\cdot \\sin 30^\\circ = 100 \\cdot 0.5 = 50$ N."
      },
      {
        "type": "mcq",
        "question": "Find the modulus $r$ and argument $\\theta$ for $z = -\\sqrt{3} + i$.",
        "options": [
          "$r = 2, \\theta = 150^\\circ$",
          "$r = 2, \\theta = 30^\\circ$",
          "$r = 4, \\theta = 150^\\circ$",
          "$r = 4, \\theta = 30^\\circ$"
        ],
        "answer": "A",
        "explanation": "$r = \\sqrt{(-\\sqrt{3})^2 + 1^2} = \\sqrt{3 + 1} = 2$. $\\tan \\theta = -1/\\sqrt{3}$, Quadrant II $\\implies \\theta = 150^\\circ$ (or $5\\pi/6$)."
      },
      {
        "type": "mcq",
        "question": "Divide $z_1 = 10 \\text{ cis } 80^\\circ$ by $z_2 = 2 \\text{ cis } 20^\\circ$.",
        "options": [
          "$5 \\text{ cis } 60^\\circ$",
          "$5 \\text{ cis } 100^\\circ$",
          "$12 \\text{ cis } 60^\\circ$",
          "$12 \\text{ cis } 100^\\circ$"
        ],
        "answer": "A",
        "explanation": "$r = 10 / 2 = 5$, $\\theta = 80^\\circ - 20^\\circ = 60^\\circ$. So $z = 5 \\text{ cis } 60^\\circ = 5(\\cos 60^\\circ + i \\sin 60^\\circ) = 2.5 + 2.5i\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Find $(3 \\text{ cis } 10^\\circ)^3$.",
        "options": [
          "$27 \\text{ cis } 30^\\circ$",
          "$27 \\text{ cis } 10^\\circ$",
          "$9 \\text{ cis } 30^\\circ$",
          "$9 \\text{ cis } 10^\\circ$"
        ],
        "answer": "A",
        "explanation": "$r^3 = 3^3 = 27$, $\\theta = 3 \\times 10^\\circ = 30^\\circ$. $z^3 = 27 \\text{ cis } 30^\\circ = 27(\\cos 30^\\circ + i \\sin 30^\\circ) = \\frac{27\\sqrt{3}}{2} + \\frac{27}{2}i$."
      }
