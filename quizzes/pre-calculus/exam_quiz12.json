{
  "quiz": {
    "title": "Pre-Calculus (Exam 12)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "Find the range of $c$ such that $2x^2 - 4x + c = 0$ has no real solutions.",
        "options": ["$c > 2$", "$c < 2$", "$c \\ge 2$", "$c \\le 2$"],
        "answer": "A",
        "explanation": "$b^2 - 4ac < 0 \\implies 16 - 8c < 0 \\implies 16 < 8c \\implies c > 2$."
      },
      {
        "type": "mcq",
        "question": "Solve $|3x + 1| = 2x + 9$.",
        "options": ["$x = 8, -2$", "$x = 8$ only", "$x = -2$ only", "$x = 4, -6$"],
        "answer": "A",
        "explanation": "Case 1: $3x+1 = 2x+9 \\implies x=8$. Case 2: $3x+1 = -(2x+9) \\implies x=-2$. Both check."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = x^3 - x$, verify its symmetry.",
        "options": ["Odd", "Even", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)^3 - (-x) = -x^3 + x = -(x^3 - x) = -f(x)$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\begin{cases} 3-x & x < 1 \\\\ \\sqrt{x} & x \\ge 1 \\end{cases}$, evaluate $f(f(0))$.",
        "options": ["$\\sqrt{3}$", "$3$", "$0$", "$\\sqrt{0}$"],
        "answer": "A",
        "explanation": "$f(0) = 3-0 = 3$. Then $f(3) = \\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Find the inverse of $f(x) = \\frac{4}{x-2}$.",
        "options": ["$\\frac{4}{x} + 2$", "$\\frac{4}{x} - 2$", "$\\frac{x}{4} + 2$", "$\\frac{x}{4} - 2$"],
        "answer": "A",
        "explanation": "$x = 4/(y-2) \\implies y-2 = 4/x \\implies y = 4/x + 2$."
      },
      {
        "type": "mcq",
        "question": "Find the quotient when $x^3 - 1$ is divided by $x - 1$.",
        "options": ["$x^2 + x + 1$", "$x^2 - x + 1$", "$x^2 + x - 1$", "$x^2 - x - 1$"],
        "answer": "A",
        "explanation": "This is the difference of cubes factorization: $(x-1)(x^2+x+1)$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to evaluate $P(-3)$ for $P(x) = x^3 + 4x^2 - 5x + 1$.",
        "options": ["$25$", "$-25$", "$1$", "$-1$"],
        "answer": "A",
        "explanation": "Synthetic division by -3 yields remainder 25."
      },
      {
        "type": "mcq",
        "question": "How many possible negative real zeros are there for $f(x) = x^3 - x^2 - x - 1$?",
        "options": ["$2$ or $0$", "$1$ only", "$0$ only", "$3$ or $1$"],
        "answer": "A",
        "explanation": "$f(-x) = -x^3 - x^2 + x - 1$ has 2 sign changes, so possible negative zeros = 2 or 0."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{1}{x} + \\frac{1}{2x} = 6$.",
        "options": ["$x = 1/4$", "$x = 1/2$", "$x = 1/3$", "$x = 1/6$"],
        "answer": "A",
        "explanation": "$3/(2x) = 6 \\implies 3 = 12x \\implies x = 1/4$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{10}{x} \\le 2$.",
        "options": ["$(-\\infty, 0) \\cup [5, \\infty)$", "$(0, 5]$", "$(-\\infty, 5]$", "$[5, \\infty)$"],
        "answer": "A",
        "explanation": "Critical values at $x=0$ and $x=5$. Testing intervals gives $(-\\infty, 0) \\cup [5, \\infty)$."
      },
      {
        "type": "mcq",
        "question": "A painter can finish a job in 8 hours. With an assistant, they finish in 3 hours. How long would it take the assistant alone?",
        "options": ["$4.8$ hours", "$5$ hours", "$4$ hours", "$6$ hours"],
        "answer": "A",
        "explanation": "$1/8 + 1/x = 1/3 \\implies 1/x = 5/24 \\implies x = 24/5 = 4.8$."
      },
      {
        "type": "mcq",
        "question": "In $\\frac{4x}{(x-1)(x+1)} = \\frac{A}{x-1} + \\frac{B}{x+1}$, find $A$.",
        "options": ["$2$", "$1$", "$3$", "$4$"],
        "answer": "A",
        "explanation": "Cover-up at $x=1$: $A = 4(1)/(1+1) = 4/2 = 2$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $f(3)$ for $f(x) = 5 \\cdot 2^{x+1}$.",
        "options": ["$80$", "$40$", "$160$", "$20$"],
        "answer": "A",
        "explanation": "$5 \\cdot 2^{4} = 5 \\cdot 16 = 80$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\ln(e^x \\cdot e^y)$.",
        "options": ["$x + y$", "$xy$", "$e^{x+y}$", "$\\ln(x+y)$"],
        "answer": "A",
        "explanation": "$\\ln(e^{x+y}) = x + y$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_9 27$.",
        "options": ["$1.5$", "$2$", "$3$", "$0.5$"],
        "answer": "A",
        "explanation": "$\\frac{\\log_3 27}{\\log_3 9} = 3/2 = 1.5$."
      },
      {
        "type": "mcq",
        "question": "Solve $10^{x-1} = 5$.",
        "options": ["$1 + \\log 5$", "$\\log 5 - 1$", "$\\log 5$", "$1 - \\log 5$"],
        "answer": "A",
        "explanation": "$x-1 = \\log 5 \\implies x = 1 + \\log 5$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log_2(x) - \\log_2(x-1) = 3$.",
        "options": ["$8/7$", "$7/8$", "$4/3$", "$3/4$"],
        "answer": "A",
        "explanation": "$x/(x-1) = 8 \\implies x = 8x - 8 \\implies 7x = 8 \\implies x = 8/7$."
      },
      {
        "type": "mcq",
        "question": "If $1000 is invested at 5% compounded continuously, find the value after 10 years.",
        "options": ["$1000e^{0.5}$", "$1000e^{5}$", "$1000(1.05)^{10}$", "$1000(1.5)$"],
        "answer": "A",
        "explanation": "$A = Pe^{rt} = 1000e^{0.05 \\cdot 10} = 1000e^{0.5}$."
      },
      {
        "type": "mcq",
        "question": "If $A$ is $4 \\times 2$ and $B$ is $2 \\times 5$, what is the dimension of $AB$?",
        "options": ["$4 \\times 5$", "$2 \\times 2$", "$4 \\times 2$", "$5 \\times 4$"],
        "answer": "A",
        "explanation": "Matrix dimension rule: $(m \\times n)(n \\times p) = m \\times p$."
      },
      {
        "type": "mcq",
        "question": "Transform the matrix $\\begin{bmatrix} 2 & 4 \\\\ 1 & 3 \\end{bmatrix}$ using $R_1 \\leftrightarrow R_2$.",
        "options": ["$\\begin{bmatrix} 1 & 3 \\\\ 2 & 4 \\end{bmatrix}$", "$\\begin{bmatrix} 2 & 4 \\\\ 1 & 3 \\end{bmatrix}$", "$\\begin{bmatrix} 1 & 2 \\\\ 3 & 4 \\end{bmatrix}$", "$\\begin{bmatrix} 3 & 1 \\\\ 4 & 2 \\end{bmatrix}$"],
        "answer": "A",
        "explanation": "Swap the two rows."
      },
      {
        "type": "mcq",
        "question": "Find the determinant of $A = \\begin{bmatrix} 3 & 1 \\\\ 4 & 2 \\end{bmatrix}$ to determine if an inverse exists.",
        "options": ["$2$", "$-2$", "$10$", "$-10$"],
        "answer": "A",
        "explanation": "$3(2) - 1(4) = 6 - 4 = 2 \\neq 0$, so inverse exists."
      },
      {
        "type": "mcq",
        "question": "For a system of 2 equations, $D=5, D_y=15$. Find $y$.",
        "options": ["$3$", "$5$", "$15$", "$75$"],
        "answer": "A",
        "explanation": "$y = D_y/D = 15/5 = 3$."
      },
      {
        "type": "mcq",
        "question": "Find the complement of $\\pi/6$.",
        "options": ["$\\pi/3$", "$\\pi/2$", "$\\pi/4$", "$2\\pi/3$"],
        "answer": "A",
        "explanation": "$\\pi/2 - \\pi/6 = 3\\pi/6 - \\pi/6 = 2\\pi/6 = \\pi/3$."
      },
      {
        "type": "mcq",
        "question": "A pendulum of length 2m swings through an arc of 0.5m. Find the angle in radians.",
        "options": ["$0.25$", "$0.5$", "$1$", "$2$"],
        "answer": "A",
        "explanation": "$\\theta = s/r = 0.5/2 = 0.25$ rad."
      },
      {
        "type": "mcq",
        "question": "Find the area of a sector with diameter 12 and angle $120^\\circ$.",
        "options": ["$12\\pi$", "$6\\pi$", "$24\\pi$", "$36\\pi$"],
        "answer": "A",
        "explanation": "$r=6, \\theta=2\\pi/3$. Area $= 0.5(36)(2\\pi/3) = 12\\pi$."
      },
      {
        "type": "mcq",
        "question": "Find the reference angle for $240^\\circ$.",
        "options": ["$60^\\circ$", "$30^\\circ$", "$45^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$240 - 180 = 60^\\circ$."
      },
      {
        "type": "mcq",
        "question": "If $\\sin \\theta = 1/3$ and $\\theta$ is in Q1, find $\\tan \\theta$.",
        "options": ["$1/\\sqrt{8}$", "$1/3$", "$\\sqrt{8}$", "$3$"],
        "answer": "A",
        "explanation": "Opp=1, Hyp=3, Adj=$\\sqrt{8}$, $\\tan = 1/\\sqrt{8}$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\sin x \\sec x$.",
        "options": ["$\\tan x$", "$\\cot x$", "$\\csc x$", "$\\cos x$"],
        "answer": "A",
        "explanation": "$\\sin x \\cdot (1/\\cos x) = \\tan x$."
      },
      {
        "type": "mcq",
        "question": "A building 50m tall casts a shadow of 50m. Find the angle of elevation of the sun.",
        "options": ["$45^\\circ$", "$30^\\circ$", "$60^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$\\tan \\theta = 50/50 = 1 \\implies \\theta = 45^\\circ$."
      },
      {
        "type": "mcq",
        "question": "Find the period of $y = \\cos(x/4)$.",
        "options": ["$8\\pi$", "$2\\pi$", "$4\\pi$", "$\\pi/2$"],
        "answer": "A",
        "explanation": "$2\\pi / (1/4) = 8\\pi$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\arcsin(\\sin(5\\pi/6))$.",
        "options": ["$\\pi/6$", "$5\\pi/6$", "$\\pi/3$", "$2\\pi/3$"],
        "answer": "A",
        "explanation": "$\\sin(5\\pi/6) = 1/2$. $\\arcsin(1/2) = \\pi/6$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sec(\\arctan(1))$.",
        "options": ["$\\sqrt{2}$", "$1$", "$2$", "$1/\\sqrt{2}$"],
        "answer": "A",
        "explanation": "$\\arctan(1) = 45^\\circ$. $\\sec(45^\\circ) = \\sqrt{2}$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\cos(x - \\pi/2)$.",
        "options": ["$\\sin x$", "$\\cos x$", "$-\\sin x$", "$-\\cos x$"],
        "answer": "A",
        "explanation": "$\\cos(x - \\pi/2) = \\cos x \\cos(\\pi/2) + \\sin x \\sin(\\pi/2) = \\sin x$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\tan(x + \\pi)$.",
        "options": ["$\\tan x$", "$-\\tan x$", "$\\cot x$", "$-\\cot x$"],
        "answer": "A",
        "explanation": "Tangent has period $\\pi$."
      },
      {
        "type": "mcq",
        "question": "Find $\\sin 2\\theta$ if $\\sin \\theta = 0.6$ and $\\theta$ is in Q1.",
        "options": ["$0.96$", "$0.48$", "$0.64$", "$0.32$"],
        "answer": "A",
        "explanation": "$\\cos \\theta = 0.8$. $\\sin 2\\theta = 2(0.6)(0.8) = 0.96$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\frac{1 - \\cos 2x}{2}$.",
        "options": ["$\\sin^2 x$", "$\\cos^2 x$", "$\\sin x$", "$\\cos x$"],
        "answer": "A",
        "explanation": "This is the power reduction identity for sine."
      },
      {
        "type": "mcq",
        "question": "Rewrite $\\cos 5x + \\cos 3x$ as a product.",
        "options": ["$2\\cos 4x \\cos x$", "$2\\cos 4x \\sin x$", "$2\\sin 4x \\cos x$", "$2\\sin 4x \\sin x$"],
        "answer": "A",
        "explanation": "$2\\cos((5x+3x)/2)\\cos((5x-3x)/2) = 2\\cos 4x \\cos x$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\cos^2 x = 1$ on $[0, 2\\pi)$.",
        "options": ["$0, \\pi$", "$0$ only", "$\\pi$ only", "$\\pi/2, 3\\pi/2$"],
        "answer": "A",
        "explanation": "$\\cos x = \\pm 1$ gives $x = 0$ and $x = \\pi$."
      },
      {
        "type": "mcq",
        "question": "Solve $2\\arccos x = \\pi$.",
        "options": ["$0$", "$1$", "$-1$", "$\\pi/2$"],
        "answer": "A",
        "explanation": "$\\arccos x = \\pi/2 \\implies x = \\cos(\\pi/2) = 0$."
      },
      {
        "type": "mcq",
        "question": "Solve $2\\sin x + 1 = 0$ on $[0, 2\\pi)$.",
        "options": ["$7\\pi/6, 11\\pi/6$", "$\\pi/6, 5\\pi/6$", "$\\pi/3, 4\\pi/3$", "$2\\pi/3, 5\\pi/3$"],
        "answer": "A",
        "explanation": "$\\sin x = -1/2 \\implies x = 7\\pi/6, 11\\pi/6$."
      },
      {
        "type": "mcq",
        "question": "Find the area of an equilateral triangle with side 2.",
        "options": ["$\\sqrt{3}$", "$2\\sqrt{3}$", "$\\sqrt{3}/2$", "$1$"],
        "answer": "A",
        "explanation": "$0.5 \\cdot 2 \\cdot 2 \\cdot \\sin 60^\\circ = 2 \\cdot \\sqrt{3}/2 = \\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Find the modulus of $z = -3 + 4i$.",
        "options": ["$5$", "$7$", "$1$", "$25$"],
        "answer": "A",
        "explanation": "$\\sqrt{(-3)^2 + 4^2} = \\sqrt{25} = 5$."
      },
      {
        "type": "mcq",
        "question": "Divide $10\\text{cis } 80^\\circ$ by $2\\text{cis } 20^\\circ$.",
        "options": ["$5 \\text{ cis } 60^\\circ$", "$5 \\text{ cis } 100^\\circ$", "$12 \\text{ cis } 60^\\circ$", "$12 \\text{ cis } 100^\\circ$"],
        "answer": "A",
        "explanation": "Divide moduli: $10/2=5$, subtract arguments: $80-20=60$."
      },
      {
        "type": "mcq",
        "question": "Find $(i)^4$.",
        "options": ["$1$", "$-1$", "$i$", "$-i$"],
        "answer": "A",
        "explanation": "$i = \\text{cis }90^\\circ$, $i^4 = \\text{cis }360^\\circ = 1$."
      },
      {
        "type": "mcq",
        "question": "Find the coefficient of $x^2 y^2$ in $(x+y)^4$.",
        "options": ["$6$", "$4$", "$8$", "$2$"],
        "answer": "A",
        "explanation": "$4C2 = 6$."
      },
      {
        "type": "mcq",
        "question": "How many ways can 1st, 2nd, and 3rd place be awarded to 10 contestants?",
        "options": ["$720$", "$1000$", "$120$", "$30$"],
        "answer": "A",
        "explanation": "$10 \\cdot 9 \\cdot 8 = 720$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $10C8$.",
        "options": ["$45$", "$90$", "$10$", "$5$"],
        "answer": "A",
        "explanation": "$10C8 = 10C2 = (10 \\cdot 9)/2 = 45$."
      },
      {
        "type": "mcq",
        "question": "Probability of drawing a spade from a standard deck?",
        "options": ["$1/4$", "$1/2$", "$1/13$", "$1/52$"],
        "answer": "A",
        "explanation": "$13/52 = 1/4$."
      },
      {
        "type": "mcq",
        "question": "Find the axis of symmetry for $y = x^2 - 6x + 5$.",
        "options": ["$x = 3$", "$x = -3$", "$x = 6$", "$x = -6$"],
        "answer": "A",
        "explanation": "$x = -b/(2a) = 6/2 = 3$."
      },
      {
        "type": "mcq",
        "question": "Find the center of the ellipse $(x+2)^2/4 + (y-5)^2/9 = 1$.",
        "options": ["$(-2, 5)$", "$(2, -5)$", "$(2, 5)$", "$(-2, -5)$"],
        "answer": "A",
        "explanation": "Standard form $(x-h)^2/a^2 + (y-k)^2/b^2 = 1$ has center $(h,k)$."
      }
    ]
  }
}
