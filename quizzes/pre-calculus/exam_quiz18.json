    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $c$ such that $x^2 - 8x + c = 0$ has exactly one real solution.",
        "options": ["$c = 16$", "$c = 8$", "$c = 4$", "$c = 2$"],
        "answer": "A",
        "explanation": "For one real solution, the discriminant $b^2 - 4ac$ must be zero. $(-8)^2 - 4(1)(c) = 0 \\implies 64 = 4c \\implies c = 16$."
      },
      {
        "type": "mcq",
