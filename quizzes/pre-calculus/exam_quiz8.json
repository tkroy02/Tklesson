        "answer": "A",
        "explanation": "Expand: $2(8-1) - (-1)(12-0) + 0 = 2(7) + 12 = 14 + 12 = 26$."
      },
      {
        "type": "mcq",
        "question": "Find the supplement of $2\\pi/5$ radians.",
        "options": ["$3\\pi/5$", "$\\pi/5$", "$7\\pi/5$", "$8\\pi/5$"],
        "answer": "A",
        "explanation": "$\\pi - 2\\pi/5 = 3\\pi/5$."
      },
      {
        "type": "mcq",
        "question": "Find the radius of a circle where an angle of $2$ radians intercepts an arc of $10$ cm.",
        "options": ["$5$", "$10$", "$20$", "$2.5$"],
        "answer": "A",
        "explanation": "$r = s/\\theta = 10/2 = 5$."
      },
      {
        "type": "mcq",
        "question": "If the radius is doubled and the angle is halved, how does the area of the sector change?",
