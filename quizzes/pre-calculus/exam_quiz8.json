        "answer": "A",
        "explanation": "$4x = 0, 2\\pi, 4\\pi, 6\\pi, 8\\pi \\implies x = 0, \\pi/2, \\pi, 3\\pi/2, 2\\pi$."
      },
      {
        "type": "mcq",
        "question": "A triangle has sides 5, 12, and 13. Find its area.",
        "options": ["$30$", "$60$", "$78$", "$65$"],
        "answer": "A",
        "explanation": "It is a right triangle. $0.5 \\cdot 5 \\cdot 12 = 30$."
      },
      {
        "type": "mcq",
        "question": "Find the product of $2\\text{cis } 15^\\circ$ and $3\\text{cis } 75^\\circ$ in rectangular form.",
        "options": ["$6i$", "$-6i$", "$6$", "$-6$"],
        "answer": "A",
        "explanation": "$6\\text{cis } 90^\\circ = 6(0 + i) = 6i$."
      },
      {
        "type": "mcq",
        "question": "Find the modulus of $z = \\frac{(1+i)^4}{(1-i)^2}$.",
        "options": ["$2$", "$4$", "$1$", "$8$"],
        "answer": "A",
        "explanation": "$|1+i| = \\sqrt{2}$, $|1-i| = \\sqrt{2}$. Result $= (\\sqrt{2})^4 / (\\sqrt{2})^2 = (\\sqrt{2})^2 = 2$."
      },
      {
        "type": "mcq",
        "question": "Find $(-\\sqrt{3} + i)^3$.",
        "options": ["$8i$", "$-8i$", "$8$", "$-8$"],
        "answer": "A",
        "explanation": "Polar: $2\\text{cis } 150^\\circ$. Cube: $8\\text{cis } 450^\\circ = 8\\text{cis } 90^\\circ = 8i$."
      },
      {
        "type": "mcq",
        "question": "Find the constant term in the expansion of $(x + 1/x)^4$.",
