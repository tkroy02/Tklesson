{
  "quiz": {
    "title": "Pre-Calculus (Exam 8)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "If the discriminant of $x^2 + bx + 9 = 0$ is zero, what are the possible values for $b$?",
        "options": ["$\\pm 6$", "$6$ only", "$-6$ only", "$\\pm 3$"],
        "answer": "A",
        "explanation": "$b^2 - 4(1)(9) = 0 \\implies b^2 = 36 \\implies b = \\pm 6$."
      },
      {
        "type": "mcq",
        "question": "Solve for $x$: $\\sqrt{x + 7} = x - 5$.",
        "options": ["$x = 9$", "$x = 2$", "$x = 9, 2$", "$x = -9$"],
        "answer": "A",
        "explanation": "$x + 7 = (x-5)^2 \\implies x + 7 = x^2 - 10x + 25 \\implies x^2 - 11x + 18 = 0 \\implies (x-9)(x-2)=0$. $x=2$ is extraneous since $\\sqrt{9} \\neq -3$."
      },
      {
        "type": "mcq",
        "question": "If $f(x)$ is an even function and the point $(4, -7)$ is on its graph, what point must also be on the graph of $y = 3f(x)$?",
        "options": ["$(-4, -21)$", "$(-4, -7)$", "$(4, -21)$", "$(4, 21)$"],
        "answer": "A",
        "explanation": "Even symmetry implies $(-4, -7)$ is on $f(x)$. The vertical stretch by 3 multiplies the y-coordinate: $(-4, -21)$."
      },
      {
        "type": "mcq",
        "question": "Find the range of $f(x) = \\begin{cases} -x + 2 & x \\le 0 \\\\ x^2 + 2 & x > 0 \\end{cases}$.",
        "options": ["$[2, \\infty)$", "$(2, \\infty)$", "$(-\\infty, 2]$", "$(-\\infty, 2)$"],
        "answer": "A",
        "explanation": "For $x \\le 0$, y-values start at 2 and increase. For $x > 0$, y-values start at 2 and increase. The minimum y-value is 2."
      },
      {
        "type": "mcq",
        "question": "Find $f^{-1}(10)$ given $f(x) = \\frac{2x + 4}{x - 3}$.",
        "options": ["$17/4$", "$4$", "$3$", "$5$"],
        "answer": "A",
        "explanation": "Set $f(x) = 10$: $10 = (2x+4)/(x-3) \\implies 10x - 30 = 2x + 4 \\implies 8x = 34 \\implies x = 34/8 = 17/4$."
      },
      {
        "type": "mcq",
        "question": "What is the quotient when $x^3 + 8$ is divided by $x + 2$?",
        "options": ["$x^2 - 2x + 4$", "$x^2 + 2x + 4$", "$x^2 - 4x + 4$", "$x^2 + 4x + 4$"],
        "answer": "A",
        "explanation": "This follows the sum of cubes factorization: $(x+2)(x^2 - 2x + 4)$."
      },
      {
        "type": "mcq",
        "question": "Using synthetic division to divide $x^4 - 16$ by $x - 2$, what is the third coefficient in the resulting quotient row?",
        "options": ["$4$", "$2$", "$8$", "$1$"],
        "answer": "A",
        "explanation": "Coefficients: [1, 0, 0, 0, -16]. Synthetic division yields quotient [1, 2, 4, 8]. The third coefficient is 4."
      },
      {
        "type": "mcq",
        "question": "Identify the number of possible *negative* real zeros for $P(x) = x^4 + 2x^3 + 3x^2 + 4x + 5$.",
        "options": ["$4, 2, \\text{ or } 0$", "$3, 1$", "$2, 0$", "$1$ only"],
        "answer": "A",
        "explanation": "$P(-x) = x^4 - 2x^3 + 3x^2 - 4x + 5$. There are 4 sign changes, so possible negative zeros = 4, 2, or 0."
      },
      {
        "type": "mcq",
        "question": "Solve for $x$: $\\frac{x}{x+1} = \\frac{4}{x+1} - 2$.",
        "options": ["$x = 2/3$", "$x = -2$", "$x = 2$", "$x = -2/3$"],
        "answer": "A",
        "explanation": "Multiply by $(x+1)$: $x = 4 - 2(x+1) \\implies x = 4 - 2x - 2 \\implies 3x = 2 \\implies x = 2/3$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{1}{x} \\le \\frac{1}{2}$.",
        "options": ["$(-\\infty, 0) \\cup [2, \\infty)$", "$(0, 2]$", "$[2, \\infty)$", "$(-\\infty, 0) \\cup (0, 2]$"],
        "answer": "A",
        "explanation": "$\\frac{1}{x} - \\frac{1}{2} \\le 0 \\implies \\frac{2-x}{2x} \\le 0$. Critical values at 0 and 2. Test intervals."
      },
      {
        "type": "mcq",
        "question": "If it takes Bob 5 hours to paint a room and Alice $x$ hours, and they finish in 2 hours together, find $x$.",
        "options": ["$10/3$", "$3$", "$4$", "$5$"],
        "answer": "A",
        "explanation": "$1/5 + 1/x = 1/2 \\implies 1/x = 3/10 \\implies x = 10/3$."
      },
      {
        "type": "mcq",
        "question": "In the decomposition of $\\frac{3x}{(x-1)^2}$, what is the numerator of the term with denominator $(x-1)$?",
        "options": ["$3$", "$1$", "$2$", "$0$"],
        "answer": "A",
        "explanation": "$\\frac{A}{x-1} + \\frac{B}{(x-1)^2}$. $A(x-1) + B = 3x \\implies Ax - A + B = 3x \\implies A=3$."
      },
      {
        "type": "mcq",
        "question": "Find the value of $x$ for which $4^{x+1} = 8^{x-1}$.",
        "options": ["$5$", "$3$", "$4$", "$6$"],
        "answer": "A",
        "explanation": "$2^{2(x+1)} = 2^{3(x-1)} \\implies 2x + 2 = 3x - 3 \\implies x = 5$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_3(1/27) + \\ln(e^5)$.",
        "options": ["$2$", "$-2$", "$8$", "$-8$"],
        "answer": "A",
        "explanation": "$\\log_3(1/27) = -3$, $\\ln(e^5) = 5$. Sum = $2$."
      },
      {
        "type": "mcq",
        "question": "Simplify $(\\log_2 5)(\\log_5 8)$.",
        "options": ["$3$", "$1$", "$5$", "$8$"],
        "answer": "A",
        "explanation": "$\\frac{\\log 5}{\\log 2} \\cdot \\frac{\\log 8}{\\log 5} = \\frac{\\log 8}{\\log 2} = \\log_2 8 = 3$."
      },
      {
        "type": "mcq",
        "question": "Solve $5^{2x} - 6(5^x) + 5 = 0$.",
        "options": ["$0, 1$", "$1, 2$", "$0, 2$", "$-1, 1$"],
        "answer": "A",
        "explanation": "$(5^x - 5)(5^x - 1) = 0 \\implies 5^x=5$ or $5^x=1$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log_2(x+3) + \\log_2(x-3) = 4$.",
        "options": ["$5$", "$-5$", "$\\pm 5$", "$3$"],
        "answer": "A",
        "explanation": "$\\log_2(x^2 - 9) = 4 \\implies x^2 - 9 = 16 \\implies x^2 = 25$. $x=-5$ is extraneous."
      },
      {
        "type": "mcq",
        "question": "The value of a car depreciates by 15% each year. If it is worth $20,000 now, find its value in 2 years.",
        "options": ["$14450$", "$17000$", "$14400$", "$15000$"],
        "answer": "A",
        "explanation": "$20000(0.85)^2 = 20000(0.7225) = 14450$."
      },
      {
        "type": "mcq",
        "question": "If $A$ is $2 \\times 3$ and $B$ is $3 \\times 2$, find the size of $B A$.",
        "options": ["$3 \\times 3$", "$2 \\times 2$", "$2 \\times 3$", "$3 \\times 2$"],
        "answer": "A",
        "explanation": "Outer dimensions of $(3 \\times 2) \\times (2 \\times 3) = 3 \\times 3$."
      },
      {
        "type": "mcq",
        "question": "What row operation on $\\begin{bmatrix} 1 & 3 \\\\ 4 & 10 \\end{bmatrix}$ results in a leading zero for the second row?",
