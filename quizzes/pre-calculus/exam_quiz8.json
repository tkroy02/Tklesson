        "answer": "A",
        "explanation": "$(1 + \\cos x)/2 = (1 + 1/4)/2 = (5/4)/2 = 5/8$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\frac{\\sin 3x + \\sin x}{\\cos 3x + \\cos x}$.",
        "options": ["$\\tan 2x$", "$\\cot 2x$", "$\\tan x$", "$\\cot x$"],
        "answer": "A",
        "explanation": "$2\\sin 2x \\cos x / 2\\cos 2x \\cos x = \\tan 2x$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\sin^2 x = 3/4$ on $[0, \\pi]$.",
