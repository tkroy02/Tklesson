    "questions": [
      {
        "type": "mcq",
        "question": "Determine the value of $c$ such that $x^2 + 12x + c$ is a perfect square trinomial.",
        "options": ["$36$", "$144$", "$12$", "$6$"],
        "answer": "A",
        "explanation": "For a perfect square $(x+h)^2$, $c = (b/2)^2$. $(12/2)^2 = 36$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $x - \\sqrt{x} = 6$.",
        "options": ["$x = 9$", "$x = 4$", "$x = 16$", "$x = 2$"],
        "answer": "A",
        "explanation": "Let $u = \\sqrt{x}$. $u^2 - u - 6 = 0 \\implies (u-3)(u+2) = 0$. Since $\\sqrt{x} \\ge 0$, $u=3$, so $x=9$."
      },
      {
        "type": "mcq",
        "question": "If $f(x)$ is an odd function and $f(5) = -2$, find $f(-5)$.",
        "options": ["$2$", "$-2$", "$0$", "$-5$"],
        "answer": "A",
        "explanation": "By definition of an odd function, $f(-x) = -f(x)$. Thus $f(-5) = -(-2) = 2$."
      },
      {
        "type": "mcq",
        "question": "Determine if $f(x) = \\begin{cases} x + k & x \\le 2 \\\\ 3x - 1 & x > 2 \\end{cases}$ is continuous at $x=2$ by finding the value of $k$.",
        "options": ["$k = 3$", "$k = 5$", "$k = 2$", "$k = 1$"],
        "answer": "A",
        "explanation": "Set the pieces equal at $x=2$: $2 + k = 3(2) - 1 \\implies 2 + k = 5 \\implies k = 3$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\sqrt[3]{x-1}$, find $f^{-1}(2)$.",
