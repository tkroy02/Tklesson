          "$\\pi/2$",
          "$\\pi$",
          "$0$",
          "$2\\pi$"
        ],
        "answer": "A",
        "explanation": "$\\tan x$ has asymptotes where $\\cos x = 0$. First positive at $x = \\pi/2$."
      },
      {
        "type": "mcq",
        "question": "Where is a vertical asymptote of $y = \\sec x$?",
        "options": [
          "$\\pi/2$",
          "$0$",
          "$\\pi$",
          "$2\\pi$"
        ],
        "answer": "A",
        "explanation": "$\\sec x = 1/\\cos x$, undefined when $\\cos x = 0$. At $x = \\pi/2$."
      },
      {
        "type": "mcq",
        "question": "What is the value of $y = \\csc x$ at $x = \\pi/2$?",
