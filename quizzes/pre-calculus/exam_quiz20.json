    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $m$ such that the equation $x^2 - mx + 25 = 0$ has exactly one real solution, where $m < 0$.",
        "options": ["$m = -10$", "$m = 10$", "$m = -5$", "$m = 5$"],
        "answer": "A",
        "explanation": "For one real solution, the discriminant $b^2 - 4ac = 0$. Here, $(-m)^2 - 4(1)(25) = 0 \\implies m^2 = 100$. Given $m < 0$, $m = -10$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\sqrt{x^2 - 9} = 4$.",
        "options": ["$x = 5$ or $x = -5$", "$x = 5$", "$x = -5$", "$x = \\pm 3$"],
        "answer": "A",
        "explanation": "Squaring both sides gives $x^2 - 9 = 16 \\implies x^2 = 25 \\implies x = \\pm 5$. Both values are valid under the radical."
      },
      {
