    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $k$ such that the equation $2x^2 + 4x + k = 0$ has exactly one real solution.",
        "options": ["$k = 2$", "$k = 4$", "$k = 8$", "$k = 1$"],
        "answer": "A",
        "explanation": "For exactly one real solution, the discriminant $b^2 - 4ac$ must be zero. $4^2 - 4(2)(k) = 0 \\implies 16 - 8k = 0 \\implies k = 2$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $|3x + 9| = 0$.",
        "options": ["$x = -3$", "$x = 3$", "$x = 0$", "$x = -9$"],
        "answer": "A",
        "explanation": "The absolute value of an expression is zero if and only if the expression itself is zero. $3x + 9 = 0 \\implies x = -3$."
      },
      {
