          "$\\pi/3$",
          "$2\\pi$",
          "$3\\pi$"
        ],
        "answer": "A",
        "explanation": "Period = $2\\pi / b = 2\\pi / 3$."
      },
      {
        "type": "mcq",
        "question": "What is the phase shift of $y = \\cos(x + \\pi/4)$?",
        "options": [
          "$\\pi/4$ left",
          "$\\pi/4$ right",
          "$\\pi/2$ left",
          "$\\pi/2$ right"
        ],
        "answer": "A",
        "explanation": "$y = \\cos(x - (-\\pi/4))$, so phase shift = $-\\pi/4$ (or $\\pi/4$ left)."
      },
      {
        "type": "mcq",
        "question": "What is the vertical shift of $y = 3\\sin x - 4$?",
        "options": [
          "4 down",
          "4 up",
          "3 down",
          "3 up"
        ],
        "answer": "A",
        "explanation": "Vertical shift = $k = -4$ (4 units down)."
      },
      {
        "type": "mcq",
        "question": "What is the period of $y = \\tan(3x)$?",
        "options": [
          "$\\pi/3$",
          "$\\pi/2$",
          "$\\pi$",
          "$2\\pi/3$"
        ],
        "answer": "A",
        "explanation": "Period = $\\pi / b = \\pi / 3$."
      },
      {
        "type": "mcq",
        "question": "Where is the first positive vertical asymptote of $y = \\tan(2x)$?",
        "options": [
          "$\\pi/4$",
          "$\\pi/2$",
          "$\\pi/3$",
          "$\\pi$"
        ],
        "answer": "A",
        "explanation": "Asymptotes occur when $2x = \\pi/2 \\implies x = \\pi/4$."
      },
      {
        "type": "mcq",
        "question": "Where is a vertical asymptote of $y = \\csc x$?",
        "options": [
          "$\\pi$",
          "$\\pi/2$",
          "$0$",
          "$2\\pi$"
        ],
        "answer": "A",
        "explanation": "$\\csc x = 1/\\sin x$, undefined when $\\sin x = 0$. At $x = \\pi$."
      },
      {
        "type": "mcq",
        "question": "What is the value of $y = \\sec x$ at $x = 0$?",
        "options": [
          "1",
          "0",
          "-1",
          "Undefined"
        ],
        "answer": "A",
        "explanation": "$\\sec(0) = 1 / \\cos(0) = 1 / 1 = 1$."
      },
      {
        "type": "mcq",
        "question": "What are the envelopes of $y = e^{-x} \\cos x$?",
