        "type": "mcq",
        "question": "What is the value of $y = 5\\sin x$ at $x = \\pi$?",
        "options": [
          "0",
          "5",
          "-5",
          "1"
        ],
        "answer": "A",
        "explanation": "$5 \\sin(\\pi) = 5 \\times 0 = 0$."
      },
      {
        "type": "mcq",
        "question": "What is the value of $y = -4\\cos x$ at $x = \\pi/2$?",
        "options": [
          "0",
          "-4",
          "4",
          "1"
        ],
        "answer": "A",
        "explanation": "$-4 \\cos(\\pi/2) = -4 \\times 0 = 0$."
      },
      {
        "type": "mcq",
        "question": "What is the amplitude of $y = 6\\sin(2x) + 3$?",
        "options": [
          "6",
