      {
        "type": "mcq",
        "question": "What is the value of the discriminant for $2x^2 - 4x + 2 = 0$?",
        "options": ["$0$", "$16$", "$-16$", "$4$"],
        "answer": "A",
        "explanation": "The discriminant is $\\Delta = b^2 - 4ac = (-4)^2 - 4(2)(2) = 16 - 16 = 0$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $\\sqrt{3x + 1} = 4$.",
        "options": ["$x = 5$", "$x = 4$", "$x = 3$", "$x = 2$"],
        "answer": "A",
        "explanation": "Square both sides: $3x + 1 = 16 \\implies 3x = 15 \\implies x = 5$. Check: $\\sqrt{15+1} = \\sqrt{16} = 4$ ✓."
      },
