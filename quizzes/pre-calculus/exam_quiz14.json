        "answer": "A",
        "explanation": "$\\sin = 4/5 \\implies \\text{Opp}=4, \\text{Hyp}=5, \\text{Adj}=3. \\tan = 4/3$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\cot(45^\\circ) + \\csc(30^\\circ)$.",
        "options": ["$3$", "$2$", "$1$", "$4$"],
        "answer": "A",
        "explanation": "$1 + 2 = 3$."
      },
      {
        "type": "mcq",
        "question": "The angle of depression from a 100ft tower to a car is $30^\\circ$. How far is the car from the tower base?",
        "options": ["$100\\sqrt{3}$ ft", "$50\\sqrt{3}$ ft", "$100$ ft", "$200$ ft"],
        "answer": "A",
        "explanation": "$\\tan 30^\\circ = 100/x \\implies 1/\\sqrt{3} = 100/x \\implies x = 100\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Find the amplitude of $y = 2 - 3\\cos(x)$.",
