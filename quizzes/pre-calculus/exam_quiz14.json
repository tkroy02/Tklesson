{
  "quiz": {
    "title": "Pre-Calculus (Exam 14)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $b$ such that the quadratic $x^2 + bx + 49 = 0$ has exactly one real solution and $b > 0$.",
        "options": ["$14$", "$7$", "$28$", "$49$"],
        "answer": "A",
        "explanation": "The discriminant must be zero: $b^2 - 4(1)(49) = 0 \\implies b^2 = 196 \\implies b = 14$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $|2x - 5| = |x + 4|$.",
        "options": ["$x = 9, x = 1/3$", "$x = 9, x = -1/3$", "$x = -9, x = 1/3$", "$x = -9, x = -1/3$"],
        "answer": "A",
        "explanation": "Case 1: $2x-5 = x+4 \\implies x=9$. Case 2: $2x-5 = -(x+4) \\implies 3x = 1 \\implies x=1/3$."
      },
      {
        "type": "mcq",
        "question": "Determine the symmetry of $f(x) = \\frac{x^3}{x^2 + 1}$.",
        "options": ["Odd", "Even", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = \\frac{(-x)^3}{(-x)^2 + 1} = \\frac{-x^3}{x^2 + 1} = -f(x)$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\begin{cases} 2x & x < 0 \\\\ x^2 & x \\ge 0 \\end{cases}$, find $f(f(-2))$.",
        "options": ["$-8$", "$16$", "$-4$", "$8$"],
        "answer": "A",
        "explanation": "$f(-2) = 2(-2) = -4$. Then $f(-4) = 2(-4) = -8$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\ln(x - 3)$, find the domain of $f^{-1}(x)$.",
        "options": ["$(-\\infty, \\infty)$", "$(3, \\infty)$", "$[3, \\infty)$", "$(0, \\infty)$"],
        "answer": "A",
        "explanation": "The domain of an inverse function is the range of the original function. The range of a natural log function is all real numbers."
      },
      {
        "type": "mcq",
        "question": "What is the quotient when $2x^3 - 4x^2 + x - 2$ is divided by $x - 2$?",
        "options": ["$2x^2 + 1$", "$2x^2 - 1$", "$2x^2 + x$", "$2x^2 - x$"],
        "answer": "A",
        "explanation": "Factor by grouping: $2x^2(x-2) + 1(x-2) = (2x^2+1)(x-2)$. Dividing by $(x-2)$ leaves $2x^2+1$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to find the remainder of $(x^4 - 81) \\div (x - 3)$.",
        "options": ["$0$", "$1$", "$81$", "$-81$"],
        "answer": "A",
        "explanation": "Evaluating $P(3) = 3^4 - 81 = 81 - 81 = 0$."
      },
      {
        "type": "mcq",
        "question": "How many possible negative real zeros are there for $P(x) = x^4 + x^3 + x^2 + x + 1$?",
        "options": ["$4, 2, \\text{ or } 0$", "$0$", "$1$", "$2$"],
        "answer": "A",
        "explanation": "$P(-x) = x^4 - x^3 + x^2 - x + 1$ has 4 sign changes, so possible negative zeros = 4, 2, or 0."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{3}{x-2} = \\frac{x}{x-2}$.",
        "options": ["$x = 3$", "$x = 2$", "No solution", "$x = 0$"],
        "answer": "A",
        "explanation": "Multiply by $(x-2)$: $3 = x$. Check $x=3$ works, not extraneous."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{1}{x} < \\frac{1}{3}$.",
        "options": ["$(-\\infty, 0) \\cup (3, \\infty)$", "$(0, 3)$", "$(-\\infty, 3)$", "$(3, \\infty)$"],
        "answer": "A",
        "explanation": "$\\frac{3-x}{3x} < 0$. Critical points at 0 and 3. Testing intervals yields the solution."
      },
      {
        "type": "mcq",
        "question": "Find the hole in the graph of $f(x) = \\frac{x^2 - x - 2}{x - 2}$.",
        "options": ["$(2, 3)$", "$(2, 2)$", "$(2, 1)$", "$(2, 0)$"],
        "answer": "A",
        "explanation": "$\\frac{(x-2)(x+1)}{x-2} = x+1$. At $x=2$, the value is $2+1=3$."
      },
      {
        "type": "mcq",
        "question": "Find $A$ such that $\\frac{x+7}{(x-3)(x+2)} = \\frac{A}{x-3} + \\frac{B}{x+2}$.",
        "options": ["$2$", "$3$", "$4$", "$5$"],
        "answer": "A",
        "explanation": "Cover-up at $x=3$: $A = (3+7)/(3+2) = 10/5 = 2$."
      },
      {
        "type": "mcq",
        "question": "Which point is the y-intercept of $f(x) = 3 \\cdot 4^x + 5$?",
        "options": ["$(0, 8)$", "$(0, 3)$", "$(0, 5)$", "$(0, 12)$"],
        "answer": "A",
        "explanation": "$f(0) = 3(1) + 5 = 8$."
      },
      {
        "type": "mcq",
        "question": "Simplify $e^{2\\ln x}$.",
        "options": ["$x^2$", "$2x$", "$e^{2x}$", "$\\ln(x^2)$"],
        "answer": "A",
        "explanation": "$e^{\\ln x^2} = x^2$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_8 4$.",
        "options": ["$2/3$", "$3/2$", "$2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\frac{\\log_2 4}{\\log_2 8} = 2/3$."
      },
      {
        "type": "mcq",
        "question": "Solve $5^{x+1} = 10$.",
        "options": ["$\\log_5 10 - 1$", "$\\log_5 10 + 1$", "$\\log_5 2$", "$\\log_5 5$"],
        "answer": "A",
        "explanation": "$x+1 = \\log_5 10 \\implies x = \\log_5 10 - 1$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\ln x + \\ln(x-1) = \\ln 6$.",
        "options": ["$3$", "$2$", "$4$", "$-2$"],
        "answer": "A",
        "explanation": "$x(x-1) = 6 \\implies x^2 - x - 6 = 0 \\implies (x-3)(x+2)=0$. $x=3$ is the valid root."
      },
      {
        "type": "mcq",
        "question": "Find the doubling time of an investment with a 7% continuous growth rate.",
        "options": ["$\\frac{100 \\ln 2}{7} \\approx 9.9$ years", "$\\frac{\\ln 2}{7} \\approx 0.1$ years", "$\\frac{7}{\\ln 2} \\approx 10.1$ years", "$\\frac{100}{7} \\approx 14.3$ years"],
        "answer": "A",
        "explanation": "$e^{0.07t} = 2 \\implies 0.07t = \\ln 2 \\implies t = \\ln 2 / 0.07 = 100\\ln 2 / 7$."
      },
      {
        "type": "mcq",
        "question": "If $A$ is $2 \\times 3$ and $B$ is $3 \\times 2$, what is the size of $BA$?",
        "options": ["$3 \\times 3$", "$2 \\times 2$", "$2 \\times 3$", "$3 \\times 2$"],
        "answer": "A",
        "explanation": "Inner dimensions 2 match; outer dimensions are 3 and 3."
      },
      {
        "type": "mcq",
        "question": "Given $\\begin{bmatrix} 1 & 3 & | & 7 \\\\ 0 & 1 & | & 2 \\end{bmatrix}$, solve for $x$.",
        "options": ["$1$", "$2$", "$3$", "$4$"],
        "answer": "A",
        "explanation": "$x + 3(2) = 7 \\implies x + 6 = 7 \\implies x = 1$."
      },
      {
        "type": "mcq",
        "question": "Find the determinant of $\\begin{bmatrix} a & 0 \\\\ 0 & b \\end{bmatrix}$.",
        "options": ["$ab$", "$a + b$", "$a - b$", "$0$"],
        "answer": "A",
        "explanation": "For a diagonal matrix, the determinant is the product of diagonal entries."
      },
      {
        "type": "mcq",
        "question": "Use Cramer's rule to find $x$ if $D=10, D_x=40, D_y=20$.",
        "options": ["$4$", "$2$", "$10$", "$40$"],
        "answer": "A",
        "explanation": "$x = D_x / D = 40/10 = 4$."
      },
      {
        "type": "mcq",
        "question": "Find the supplement of $2\\pi/5$.",
        "options": ["$3\\pi/5$", "$\\pi/5$", "$7\\pi/5$", "$8\\pi/5$"],
        "answer": "A",
        "explanation": "$\\pi - 2\\pi/5 = 3\\pi/5$."
      },
      {
        "type": "mcq",
        "question": "If $r=5$ and $\\theta=2$, find the arc length $s$.",
        "options": ["$10$", "$5$", "$2$", "$2.5$"],
        "answer": "A",
        "explanation": "$s = r\\theta = 5(2) = 10$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a sector with $r=10$ and $s=5$.",
        "options": ["$25$", "$50$", "$10$", "$5$"],
        "answer": "A",
        "explanation": "Area $= 0.5rs = 0.5(10)(5) = 25$."
      },
      {
        "type": "mcq",
        "question": "Find the reference angle for $330^\\circ$.",
        "options": ["$30^\\circ$", "$60^\\circ$", "$45^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$360 - 330 = 30$."
      },
      {
        "type": "mcq",
        "question": "In a right triangle, if $\\sin \\theta = 0.8$, find $\\tan \\theta$.",
