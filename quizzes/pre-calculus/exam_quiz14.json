        "answer": "A",
        "explanation": "$5C1 \\cdot x^4 \\cdot (-1)^1 = -5x^4$."
      },
      {
        "type": "mcq",
        "question": "How many ways can 5 people stand in a line?",
        "options": ["$120$", "$60$", "$24$", "$5$"],
        "answer": "A",
        "explanation": "$5! = 120$."
      },
      {
        "type": "mcq",
        "question": "How many ways to pick 2 colors from a set of 10?",
