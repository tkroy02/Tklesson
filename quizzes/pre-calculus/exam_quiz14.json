        "answer": "A",
        "explanation": "$\\frac{\\sqrt{3}+1}{1-\\sqrt{3}} = \\frac{(\\sqrt{3}+1)^2}{-2} = \\frac{4+2\\sqrt{3}}{-2} = -2-\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\cos^2(x) - \\sin^2(x)$.",
        "options": ["$\\cos(2x)$", "$\\sin(2x)$", "$\\cos^2(2x)$", "$\\sin^2(2x)$"],
        "answer": "A",
        "explanation": "Standard double angle identity for cosine."
      },
      {
        "type": "mcq",
        "question": "If $\\cos x = 0.8$, find $\\cos(x/2)$ for $x \\in [0, \\pi/2]$.",
        "options": ["$3/\\sqrt{10}$", "$1/\\sqrt{10}$", "$2/\\sqrt{5}$", "$1/\\sqrt{5}$"],
        "answer": "A",
        "explanation": "$\\sqrt{(1+0.8)/2} = \\sqrt{0.9} = \\sqrt{9/10} = 3/\\sqrt{10}$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sin(75) \\sin(15)$ using product-to-sum.",
        "options": ["$0.25$", "$0.5$", "$0.75$", "$1$"],
        "answer": "A",
        "explanation": "$0.5[\\cos(60) - \\cos(90)] = 0.5(0.5 - 0) = 0.25$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\sin^2 x - \\sin x = 0$ for $x \\in [0, 2\\pi)$.",
