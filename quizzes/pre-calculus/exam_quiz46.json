    "questions": [
      {
        "type": "mcq",
        "question": "What is the value of the discriminant for $x^2 - 4x + 5 = 0$?",
        "options": ["$-4$", "$4$", "$16$", "$-16$"],
        "answer": "A",
        "explanation": "The discriminant is $\\Delta = b^2 - 4ac = (-4)^2 - 4(1)(5) = 16 - 20 = -4$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $|2x - 1| = 9$.",
        "options": ["$x = 5, -4$", "$x = 5$ only", "$x = -4$ only", "$x = 4, -5$"],
        "answer": "A",
        "explanation": "Case 1: $2x - 1 = 9 \\implies 2x = 10 \\implies x = 5$. Case 2: $2x - 1 = -9 \\implies 2x = -8 \\implies x = -4$."
      },
      {
        "type": "mcq",
        "question": "Determine the parity of $f(x) = x^6 + x^4 + 1$.",
        "options": ["Even", "Odd", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)^6 + (-x)^4 + 1 = x^6 + x^4 + 1 = f(x)$. Since $f(-x) = f(x)$, the function is even."
      },
      {
        "type": "mcq",
        "question": "Evaluate $f(1)$ if $f(x) = \\begin{cases} 0 & x < 1 \\\\ 100 & x \\ge 1 \\end{cases}$.",
        "options": ["$100$", "$0$", "$1$", "$-1$"],
        "answer": "A",
        "explanation": "Since $x = 1$ satisfies $x \\ge 1$, use the second piece: $f(1) = 100$."
      },
      {
        "type": "mcq",
        "question": "Find $f^{-1}(x)$ for $f(x) = \\sqrt[3]{x}$.",
        "options": ["$x^3$", "$\\sqrt[3]{x}$", "$x^{1/3}$", "$3x$"],
        "answer": "A",
        "explanation": "Replace $f(x)$ with $y$: $y = \\sqrt[3]{x}$. Swap $x$ and $y$: $x = \\sqrt[3]{y}$. Then $y = x^3$."
      },
      {
        "type": "mcq",
        "question": "What is the remainder when $x^2 + 1$ is divided by $x - 1$?",
        "options": ["$2$", "$0$", "$1$", "$-1$"],
        "answer": "A",
        "explanation": "By the Remainder Theorem, the remainder is $P(1) = 1^2 + 1 = 2$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to divide $x^2 - 5x + 6$ by $x - 2$.",
