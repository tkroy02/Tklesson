{
  "quiz": {
    "title": "Pre-Calculus (Exam 11)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $m$ such that the equation $x^2 - mx + 25 = 0$ has exactly one real solution.",
        "options": ["$10, -10$", "$5, -5$", "$25, -25$", "$0$"],
        "answer": "A",
        "explanation": "Set discriminant $b^2 - 4ac = 0$. $m^2 - 4(1)(25) = 0 \\implies m^2 = 100 \\implies m = \\pm 10$."
      },
      {
        "type": "mcq",
        "question": "Solve the inequality $|4x - 3| > 9$.",
        "options": ["$x < -1.5 \\text{ or } x > 3$", "$x > 3$", "$x < -1.5$", "$-1.5 < x < 3$"],
        "answer": "A",
        "explanation": "Case 1: $4x - 3 > 9 \\implies x > 3$. Case 2: $4x - 3 < -9 \\implies x < -1.5$."
      },
      {
        "type": "mcq",
        "question": "Determine if $f(x) = x^4 - 2x^2 + 7$ is even, odd, or neither.",
        "options": ["Even", "Odd", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)^4 - 2(-x)^2 + 7 = x^4 - 2x^2 + 7 = f(x)$."
      },
      {
        "type": "mcq",
        "question": "Find $f(3)$ if $f(x) = \\begin{cases} x^2 - 1 & x < 2 \\\\ 2x + 5 & x \\ge 2 \\end{cases}$.",
        "options": ["$11$", "$8$", "$10$", "$9$"],
        "answer": "A",
        "explanation": "Since $3 \\ge 2$, use second piece: $2(3) + 5 = 11$."
      },
      {
        "type": "mcq",
        "question": "Given $f(x) = 3x - 5$, evaluate $f^{-1}(7)$.",
        "options": ["$4$", "$3$", "$5$", "$2$"],
        "answer": "A",
        "explanation": "Set $3x - 5 = 7 \\implies 3x = 12 \\implies x = 4$."
      },
      {
        "type": "mcq",
        "question": "Divide $x^3 + 2x^2 - 5x + 6$ by $x - 1$ and find the remainder.",
        "options": ["$4$", "$2$", "$0$", "$6$"],
        "answer": "A",
        "explanation": "Remainder Theorem: $P(1) = 1 + 2 - 5 + 6 = 4$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to find the quotient when $x^3 - 7x - 6$ is divided by $x + 2$.",
        "options": ["$x^2 - 2x - 3$", "$x^2 + 2x - 3$", "$x^2 - 2x + 3$", "$x^2 + 2x + 3$"],
        "answer": "A",
        "explanation": "Coefficients [1, 0, -7, -6] divided by -2 yields [1, -2, -3, 0]."
      },
      {
        "type": "mcq",
        "question": "Determine the maximum number of positive real zeros for $P(x) = x^5 - x^4 + 3x^3 + 9x^2 - x + 5$.",
        "options": ["$4$", "$3$", "$2$", "$1$"],
        "answer": "A",
        "explanation": "Sign changes: (+ to -), (- to +), (+ to +), (+ to -), (- to +). Total of 4 changes."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{5}{x} = \\frac{3}{x-2}$.",
        "options": ["$x = 5$", "$x = 2$", "$x = 3$", "$x = 4$"],
        "answer": "A",
        "explanation": "$5(x-2) = 3x \\implies 5x - 10 = 3x \\implies 2x = 10 \\implies x = 5$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{x-2}{x+4} < 1$.",
        "options": ["$x > -4$", "$x < -4$", "$x > 4$", "$x < 4$"],
        "answer": "A",
        "explanation": "$\\frac{x-2}{x+4} - 1 < 0 \\implies \\frac{-6}{x+4} < 0$. This is true when $x+4 > 0 \\implies x > -4$."
      },
      {
        "type": "mcq",
        "question": "Find the horizontal asymptote of $f(x) = \\frac{7x^2 - 3x}{2x^2 + 5}$.",
        "options": ["$y = 3.5$", "$y = 7/2$", "$y = 0$", "$y = 3$"],
        "answer": "A",
        "explanation": "Degrees are equal; H.A. is the ratio of leading coefficients $7/2 = 3.5$."
      },
      {
        "type": "mcq",
        "question": "Decompose $\\frac{1}{x^2 - x}$ into partial fractions.",
        "options": ["$1/(x-1) - 1/x$", "$1/x - 1/(x-1)$", "$1/(x-1) + 1/x$", "$-1/(x-1) - 1/x$"],
        "answer": "A",
        "explanation": "$\\frac{A}{x} + \\frac{B}{x-1} \\implies A(x-1) + Bx = 1$. $x=0 \\to A=-1$. $x=1 \\to B=1$."
      },
      {
        "type": "mcq",
        "question": "Solve $2^{x+3} = 16$.",
        "options": ["$1$", "$2$", "$3$", "$0$"],
        "answer": "A",
        "explanation": "$2^{x+3} = 2^4 \\implies x+3 = 4 \\implies x = 1$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_2(32) - \\log_2(4)$.",
        "options": ["$3$", "$2$", "$4$", "$1$"],
        "answer": "A",
        "explanation": "$\\log_2(32/4) = \\log_2(8) = 3$."
      },
      {
        "type": "mcq",
        "question": "Express $\\log_3 7$ using natural logarithms.",
        "options": ["$\\ln 7 / \\ln 3$", "$\\ln 3 / \\ln 7$", "$\\ln(7-3)$", "$\\ln(7+3)$"],
        "answer": "A",
        "explanation": "Using the identity $\\log_a b = \\frac{\\ln b}{\\ln a}$."
      },
      {
        "type": "mcq",
        "question": "Solve $4^x = 12$. (Express in terms of $\\ln$).",
        "options": ["$\\ln 12 / \\ln 4$", "$\\ln 4 / \\ln 12$", "$\\ln(12-4)$", "$\\ln(12+4)$"],
        "answer": "A",
        "explanation": "$x \\ln 4 = \\ln 12 \\implies x = \\ln 12 / \\ln 4$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log(x) + \\log(5) = 2$.",
        "options": ["$20$", "$10$", "$5$", "$25$"],
        "answer": "A",
        "explanation": "$\\log(5x) = 2 \\implies 5x = 100 \\implies x = 20$."
      },
      {
        "type": "mcq",
        "question": "An investment of $500 grows at 6% interest compounded annually. Find the value after 2 years.",
        "options": ["$561.80$", "$560$", "$562$", "$563$"],
        "answer": "A",
        "explanation": "$500(1.06)^2 = 500(1.1236) = 561.80$."
      },
      {
        "type": "mcq",
        "question": "Find the product $AB$ if $A = \\begin{bmatrix} 3 & 0 \\\\ 0 & 3 \\end{bmatrix}$ and $B = \\begin{bmatrix} 1 & 2 \\\\ 3 & 4 \\end{bmatrix}$.",
        "options": ["$\\begin{bmatrix} 3 & 6 \\\\ 9 & 12 \\end{bmatrix}$", "$\\begin{bmatrix} 3 & 2 \\\\ 3 & 4 \\end{bmatrix}$", "$\\begin{bmatrix} 1 & 6 \\\\ 9 & 4 \\end{bmatrix}$", "$\\begin{bmatrix} 3 & 0 \\\\ 0 & 12 \\end{bmatrix}$"],
        "answer": "A",
        "explanation": "Multiplying by $3I$ simply scales all entries of $B$ by 3."
      },
      {
        "type": "mcq",
        "question": "Given the system $x + y = 10, x - y = 2$, find $x$ using an augmented matrix.",
        "options": ["$6$", "$4$", "$8$", "$10$"],
        "answer": "A",
        "explanation": "Add equations: $2x = 12 \\implies x = 6$."
      },
      {
        "type": "mcq",
        "question": "What is $A \\cdot A^{-1}$ for any invertible matrix $A$?",
        "options": ["$I$ (Identity Matrix)", "$0$ (Zero Matrix)", "$A$", "$A^{-1}$"],
        "answer": "A",
        "explanation": "By definition of an inverse matrix, $A \\cdot A^{-1} = I$."
      },
      {
        "type": "mcq",
        "question": "Find the determinant of $\\begin{bmatrix} 5 & 6 \\\\ 2 & 3 \\end{bmatrix}$.",
        "options": ["$3$", "$-3$", "$2$", "$-2$"],
        "answer": "A",
        "explanation": "$(5)(3) - (6)(2) = 15 - 12 = 3$."
      },
      {
        "type": "mcq",
        "question": "Convert $210^\\circ$ to radians.",
        "options": ["$7\\pi/6$", "$5\\pi/6$", "$11\\pi/6$", "$\\pi/6$"],
        "answer": "A",
        "explanation": "$210 \\cdot (\\pi/180) = 7\\pi/6$."
      },
      {
        "type": "mcq",
        "question": "Find the arc length for a $90^\\circ$ angle in a circle with radius 10.",
        "options": ["$5\\pi$", "$10\\pi$", "$20\\pi$", "$2.5\\pi$"],
        "answer": "A",
        "explanation": "$90^\\circ = \\pi/2$ rad. $s = 10(\\pi/2) = 5\\pi$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a sector with radius 8 and angle $\\pi/4$.",
        "options": ["$8\\pi$", "$4\\pi$", "$16\\pi$", "$2\\pi$"],
        "answer": "A",
        "explanation": "$0.5(8^2)(\\pi/4) = 0.5(64)(\\pi/4) = 8\\pi$."
      },
      {
        "type": "mcq",
        "question": "Find a positive coterminal angle for $-45^\\circ$.",
        "options": ["$315^\\circ$", "$45^\\circ$", "$135^\\circ$", "$225^\\circ$"],
        "answer": "A",
        "explanation": "$-45 + 360 = 315$."
      },
      {
        "type": "mcq",
        "question": "In a right triangle, if the opposite side is 8 and the adjacent side is 15, find the hypotenuse.",
        "options": ["$17$", "$13$", "$12$", "$10$"],
        "answer": "A",
        "explanation": "$\\sqrt{8^2 + 15^2} = \\sqrt{64 + 225} = \\sqrt{289} = 17$."
      },
      {
        "type": "mcq",
        "question": "Find the value of $\\sec(60^\\circ)$.",
        "options": ["$2$", "$1$", "$\\sqrt{3}$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\cos(60^\\circ) = 1/2$. Reciprocal is 2."
      },
      {
        "type": "mcq",
        "question": "The angle of elevation to a plane is $45^\\circ$. If the plane is at an altitude of 3000ft, what is the horizontal distance to the plane?",
        "options": ["$3000$ ft", "$1500$ ft", "$3000\\sqrt{3}$ ft", "$3000/\\sqrt{3}$ ft"],
        "answer": "A",
        "explanation": "In a $45^\\circ$ triangle, the legs are equal."
      },
      {
        "type": "mcq",
        "question": "Find the amplitude of $y = -7\\sin(x) + 2$.",
        "options": ["$7$", "$-7$", "$2$", "$-2$"],
        "answer": "A",
        "explanation": "Amplitude is the absolute value of the coefficient of the sine function: $| -7 | = 7$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\arccos(\\sqrt{2}/2)$.",
        "options": ["$\\pi/4$", "$\\pi/3$", "$\\pi/6$", "$\\pi/2$"],
        "answer": "A",
        "explanation": "$\\cos(\\pi/4) = \\sqrt{2}/2$ within the range $[0, \\pi]$."
      },
      {
        "type": "mcq",
        "question": "Find the exact value of $\\tan(\\arcsin(1/2))$.",
        "options": ["$1/\\sqrt{3}$", "$\\sqrt{3}$", "$1$", "$0$"],
        "answer": "A",
        "explanation": "$\\arcsin(1/2) = 30^\\circ$. $\\tan(30^\\circ) = 1/\\sqrt{3}$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\sin(75^\\circ)$ using $\\sin(45+30)$.",
        "options": ["$(\\sqrt{6}+\\sqrt{2})/4$", "$(\\sqrt{6}-\\sqrt{2})/4$", "$\\sqrt{3}/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\sin45\\cos30 + \\cos45\\sin30 = (\\sqrt{2}/2)(\\sqrt{3}/2) + (\\sqrt{2}/2)(1/2) = (\\sqrt{6}+\\sqrt{2})/4$."
      },
      {
        "type": "mcq",
        "question": "If $\\tan A = 2$ and $\\tan B = 3$, find $\\tan(A+B)$.",
        "options": ["$-1$", "$1$", "$5$", "$-5$"],
        "answer": "A",
        "explanation": "$(2+3)/(1 - 2\\cdot3) = 5/(1-6) = 5/(-5) = -1$."
      },
      {
        "type": "mcq",
        "question": "Simplify $2\\sin(x)\\cos(x)$.",
        "options": ["$\\sin(2x)$", "$\\cos(2x)$", "$\\sin(x)$", "$\\cos(x)$"],
        "answer": "A",
        "explanation": "Standard double angle identity for sine."
      },
      {
        "type": "mcq",
        "question": "Find $\\sin(22.5^\\circ)$ using the half-angle formula.",
        "options": ["$\\sqrt{2-\\sqrt{2}}/2$", "$\\sqrt{2+\\sqrt{2}}/2$", "$\\sqrt{2}/2$", "$1/2$"],
        "answer": "A",
        "explanation": "$\\sqrt{(1-\\cos45)/2} = \\sqrt{(1-\\sqrt{2}/2)/2} = \\sqrt{(2-\\sqrt{2})/4}$."
      },
      {
        "type": "mcq",
        "question": "Convert $\\sin(40^\\circ) + \\sin(20^\\circ)$ to a product.",
        "options": ["$2\\sin(30^\\circ)\\cos(10^\\circ)$", "$2\\cos(30^\\circ)\\sin(10^\\circ)$", "$2\\sin(30^\\circ)\\sin(10^\\circ)$", "$2\\cos(30^\\circ)\\cos(10^\\circ)$"],
        "answer": "A",
        "explanation": "$2\\sin((40+20)/2)\\cos((40-20)/2) = 2\\sin(30)\\cos(10)$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\tan^2 x = 1$ for $x \\in [0, \\pi]$.",
        "options": ["$\\pi/4, 3\\pi/4$", "$\\pi/4, 5\\pi/4$", "$\\pi/4$ only", "$3\\pi/4$ only"],
        "answer": "A",
        "explanation": "$\\tan x = \\pm 1$ gives $x = \\pi/4$ and $x = 3\\pi/4$."
      },
      {
        "type": "mcq",
        "question": "Solve $4\\arctan(x) = \\pi$.",
        "options": ["$1$", "$0$", "$-1$", "$\\sqrt{3}$"],
        "answer": "A",
        "explanation": "$\\arctan(x) = \\pi/4 \\implies x = \\tan(\\pi/4) = 1$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\sin(x) = 1$ for $x \\in [0, 2\\pi)$.",
        "options": ["$\\pi/2$", "$0$", "$\\pi$", "$3\\pi/2$"],
        "answer": "A",
        "explanation": "The only point where the y-coordinate is 1 on the unit circle is $x = \\pi/2$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a triangle with sides $a=4, b=6$ and included angle $30^\\circ$.",
        "options": ["$6$", "$12$", "$24$", "$3$"],
        "answer": "A",
        "explanation": "$0.5 \\cdot 4 \\cdot 6 \\cdot \\sin(30^\\circ) = 12 \\cdot 0.5 = 6$."
      },
      {
        "type": "mcq",
        "question": "Write $z = 1 + i$ in trig form.",
        "options": ["$\\sqrt{2} \\text{ cis}(\\pi/4)$", "$\\sqrt{2} \\text{ cis}(3\\pi/4)$", "$2 \\text{ cis}(\\pi/4)$", "$2 \\text{ cis}(3\\pi/4)$"],
        "answer": "A",
        "explanation": "$r = \\sqrt{1^2+1^2} = \\sqrt{2}$. $\\theta = \\arctan(1/1) = \\pi/4$."
      },
      {
        "type": "mcq",
        "question": "Find $z_1 \\cdot z_2$ if $z_1 = 2\\text{cis } 30^\\circ$ and $z_2 = 5\\text{cis } 60^\\circ$.",
        "options": ["$10i$", "$10$", "$-10i$", "$-10$"],
        "answer": "A",
        "explanation": "$10\\text{cis } 90^\\circ = 10(0 + i) = 10i$."
      },
      {
        "type": "mcq",
        "question": "Find $(1+i)^2$ using De Moivre's Theorem.",
        "options": ["$2i$", "$-2i$", "$2$", "$-2$"],
        "answer": "A",
        "explanation": "$(\\sqrt{2}\\text{cis }45^\\circ)^2 = 2\\text{cis }90^\\circ = 2i$."
      },
      {
        "type": "mcq",
        "question": "Find the 2nd term in the expansion of $(x+y)^3$.",
        "options": ["$3x^2 y$", "$3x y^2$", "$x^2 y$", "$x y^2$"],
        "answer": "A",
        "explanation": "$3C1 \\cdot x^2 \\cdot y^1 = 3x^2 y$."
      },
      {
        "type": "mcq",
        "question": "How many 3-digit numbers can be formed using digits {1, 2, 3} if repetition is allowed?",
        "options": ["$27$", "$9$", "$18$", "$36$"],
        "answer": "A",
        "explanation": "$3 \\cdot 3 \\cdot 3 = 27$."
      },
      {
        "type": "mcq",
        "question": "Find the number of ways to choose 2 items from 5.",
        "options": ["$10$", "$5$", "$20$", "$15$"],
        "answer": "A",
        "explanation": "$5C2 = (5 \\cdot 4)/(2 \\cdot 1) = 10$."
      },
      {
        "type": "mcq",
        "question": "What is the probability of rolling a sum of 7 with two dice?",
        "options": ["$1/6$", "$1/12$", "$1/36$", "$5/36$"],
        "answer": "A",
        "explanation": "Outcomes: (1,6),(2,5),(3,4),(4,3),(5,2),(6,1). $6/36 = 1/6$."
      },
      {
        "type": "mcq",
        "question": "Find the vertex of $y = (x-4)^2 + 3$.",
        "options": ["$(4, 3)$", "$(-4, 3)$", "$(4, -3)$", "$(-4, -3)$"],
        "answer": "A",
        "explanation": "Given in vertex form $(x-h)^2 + k$, vertex is $(h, k)$."
      },
      {
        "type": "mcq",
        "question": "Find the length of the major axis for $x^2/16 + y^2/4 = 1$.",
        "options": ["$8$", "$4$", "$16$", "$2$"],
        "answer": "A",
        "explanation": "$a^2 = 16 \\implies a = 4$. Major axis $= 2a = 8$."
      }
    ]
  }
}
