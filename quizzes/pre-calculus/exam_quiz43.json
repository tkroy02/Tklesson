    "questions": [
      {
        "type": "mcq",
        "question": "What is the value of the discriminant for $x^2 - 10x + 25 = 0$?",
        "options": ["$0$", "$100$", "$-100$", "$50$"],
        "answer": "A",
        "explanation": "The discriminant is $\\Delta = b^2 - 4ac = (-10)^2 - 4(1)(25) = 100 - 100 = 0$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $|x + 4| = 10$.",
        "options": ["$x = 6, -14$", "$x = 6$ only", "$x = -14$ only", "$x = 14, -6$"],
        "answer": "A",
        "explanation": "Case 1: $x + 4 = 10 \\implies x = 6$. Case 2: $x + 4 = -10 \\implies x = -14$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = x^3 - x$, is the function even, odd, or neither?",
        "options": ["Odd", "Even", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)^3 - (-x) = -x^3 + x = -(x^3 - x) = -f(x)$. Since $f(-x) = -f(x)$, the function is odd."
      },
      {
        "type": "mcq",
        "question": "Find $f(5)$ if $f(x) = \\begin{cases} 2x & x < 5 \\\\ 0 & x \\ge 5 \\end{cases}$.",
        "options": ["$0$", "$10$", "$5$", "$2$"],
        "answer": "A",
        "explanation": "Since $x = 5$ satisfies $x \\ge 5$, use the second piece: $f(5) = 0$."
      },
      {
        "type": "mcq",
        "question": "Find $f^{-1}(x)$ for $f(x) = e^x$.",
        "options": ["$\\ln x$", "$e^x$", "$\\log x$", "$x^e$"],
        "answer": "A",
        "explanation": "The natural logarithm is the inverse of the exponential function with base $e$: $f^{-1}(x) = \\ln x$."
      },
      {
        "type": "mcq",
        "question": "Divide $3x^2 + 7x + 2$ by $x + 2$.",
        "options": ["$3x + 1$", "$3x - 1$", "$x + 3$", "$x - 3$"],
        "answer": "A",
        "explanation": "$3x^2 + 7x + 2 = (x+2)(3x+1)$, so the quotient is $3x + 1$."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to find the remainder of $(x^2 - 4) \\div (x - 2)$.",
        "options": ["$0$", "$1$", "$2$", "$4$"],
        "answer": "A",
        "explanation": "$P(2) = 2^2 - 4 = 4 - 4 = 0$, so the remainder is $0$."
      },
      {
        "type": "mcq",
        "question": "How many sign changes are in $P(x) = 2x^2 + 5x + 1$?",
        "options": ["$0$", "$1$", "$2$", "$3$"],
        "answer": "A",
        "explanation": "Coefficients: $+2, +5, +1$. All are positive, so there are $0$ sign changes."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{1}{x} = 0.25$.",
        "options": ["$x = 4$", "$x = 0.25$", "$x = 2$", "$x = 1$"],
        "answer": "A",
        "explanation": "$x = 1 / 0.25 = 4$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{x-2}{x} < 0$.",
        "options": ["$(0, 2)$", "$(-\\infty, 0) \\cup (2, \\infty)$", "$(-\\infty, 0)$", "$(2, \\infty)$"],
        "answer": "A",
        "explanation": "Critical points: $x = 0$ (undefined), $x = 2$ (zero). Testing intervals: $(-\\infty, 0)$ positive, $(0, 2)$ negative, $(2, \\infty)$ positive. Solution: $(0, 2)$."
      },
      {
        "type": "mcq",
        "question": "Find the horizontal asymptote of $f(x) = \\frac{100}{x+1}$.",
        "options": ["$y = 0$", "$y = 100$", "$y = 1$", "$y = -1$"],
        "answer": "A",
        "explanation": "The degree of the denominator ($1$) is greater than the degree of the numerator ($0$). Therefore, the horizontal asymptote is $y = 0$."
      },
      {
        "type": "mcq",
        "question": "Find $B$ for $\\frac{5}{(x+1)(x-4)} = \\frac{A}{x+1} + \\frac{B}{x-4}$.",
        "options": ["$B = 1$", "$B = -1$", "$B = 5$", "$B = -5$"],
        "answer": "A",
        "explanation": "Cover-up at $x = 4$: multiply both sides by $(x-4)$ and evaluate at $x = 4$. $B = \\frac{5}{4+1} = \\frac{5}{5} = 1$."
      },
      {
        "type": "mcq",
        "question": "Solve $4^x = 64$.",
        "options": ["$x = 3$", "$x = 4$", "$x = 2$", "$x = 1$"],
        "answer": "A",
        "explanation": "$64 = 4^3$, so $4^x = 4^3 \\implies x = 3$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\log_{10}(1000)$.",
        "options": ["$3$", "$4$", "$5$", "$2$"],
        "answer": "A",
        "explanation": "$10^3 = 1000$, so $\\log_{10}(1000) = 3$."
      },
      {
        "type": "mcq",
        "question": "Simplify $\\frac{\\log 81}{\\log 3}$.",
        "options": ["$4$", "$3$", "$2$", "$5$"],
        "answer": "A",
        "explanation": "$\\frac{\\log 81}{\\log 3} = \\log_3 81 = 4$ (since $3^4 = 81$)."
      },
      {
        "type": "mcq",
        "question": "Solve $2^x = 10$ using natural logs.",
        "options": ["$\\frac{\\ln 10}{\\ln 2}$", "$\\frac{\\ln 2}{\\ln 10}$", "$\\ln 8$", "$\\ln 12$"],
        "answer": "A",
        "explanation": "$\\ln(2^x) = \\ln 10 \\implies x \\ln 2 = \\ln 10 \\implies x = \\frac{\\ln 10}{\\ln 2}$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log_x 49 = 2$.",
        "options": ["$x = 7$", "$x = 49$", "$x = 14$", "$x = 2$"],
        "answer": "A",
        "explanation": "$\\log_x 49 = 2 \\implies x^2 = 49 \\implies x = 7$ (base must be positive and not equal to $1$)."
      },
      {
        "type": "mcq",
        "question": "If a sample starts at 100 and doubles every hour, how much is present at $t=3$?",
