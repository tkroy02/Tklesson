{
  "quiz": {
    "title": "Pre-Calculus (Exam 21)",
    "settings": {
      "timeLimit": "120min",
      "shuffleQuestions": true,
      "shuffleOptions": true
    },
    "questions": [
      {
        "type": "mcq",
        "question": "Find the value of $k$ such that $x^2 + 12x + k = 0$ has two real solutions.",
        "options": ["$k < 36$", "$k > 36$", "$k \\le 36$", "$k \\ge 36$"],
        "answer": "A",
        "explanation": "For two real solutions, $b^2 - 4ac > 0$. $144 - 4k > 0 \\implies 144 > 4k \\implies k < 36$."
      },
      {
        "type": "mcq",
        "question": "Solve the equation $|2x - 5| = 7$.",
        "options": ["$x = 6$ or $x = -1$", "$x = 6$ only", "$x = -1$ only", "$x = 12$ or $x = -2$"],
        "answer": "A",
        "explanation": "$2x - 5 = 7 \\implies x = 6$. $2x - 5 = -7 \\implies x = -1$."
      },
      {
        "type": "mcq",
        "question": "Determine if $f(x) = x^3 - 4x$ is even, odd, or neither.",
        "options": ["Odd", "Even", "Neither", "Both"],
        "answer": "A",
        "explanation": "$f(-x) = (-x)^3 - 4(-x) = -x^3 + 4x = -f(x)$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\begin{cases} 5 & x < 0 \\\\ x + 5 & x \\ge 0 \\end{cases}$, evaluate $f(-10) + f(10)$.",
        "options": ["$20$", "$15$", "$10$", "$25$"],
        "answer": "A",
        "explanation": "$f(-10) = 5$. $f(10) = 10 + 5 = 15$. $5 + 15 = 20$."
      },
      {
        "type": "mcq",
        "question": "If $f(x) = \\log_3(x)$, find $f^{-1}(2)$.",
        "options": ["$9$", "$6$", "$8$", "$3$"],
        "answer": "A",
        "explanation": "$f^{-1}(x) = 3^x$, so $3^2 = 9$."
      },
      {
        "type": "mcq",
        "question": "Find the quotient when $x^3 - 8$ is divided by $x - 2$.",
        "options": ["$x^2 + 2x + 4$", "$x^2 - 2x + 4$", "$x^2 + 2x - 4$", "$x^2 - 2x - 4$"],
        "answer": "A",
        "explanation": "This is a difference of cubes factorization divided by one of its factors."
      },
      {
        "type": "mcq",
        "question": "Use synthetic division to evaluate $P(-2)$ for $P(x) = x^3 + 4x^2 + x - 6$.",
        "options": ["$0$", "$2$", "$-2$", "$4$"],
        "answer": "A",
        "explanation": "Coefficients [1, 4, 1, -6] with $-2$ results in a remainder of $0$."
      },
      {
        "type": "mcq",
        "question": "What is the maximum number of positive real roots for $P(x) = x^5 + x^3 + x + 1$?",
        "options": ["$0$", "$1$", "$2$", "$3$"],
        "answer": "A",
        "explanation": "There are no sign changes in the coefficients, so there are no positive real roots."
      },
      {
        "type": "mcq",
        "question": "Solve $\\frac{x+3}{x} = 2$.",
        "options": ["$x = 3$", "$x = 2$", "$x = 1$", "$x = 0$"],
        "answer": "A",
        "explanation": "$x + 3 = 2x \\implies x = 3$."
      },
      {
        "type": "mcq",
        "question": "Solve the inequality $\\frac{1}{x} \\le 1$.",
        "options": ["$(-\\infty, 0) \\cup [1, \\infty)$", "$(0, 1]$", "$[1, \\infty)$", "$(-\\infty, 0) \\cup (1, \\infty)$"],
        "answer": "A",
        "explanation": "Critical values at 0 and 1. Test values show the inequality holds outside of $(0, 1)$."
      },
      {
        "type": "mcq",
        "question": "Find the vertical asymptote of $f(x) = \\frac{2x - 4}{x^2 - 4}$.",
        "options": ["$x = -2$", "$x = 2$", "$x = 2$ and $x = -2$", "No vertical asymptote"],
        "answer": "A",
        "explanation": "$x^2 - 4 = (x-2)(x+2)$. The factor $(x-2)$ cancels with the numerator (creating a hole), leaving $x = -2$ as the asymptote."
      },
      {
        "type": "mcq",
        "question": "In $\\frac{2x}{(x-1)(x+1)} = \\frac{A}{x-1} + \\frac{B}{x+1}$, find $A$.",
        "options": ["$A = 1$", "$A = 2$", "$A = -1$", "$A = 0$"],
        "answer": "A",
        "explanation": "Cover-up at $x=1$: $A = \\frac{2(1)}{1+1} = \\frac{2}{2} = 1$."
      },
      {
        "type": "mcq",
        "question": "Find the horizontal asymptote of $f(x) = 5^x + 7$.",
        "options": ["$y = 7$", "$y = 5$", "$y = 0$", "No horizontal asymptote"],
        "answer": "A",
        "explanation": "As $x \\to -\\infty$, $5^x \\to 0$, so the function approaches $7$."
      },
      {
        "type": "mcq",
        "question": "Evaluate $\\ln(1) + \\log(10)$.",
        "options": ["$1$", "$2$", "$0$", "$10$"],
        "answer": "A",
        "explanation": "$\\ln(1) = 0$, $\\log(10) = 1$, sum $= 1$."
      },
      {
        "type": "mcq",
        "question": "Simplify $(\\log_2 5)(\\log_5 8)$.",
        "options": ["$3$", "$2$", "$4$", "$5$"],
        "answer": "A",
        "explanation": "$\\frac{\\log 5}{\\log 2} \\cdot \\frac{\\log 8}{\\log 5} = \\frac{\\log 8}{\\log 2} = \\log_2 8 = 3$."
      },
      {
        "type": "mcq",
        "question": "Solve $10^x = 0.001$.",
        "options": ["$x = -3$", "$x = 3$", "$x = -2$", "$x = 2$"],
        "answer": "A",
        "explanation": "$10^x = 10^{-3} \\implies x = -3$."
      },
      {
        "type": "mcq",
        "question": "Solve $\\log_2(x) + \\log_2(8) = 5$.",
        "options": ["$x = 4$", "$x = 2$", "$x = 8$", "$x = 16$"],
        "answer": "A",
        "explanation": "$\\log_2(8x) = 5 \\implies 8x = 2^5 \\implies 8x = 32 \\implies x = 4$."
      },
      {
        "type": "mcq",
        "question": "A substance triples every 4 hours. If you start with 10g, write the function $M(t)$.",
        "options": ["$M(t) = 10 \\cdot 3^{t/4}$", "$M(t) = 10 \\cdot 3^{4t}$", "$M(t) = 10 \\cdot 3^{t}$", "$M(t) = 10 \\cdot 3^{t-4}$"],
        "answer": "A",
        "explanation": "Growth follows the form $A_0(\\text{base})^{t/\\text{period}}$."
      },
      {
        "type": "mcq",
        "question": "Calculate $\\begin{bmatrix} 1 & 2 \\end{bmatrix} \\begin{bmatrix} 3 \\\\ 4 \\end{bmatrix}$.",
        "options": ["$[11]$", "$[7]$", "$[10]$", "$[12]$"],
        "answer": "A",
        "explanation": "$(1)(3) + (2)(4) = 3 + 8 = 11$."
      },
      {
        "type": "mcq",
        "question": "Given a system of 2 equations and 2 variables, if the reduced row echelon form is the identity matrix, how many solutions exist?",
        "options": ["$1$", "$0$", "Infinitely many", "Cannot determine"],
        "answer": "A",
        "explanation": "The identity matrix indicates each variable has a specific, unique value."
      },
      {
        "type": "mcq",
        "question": "What is the determinant of $3I$ for a $2 \\times 2$ identity matrix?",
        "options": ["$9$", "$3$", "$1$", "$0$"],
        "answer": "A",
        "explanation": "The matrix is $\\begin{bmatrix} 3 & 0 \\\\ 0 & 3 \\end{bmatrix}$, so $(3)(3) - 0 = 9$."
      },
      {
        "type": "mcq",
        "question": "If the determinant of the coefficient matrix is 0, what does Cramer's Rule say about the system?",
        "options": ["Cannot be used", "Unique solution", "No solution", "Infinitely many solutions"],
        "answer": "A",
        "explanation": "Cramer's Rule requires dividing by the determinant; if it is 0, the rule is inapplicable."
      },
      {
        "type": "mcq",
        "question": "Find the reference angle for $330^\\circ$.",
        "options": ["$30^\\circ$", "$60^\\circ$", "$45^\\circ$", "$90^\\circ$"],
        "answer": "A",
        "explanation": "$360 - 330 = 30$."
      },
      {
        "type": "mcq",
        "question": "Find the arc length if $r = 10$ and the angle is $180^\\circ$.",
        "options": ["$10\\pi$", "$5\\pi$", "$20\\pi$", "$\\pi$"],
        "answer": "A",
        "explanation": "$s = r\\theta = 10(\\pi) = 10\\pi$."
      },
      {
        "type": "mcq",
        "question": "Find the area of a sector with radius 2 and central angle $90^\\circ$.",
        "options": ["$\\pi$", "$2\\pi$", "$\\pi/2$", "$4\\pi$"],
        "answer": "A",
        "explanation": "$90^\\circ = \\pi/2$ rad. Area $= 0.5(2^2)(\\pi/2) = \\pi$."
      },
      {
        "type": "mcq",
        "question": "What is the smallest positive coterminal angle for $-10^\\circ$?",
        "options": ["$350^\\circ$", "$10^\\circ$", "$-350^\\circ$", "$370^\\circ$"],
        "answer": "A",
        "explanation": "$-10 + 360 = 350$."
      },
      {
        "type": "mcq",
        "question": "If $\\sin \\theta = 0.8$, find $\\csc \\theta$.",
