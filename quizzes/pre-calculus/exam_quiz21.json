        "answer": "A",
        "explanation": "$8\\text{cis } 90^\\circ = 8i$."
      },
      {
        "type": "mcq",
        "question": "Find the sum of the coefficients in $(x+y)^3$.",
        "options": ["$8$", "$6$", "$4$", "$2$"],
        "answer": "A",
        "explanation": "Let $x = 1, y = 1$. $(1+1)^3 = 8$."
      },
      {
        "type": "mcq",
        "question": "How many ways can 5 people stand in a line?",
