        "question": "Simplify: $(3x^2 - 5x + 7) - (2x^2 + 4x - 3)$",
        "options": [
          "$x^2 - 9x + 10$",
          "$x^2 + x + 4$",
          "$5x^2 - x + 10$",
          "$x^2 - x + 4$"
        ],
        "answer": "A",
        "explanation": "$3x^2 - 5x + 7 - 2x^2 - 4x + 3 = x^2 - 9x + 10$."
      },
      {
        "type": "mcq",
        "question": "Multiply: $(2x + 5)(x - 3)$",
        "options": [
          "$2x^2 - x - 15$",
          "$2x^2 - 11x - 15$",
          "$2x^2 + 11x - 15$",
          "$2x^2 + x - 15$"
        ],
        "answer": "A",
        "explanation": "$2x(x) + 2x(-3) + 5(x) + 5(-3) = 2x^2 - 6x + 5x - 15 = 2x^2 - x - 15$."
      },
      {
        "type": "mcq",
        "question": "Multiply: $(x - 4)(x^2 + 3x - 5)$",
        "options": [
          "$x^3 - x^2 - 17x + 20$",
          "$x^3 + 7x^2 - 17x + 20$",
          "$x^3 - x^2 + 7x + 20$",
          "$x^3 + x^2 - 17x - 20$"
        ],
        "answer": "A",
        "explanation": "$x(x^2 + 3x - 5) - 4(x^2 + 3x - 5) = x^3 + 3x^2 - 5x - 4x^2 - 12x + 20 = x^3 - x^2 - 17x + 20$."
      },
      {
