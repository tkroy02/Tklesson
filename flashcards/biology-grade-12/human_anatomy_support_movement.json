
{
  "flashcards": [
    {
      "category": "Grade 12 Biology: Human Anatomy: Support & Movement",
      "cards": [
        {
          "front": "What are the main functions of the **skeletal system**?",
          "back": "Support, protection, movement, mineral storage, blood cell production."
        },
        {
          "front": "How many bones in the adult human body?",
          "back": "206."
        },
        {
          "front": "What are the two divisions of the skeleton?",
          "back": "**Axial skeleton** and **Appendicular skeleton**."
        },
        {
          "front": "What makes up the **axial skeleton**?",
          "back": "Skull, vertebral column, rib cage, sternum."
        },
        {
          "front": "What makes up the **appendicular skeleton**?",
          "back": "Pectoral girdle, pelvic girdle, limbs."
        },
        {
          "front": "What are the 5 bone shapes?",
          "back": "Long, short, flat, irregular, sesamoid."
        },
        {
          "front": "Example of a long bone?",
          "back": "Femur, humerus."
        },
        {
          "front": "Example of a flat bone?",
          "back": "Skull, ribs, sternum."
        },
        {
          "front": "What is the **diaphysis**?",
          "back": "Shaft of a long bone."
        },
        {
          "front": "What is the **epiphysis**?",
          "back": "End of a long bone."
        },
        {
          "front": "What is **compact bone**?",
          "back": "Dense outer bone layer, made of osteons (Haversian systems)."
        },
        {
          "front": "What is **spongy bone**?",
          "back": "Porous inner bone containing red marrow."
        },
        {
          "front": "Where is **red marrow** found and its function?",
          "back": "Spongy bone; hematopoiesis (blood cell production)."
        },
        {
          "front": "What is **yellow marrow**?",
          "back": "Fat storage in medullary cavity of long bones."
        },
        {
          "front": "What are **osteoblasts**?",
          "back": "Bone-forming cells."
        },
        {
          "front": "What are **osteoclasts**?",
          "back": "Bone-resorbing (breaking down) cells."
        },
        {
          "front": "What are **osteocytes**?",
          "back": "Mature bone cells maintaining bone matrix."
        },
        {
          "front": "What is an **osteon (Haversian system)**?",
          "back": "Structural unit of compact bone: concentric lamellae around a central canal."
        },
        {
          "front": "What is **ossification**?",
          "back": "Bone formation (endochondral or intramembranous)."
        },
        {
          "front": "What are the 3 types of joints (functional)?",
          "back": "**Synarthrosis** (immovable), **Amphiarthrosis** (slightly movable), **Diarthrosis** (freely movable)."
        },
        {
          "front": "What are the 3 types of joints (structural)?",
          "back": "**Fibrous**, **Cartilaginous**, **Synovial**."
        },
        {
          "front": "What is a **synovial joint**?",
          "back": "Freely movable joint with articular cartilage, synovial fluid, joint capsule."
        },
        {
          "front": "Function of **synovial fluid**?",
          "back": "Lubricates and nourishes joint cartilage."
        },
        {
          "front": "Types of synovial joints?",
          "back": "Hinge, ball-and-socket, pivot, saddle, gliding, condyloid."
        },
        {
          "front": "Example of a hinge joint?",
          "back": "Elbow, knee."
        },
        {
          "front": "Example of a ball-and-socket joint?",
          "back": "Shoulder, hip."
        },
        {
          "front": "What are the 3 types of muscle tissue?",
          "back": "Skeletal, Cardiac, Smooth."
        },
        {
          "front": "Which muscle type is voluntary?",
          "back": "Skeletal."
        },
        {
          "front": "Which muscle type is striated?",
          "back": "Skeletal and Cardiac."
        },
        {
          "front": "What is the functional unit of skeletal muscle?",
          "back": "Sarcomere."
        },
        {
          "front": "What are the two main contractile proteins?",
          "back": "**Actin** (thin filament) and **Myosin** (thick filament)."
        },
        {
          "front": "What is the **sliding filament model**?",
          "back": "Myosin heads pull actin filaments inward, shortening the sarcomere."
        },
        {
          "front": "What role does **ATP** play in muscle contraction?",
          "back": "Energizes myosin head; binds to myosin to release actin; powers calcium pump."
        },
        {
          "front": "What is the role of **calcium** in muscle contraction?",
          "back": "Binds troponin, causing tropomyosin to expose myosin-binding sites on actin."
        },
        {
          "front": "What is the **neuromuscular junction**?",
          "back": "Synapse between motor neuron and muscle fiber."
        },
        {
          "front": "What neurotransmitter triggers muscle contraction?",
          "back": "Acetylcholine (ACh)."
        },
        {
          "front": "What is a **motor unit**?",
          "back": "A motor neuron and all the muscle fibers it innervates."
        },
        {
          "front": "Define **origin** (muscle attachment).",
          "back": "Attachment to the stationary bone."
        },
        {
          "front": "Define **insertion** (muscle attachment).",
          "back": "Attachment to the movable bone."
        },
        {
          "front": "What is **antagonistic muscle pair**?",
          "back": "Two muscles with opposite actions (e.g., biceps brachii and triceps brachii)."
        }
      ]
    }
  ]
}
