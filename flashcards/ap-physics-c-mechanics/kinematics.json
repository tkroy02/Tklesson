{
  "flashcards": [
    {
      "category": "AP Physics C: Mechanics - Kinematics",
      "cards": [
        {
          "front": "Define **position vector**.",
          "back": "A vector from the origin to an object's location: $\\vec{r}$."
        },
        {
          "front": "Define **displacement**.",
          "back": "$\\Delta \\vec{r} = \\vec{r}_f - \\vec{r}_i$. Vector quantity."
        },
        {
          "front": "Define **distance** vs. **displacement**.",
          "back": "Distance: scalar, path-dependent. Displacement: vector, path-independent."
        },
        {
          "front": "Define **average velocity**.",
          "back": "$\\vec{v}_{\\text{avg}} = \\frac{\\Delta \\vec{r}}{\\Delta t}$"
        },
        {
          "front": "Define **instantaneous velocity**.",
          "back": "$\\vec{v} = \\frac{d\\vec{r}}{dt}$"
        },
        {
          "front": "Define **speed**.",
          "back": "$|\\vec{v}|$. Scalar magnitude of velocity."
        },
        {
          "front": "Define **average acceleration**.",
          "back": "$\\vec{a}_{\\text{avg}} = \\frac{\\Delta \\vec{v}}{\\Delta t}$"
        },
        {
          "front": "Define **instantaneous acceleration**.",
          "back": "$\\vec{a} = \\frac{d\\vec{v}}{dt} = \\frac{d^2\\vec{r}}{dt^2}$"
        },
        {
          "front": "1D constant acceleration: $v(t)$?",
          "back": "$v = v_0 + at$"
        },
        {
          "front": "1D constant acceleration: $x(t)$?",
          "back": "$x = x_0 + v_0 t + \\frac{1}{2}at^2$"
        },
        {
          "front": "1D constant acceleration: $v^2$ (no $t$)?",
          "back": "$v^2 = v_0^2 + 2a(x - x_0)$"
        },
        {
          "front": "1D constant acceleration: position (no $a$)?",
          "back": "$x = x_0 + \\frac{1}{2}(v_0 + v)t$"
        },
        {
          "front": "What is **free fall**?",
          "back": "Motion under gravity only. $a_y = -g = -9.8\\ \\text{m/s}^2$."
        },
        {
          "front": "What is a **vector**?",
          "back": "A quantity with magnitude and direction."
        },
        {
          "front": "What is a **scalar**?",
          "back": "A quantity with magnitude only."
        },
        {
          "front": "Vector in component form?",
          "back": "$\\vec{A} = A_x \\hat{i} + A_y \\hat{j} + A_z \\hat{k}$"
        },
        {
          "front": "Given $\\theta$ from $+x$ axis, find components.",
          "back": "$A_x = A\\cos\\theta$, $A_y = A\\sin\\theta$"
        },
        {
          "front": "Magnitude of $\\vec{A}$?",
          "back": "$|\\vec{A}| = \\sqrt{A_x^2 + A_y^2 + A_z^2}$"
        },
        {
          "front": "Direction of $\\vec{A}$ (2D)?",
          "back": "$\\theta = \\tan^{-1}\\left(\\frac{A_y}{A_x}\\right)$"
        },
        {
          "front": "Define **dot product**.",
          "back": "$\\vec{A} \\cdot \\vec{B} = |A||B|\\cos\\theta = A_x B_x + A_y B_y + A_z B_z$. Scalar."
        },
        {
          "front": "Define **cross product** magnitude.",
          "back": "$|\\vec{A} \\times \\vec{B}| = |A||B|\\sin\\theta$"
        },
        {
          "front": "Cross product direction?",
          "back": "Right-hand rule: fingers $\\vec{A}$ to $\\vec{B}$, thumb = $\\vec{A} \\times \\vec{B}$."
        },
        {
          "front": "Cross product using components?",
          "back": "$\\vec{A} \\times \\vec{B} = \\begin{vmatrix} \\hat{i} & \\hat{j} & \\hat{k} \\\\ A_x & A_y & A_z \\\\ B_x & B_y & B_z \\end{vmatrix}$"
        },
        {
          "front": "Projectile motion: $x(t)$?",
          "back": "$x = x_0 + v_{0x} t$, with $v_x = v_{0x}$ constant."
        },
        {
          "front": "Projectile motion: $y(t)$?",
          "back": "$y = y_0 + v_{0y} t - \\frac{1}{2}gt^2$, with $v_y = v_{0y} - gt$"
        },
        {
          "front": "Range equation (level ground, launch angle $\\theta$)?",
          "back": "$R = \\frac{v_0^2 \\sin 2\\theta}{g}$"
        },
        {
          "front": "Angle for maximum range?",
          "back": "$45^\\circ$"
        },
        {
          "front": "At the peak of projectile motion, $v_y =$ ?",
          "back": "$v_y = 0$"
        },
        {
          "front": "What is **relative velocity**?",
          "back": "$\\vec{v}_{AC} = \\vec{v}_{AB} + \\vec{v}_{BC}$"
        },
        {
          "front": "Slope of $x$-$t$ graph?",
          "back": "Velocity: $v = dx/dt$."
        },
        {
          "front": "Slope of $v$-$t$ graph?",
          "back": "Acceleration: $a = dv/dt$."
        },
        {
          "front": "Area under $v$-$t$ curve?",
          "back": "$\\Delta x = \\int v\\,dt$ (displacement)."
        },
        {
          "front": "Area under $a$-$t$ curve?",
          "back": "$\\Delta v = \\int a\\,dt$ (change in velocity)."
        },
        {
          "front": "Constant velocity on $x$-$t$ graph?",
          "back": "Straight line."
        },
        {
          "front": "Constant acceleration on $v$-$t$ graph?",
          "back": "Straight line."
        },
        {
          "front": "Object at rest on $x$-$t$ graph?",
          "back": "Horizontal line ($v = 0$)."
        },
        {
          "front": "Define **jerk**.",
          "back": "$\\vec{j} = \\frac{d\\vec{a}}{dt} = \\frac{d^3\\vec{r}}{dt^3}$"
        },
        {
          "front": "Velocity from acceleration (integral form)?",
          "back": "$\\vec{v}(t) = \\vec{v}_0 + \\int_0^t \\vec{a}(t)\\,dt$"
        },
        {
          "front": "Position from velocity (integral form)?",
          "back": "$\\vec{r}(t) = \\vec{r}_0 + \\int_0^t \\vec{v}(t)\\,dt$"
        },
        {
          "front": "What is **uniform circular motion**?",
          "back": "Constant speed, changing direction. Centripetal acceleration $a_c = \\frac{v^2}{r}$ toward center."
        }
      ]
    }
  ]
}
