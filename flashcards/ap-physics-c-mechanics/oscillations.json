{
  "flashcards": [
    {
      "category": "AP Physics C: Mechanics - Oscillations",
      "cards": [
        {
          "front": "Define **simple harmonic motion (SHM)**.",
          "back": "Motion where the restoring force is proportional to displacement and opposite in direction: $F = -kx$."
        },
        {
          "front": "Differential equation for SHM?",
          "back": "$\\frac{d^2x}{dt^2} + \\omega^2 x = 0$"
        },
        {
          "front": "General solution for SHM?",
          "back": "$x(t) = A\\cos(\\omega t + \\phi)$ or $x(t) = A\\sin(\\omega t + \\phi_0)$"
        },
        {
          "front": "Define **amplitude** $A$.",
          "back": "Maximum displacement from equilibrium."
        },
        {
          "front": "Define **angular frequency** $\\omega$.",
          "back": "$\\omega = 2\\pi f = \\frac{2\\pi}{T}$. Rate of oscillation in rad/s."
        },
        {
          "front": "Define **frequency** $f$.",
          "back": "Number of oscillations per second. $f = \\frac{1}{T}$. SI unit: Hz."
        },
        {
          "front": "Define **period** $T$.",
          "back": "Time for one complete oscillation. $T = \\frac{1}{f} = \\frac{2\\pi}{\\omega}$."
        },
        {
          "front": "Define **phase constant** $\\phi$.",
          "back": "Determines initial position and direction of motion at $t = 0$."
        },
        {
          "front": "Velocity in SHM?",
          "back": "$v(t) = \\frac{dx}{dt} = -\\omega A\\sin(\\omega t + \\phi)$"
        },
        {
          "front": "Maximum speed in SHM?",
          "back": "$v_{\\text{max}} = \\omega A$"
        },
        {
          "front": "Acceleration in SHM?",
          "back": "$a(t) = \\frac{d^2x}{dt^2} = -\\omega^2 A\\cos(\\omega t + \\phi) = -\\omega^2 x$"
        },
        {
          "front": "Maximum acceleration in SHM?",
          "back": "$a_{\\text{max}} = \\omega^2 A$"
        },
        {
          "front": "Period of a **mass-spring system**?",
          "back": "$T = 2\\pi\\sqrt{\\frac{m}{k}}$"
        },
        {
          "front": "Angular frequency of mass-spring?",
          "back": "$\\omega = \\sqrt{\\frac{k}{m}}$"
        },
        {
          "front": "Period of a **simple pendulum**?",
          "back": "$T = 2\\pi\\sqrt{\\frac{L}{g}}$"
        },
        {
          "front": "Angular frequency of simple pendulum?",
          "back": "$\\omega = \\sqrt{\\frac{g}{L}}$"
        },
        {
          "front": "Period of a **physical pendulum**?",
          "back": "$T = 2\\pi\\sqrt{\\frac{I}{mgd}}$, where $d$ is distance from pivot to CM."
        },
        {
          "front": "Period of a **torsional pendulum**?",
          "back": "$T = 2\\pi\\sqrt{\\frac{I}{\\kappa}}$, where $\\kappa$ is torsional constant."
        },
        {
          "front": "Energy in SHM (spring)?",
          "back": "$E = \\frac{1}{2}kA^2 = \\frac{1}{2}mv^2 + \\frac{1}{2}kx^2$ (constant)."
        },
        {
          "front": "Kinetic energy in SHM as function of time?",
          "back": "$K = \\frac{1}{2}kA^2\\sin^2(\\omega t + \\phi)$"
        },
        {
          "front": "Potential energy in SHM (spring)?",
          "back": "$U = \\frac{1}{2}kx^2 = \\frac{1}{2}kA^2\\cos^2(\\omega t + \\phi)$"
        },
        {
          "front": "When are $K$ and $U$ equal in SHM?",
          "back": "When $x = \\pm A/\\sqrt{2}$."
        },
        {
          "front": "What is a **damped oscillation**?",
          "back": "Oscillation where amplitude decreases over time due to a damping force, often $F_d = -bv$."
        },
        {
          "front": "Differential equation for damped oscillator?",
          "back": "$m\\frac{d^2x}{dt^2} + b\\frac{dx}{dt} + kx = 0$"
        },
        {
          "front": "Define **underdamped** motion.",
          "back": "System oscillates with exponentially decaying amplitude. $b < 2\\sqrt{mk}$."
        },
        {
          "front": "Define **critically damped** motion.",
          "back": "Returns to equilibrium fastest without oscillating. $b = 2\\sqrt{mk}$."
        },
        {
          "front": "Define **overdamped** motion.",
          "back": "Returns to equilibrium slowly without oscillating. $b > 2\\sqrt{mk}$."
        },
        {
          "front": "What is a **driven (forced) oscillator**?",
          "back": "System subjected to an external periodic driving force $F(t) = F_0\\cos(\\omega_d t)$."
        },
        {
          "front": "What is **resonance**?",
          "back": "When driving frequency $\\omega_d$ equals natural frequency $\\omega_0$, amplitude becomes maximum."
        },
        {
          "front": "Natural frequency of a mass-spring system?",
          "back": "$\\omega_0 = \\sqrt{\\frac{k}{m}}$"
        },
        {
          "front": "At resonance, what is the phase difference between driving force and displacement?",
          "back": "$90^\\circ$ ($\\pi/2$ radians). Velocity is in phase with driving force."
        },
        {
          "front": "$x(t)$ vs. $v(t)$ vs. $a(t)$ phase relations in SHM?",
          "back": "$v$ leads $x$ by $90^\\circ$. $a$ leads $x$ by $180^\\circ$ (opposite). $a$ leads $v$ by $90^\\circ$."
        },
        {
          "front": "Small angle approximation for pendulum?",
          "back": "$\\sin\\theta \\approx \\theta$ (in radians). Valid for $\\theta \\lesssim 15^\\circ$."
        },
        {
          "front": "SHM as projection of uniform circular motion. $x(t)$?",
          "back": "$x(t) = A\\cos(\\omega t + \\phi)$. The $x$-component of a point moving on a circle of radius $A$."
        },
        {
          "front": "Effective spring constant: springs in **series**?",
          "back": "$\\frac{1}{k_{\\text{eff}}} = \\frac{1}{k_1} + \\frac{1}{k_2}$"
        },
        {
          "front": "Effective spring constant: springs in **parallel**?",
          "back": "$k_{\\text{eff}} = k_1 + k_2$"
        },
        {
          "front": "Vertical mass-spring equilibrium position?",
          "back": "$x_{\\text{eq}} = mg/k$ (stretch from natural length). Oscillations occur about this equilibrium with same $\\omega = \\sqrt{k/m}$."
        },
        {
          "front": "Energy loss per cycle in lightly damped oscillator?",
          "back": "$\\Delta E \\approx -\\frac{2\\pi b}{m\\omega_0}E$"
        },
        {
          "front": "Quality factor $Q$ of an oscillator?",
          "back": "$Q = 2\\pi \\frac{\\text{energy stored}}{\\text{energy lost per cycle}} \\approx \\frac{m\\omega_0}{b}$"
        }
      ]
    }
  ]
}
