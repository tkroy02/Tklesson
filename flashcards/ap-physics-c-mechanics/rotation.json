{
  "flashcards": [
    {
      "category": "AP Physics C: Mechanics - Rotation",
      "cards": [
        {
          "front": "Define **angular position** $\\theta$.",
          "back": "Angle measured from a reference line. SI unit: radian."
        },
        {
          "front": "Define **angular displacement**.",
          "back": "$\\Delta \\theta = \\theta_f - \\theta_i$"
        },
        {
          "front": "Define **angular velocity** $\\omega$.",
          "back": "$\\omega = \\frac{d\\theta}{dt}$"
        },
        {
          "front": "Define **angular acceleration** $\\alpha$.",
          "back": "$\\alpha = \\frac{d\\omega}{dt} = \\frac{d^2\\theta}{dt^2}$"
        },
        {
          "front": "Kinematic equations for constant $\\alpha$? (list 3)",
          "back": "$\\omega = \\omega_0 + \\alpha t$; $\\theta = \\theta_0 + \\omega_0 t + \\frac{1}{2}\\alpha t^2$; $\\omega^2 = \\omega_0^2 + 2\\alpha(\\theta - \\theta_0)$"
        },
        {
          "front": "Arc length from angular position?",
          "back": "$s = r\\theta$ ($\\theta$ in radians)."
        },
        {
          "front": "Tangential velocity from $\\omega$?",
          "back": "$v_t = r\\omega$"
        },
        {
          "front": "Tangential acceleration from $\\alpha$?",
          "back": "$a_t = r\\alpha$"
        },
        {
          "front": "Centripetal (radial) acceleration in angular form?",
          "back": "$a_c = \\frac{v^2}{r} = \\omega^2 r$"
        },
        {
          "front": "Define **moment of inertia** for a particle.",
          "back": "$I = mr^2$"
        },
        {
          "front": "Moment of inertia for a system of particles?",
          "back": "$I = \\sum m_i r_i^2$"
        },
        {
          "front": "Moment of inertia for a continuous body?",
          "back": "$I = \\int r^2\\,dm$"
        },
        {
          "front": "State the **parallel axis theorem**.",
          "back": "$I = I_{\\text{cm}} + Md^2$, where $d$ is distance between axes."
        },
        {
          "front": "Moment of inertia: thin rod about center?",
          "back": "$I_{\\text{cm}} = \\frac{1}{12}ML^2$"
        },
        {
          "front": "Moment of inertia: thin rod about end?",
          "back": "$I = \\frac{1}{3}ML^2$"
        },
        {
          "front": "Moment of inertia: solid cylinder/disk about center?",
          "back": "$I_{\\text{cm}} = \\frac{1}{2}MR^2$"
        },
        {
          "front": "Moment of inertia: solid sphere about center?",
          "back": "$I_{\\text{cm}} = \\frac{2}{5}MR^2$"
        },
        {
          "front": "Moment of inertia: thin spherical shell?",
          "back": "$I_{\\text{cm}} = \\frac{2}{3}MR^2$"
        },
        {
          "front": "Moment of inertia: hoop about center?",
          "back": "$I_{\\text{cm}} = MR^2$"
        },
        {
          "front": "Define **torque**.",
          "back": "$\\vec{\\tau} = \\vec{r} \\times \\vec{F}$"
        },
        {
          "front": "Magnitude of torque?",
          "back": "$\\tau = rF\\sin\\theta = r_\\perp F = rF_\\perp$"
        },
        {
          "front": "What is the **lever arm (moment arm)**?",
          "back": "Perpendicular distance from axis to line of action of force: $r_\\perp = r\\sin\\theta$."
        },
        {
          "front": "Rotational analog of Newton's Second Law?",
          "back": "$\\Sigma \\tau = I\\alpha$"
        },
        {
          "front": "Define **rotational kinetic energy**.",
          "back": "$K_{\\text{rot}} = \\frac{1}{2}I\\omega^2$"
        },
        {
          "front": "Total KE of a rolling object?",
          "back": "$K = \\frac{1}{2}mv_{\\text{cm}}^2 + \\frac{1}{2}I_{\\text{cm}}\\omega^2$"
        },
        {
          "front": "Condition for **rolling without slipping**?",
          "back": "$v_{\\text{cm}} = R\\omega$ and $a_{\\text{cm}} = R\\alpha$"
        },
        {
          "front": "Define **angular momentum** of a particle.",
          "back": "$\\vec{L} = \\vec{r} \\times \\vec{p} = m(\\vec{r} \\times \\vec{v})$"
        },
        {
          "front": "Angular momentum for a rigid body?",
          "back": "$\\vec{L} = I\\vec{\\omega}$ (about a fixed axis)."
        },
        {
          "front": "Rotational form of Newton's 2nd Law (using $L$)?",
          "back": "$\\Sigma \\vec{\\tau} = \\frac{d\\vec{L}}{dt}$"
        },
        {
          "front": "State conservation of angular momentum.",
          "back": "If $\\Sigma \\vec{\\tau}_{\\text{ext}} = 0$, then $\\vec{L}_i = \\vec{L}_f$."
        },
        {
          "front": "Ice skater pulling arms in: explain.",
          "back": "$I$ decreases, $\\omega$ increases to keep $L = I\\omega$ constant."
        },
        {
          "front": "Define **work** in rotational form.",
          "back": "$W = \\int \\tau\\,d\\theta$"
        },
        {
          "front": "Work done by constant torque?",
          "back": "$W = \\tau \\Delta \\theta$"
        },
        {
          "front": "Power in rotational form?",
          "back": "$P = \\tau \\omega$"
        },
        {
          "front": "Work-energy theorem for rotation?",
          "back": "$W_{\\text{net}} = \\Delta K_{\\text{rot}} = \\frac{1}{2}I\\omega_f^2 - \\frac{1}{2}I\\omega_i^2$"
        },
        {
          "front": "What is **angular impulse**?",
          "back": "$\\int \\tau\\,dt = \\Delta L$"
        },
        {
          "front": "Right-hand rule for angular quantities?",
          "back": "Fingers curl in direction of rotation, thumb points in direction of $\\vec{\\omega}$, $\\vec{\\alpha}$, $\\vec{L}$, $\\vec{\\tau}$."
        },
        {
          "front": "Torque is to force as ___ is to ___?",
          "back": "Angular momentum is to linear momentum. ($\\tau : F :: L : p$)"
        },
        {
          "front": "What is **radius of gyration** $k$?",
          "back": "$I = Mk^2$, where $k$ is the distance from axis where all mass could be concentrated."
        }
      ]
    }
  ]
}
