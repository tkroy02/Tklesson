{
  "flashcards": [
    {
      "category": "Electricity & Circuits",
      "cards": [
        {
          "front": "What is **electric current** ($I$)?",
          "back": "Rate of flow of charge: $I = \\frac{\\Delta Q}{\\Delta t}$"
        },
        {
          "front": "What is the **SI unit of current**?",
          "back": "Ampere ($\\text{A}$), where $1 \\text{ A} = 1 \\text{ C/s}$"
        },
        {
          "front": "What is **voltage** ($V$)?",
          "back": "Electrical potential difference; energy per unit charge."
        },
        {
          "front": "What is the **SI unit of voltage**?",
          "back": "Volt ($\\text{V}$), where $1 \\text{ V} = 1 \\text{ J/C}$"
        },
        {
          "front": "What is **resistance** ($R$)?",
          "back": "Opposition to current flow; measured in ohms ($\\Omega$)."
        },
        {
          "front": "What is **Ohm's Law**?",
          "back": "$V = IR$"
        },
        {
          "front": "What is an **ohmic material**?",
          "back": "Material where $V \\propto I$ (constant resistance, e.g., metals at constant temperature)."
        },
        {
          "front": "What is **resistivity** ($\\rho$)?",
          "back": "Intrinsic property of a material: $R = \\rho \\frac{L}{A}$"
        },
        {
          "front": "How does **temperature** affect resistance in metals?",
          "back": "Resistance increases with increasing temperature."
        },
        {
          "front": "What is **power** in electrical circuits?",
          "back": "$P = IV = I^2R = \\frac{V^2}{R}$"
        },
        {
          "front": "What is the **SI unit of power**?",
          "back": "Watt ($\\text{W}$), where $1 \\text{ W} = 1 \\text{ J/s}$"
        },
        {
          "front": "What is **energy** in electrical circuits?",
          "back": "$E = P\\Delta t = IV\\Delta t$"
        },
        {
          "front": "What is a **series circuit**?",
          "back": "Components connected end-to-end; same current through all."
        },
        {
          "front": "What is **equivalent resistance** in series?",
          "back": "$R_{eq} = R_1 + R_2 + R_3 + ...$"
        },
        {
          "front": "What is a **parallel circuit**?",
          "back": "Components connected across same voltage; current divides."
        },
        {
          "front": "What is **equivalent resistance** in parallel?",
          "back": "$\\frac{1}{R_{eq}} = \\frac{1}{R_1} + \\frac{1}{R_2} + \\frac{1}{R_3} + ...$"
        },
        {
          "front": "How does **voltage** behave in series?",
          "back": "Total voltage divides among components: $V_{total} = V_1 + V_2 + V_3 + ...$"
        },
        {
          "front": "How does **voltage** behave in parallel?",
          "back": "Same voltage across each branch."
        },
        {
          "front": "How does **current** behave in series?",
          "back": "Same current through all components."
        },
        {
          "front": "How does **current** behave in parallel?",
          "back": "Total current divides: $I_{total} = I_1 + I_2 + I_3 + ...$"
        },
        {
          "front": "What is **Kirchhoff's Current Law** (KCL)?",
          "back": "Sum of currents entering a junction equals sum leaving."
        },
        {
          "front": "What is **Kirchhoff's Voltage Law** (KVL)?",
          "back": "Sum of voltage drops around any closed loop equals zero."
        },
        {
          "front": "What is a **junction** in a circuit?",
          "back": "A point where three or more conductors meet."
        },
        {
          "front": "What is a **loop** in a circuit?",
          "back": "Any closed conducting path."
        },
        {
          "front": "What is **internal resistance** ($r$)?",
          "back": "Resistance within a voltage source; causes terminal voltage to drop under load."
        },
        {
          "front": "What is **terminal voltage** ($V_T$)?",
          "back": "$V_T = \\varepsilon - Ir$, where $\\varepsilon$ is EMF."
        },
        {
          "front": "What is **EMF** ($\\varepsilon$)?",
          "back": "Electromotive force; energy per charge supplied by a source."
        },
        {
          "front": "What is a **short circuit**?",
          "back": "Low-resistance path bypassing normal load; causes high current."
        },
        {
          "front": "What is an **open circuit**?",
          "back": "Broken path; current is zero."
        },
        {
          "front": "What is an **ammeter**?",
          "back": "Device measuring current; connected in series."
        },
        {
          "front": "What is a **voltmeter**?",
          "back": "Device measuring voltage; connected in parallel."
        },
        {
          "front": "What is an **ideal ammeter**?",
          "back": "Has zero resistance."
        },
        {
          "front": "What is an **ideal voltmeter**?",
          "back": "Has infinite resistance."
        },
        {
          "front": "What is a **capacitor**?",
          "back": "Device storing electrical energy in an electric field."
        },
        {
          "front": "What is **capacitance** ($C$)?",
          "back": "$C = \\frac{Q}{V}$ (units: farad, $\\text{F}$)."
        },
        {
          "front": "What is the **energy stored** in a capacitor?",
          "back": "$U = \\frac{1}{2}CV^2 = \\frac{1}{2}QV = \\frac{Q^2}{2C}$"
        },
        {
          "front": "What is **equivalent capacitance** in series?",
          "back": "$\\frac{1}{C_{eq}} = \\frac{1}{C_1} + \\frac{1}{C_2} + \\frac{1}{C_3} + ...$"
        },
        {
          "front": "What is **equivalent capacitance** in parallel?",
          "back": "$C_{eq} = C_1 + C_2 + C_3 + ...$"
        },
        {
          "front": "What is the **time constant** ($\\tau$) in an RC circuit?",
          "back": "$\\tau = RC$"
        },
        {
          "front": "What is **charging equation** for capacitor?",
          "back": "$q(t) = Q_{max}(1 - e^{-t/\\tau})$"
        }
      ]
    }
  ]
}
