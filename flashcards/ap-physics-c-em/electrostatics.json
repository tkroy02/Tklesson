{
  "flashcards": [
    {
      "category": "AP Physics C: E&M - Electrostatics",
      "cards": [
        {
          "front": "Define **elementary charge** $e$.",
          "back": "$e = 1.60 \\times 10^{-19}\\ \\text{C}$. Magnitude of charge on proton/electron."
        },
        {
          "front": "Principle of **conservation of charge**?",
          "back": "Net charge in an isolated system remains constant."
        },
        {
          "front": "What is **quantization of charge**?",
          "back": "All charges are integer multiples of $e$: $q = ne$, $n \\in \\mathbb{Z}$."
        },
        {
          "front": "State **Coulomb's Law**.",
          "back": "$\\vec{F}_{12} = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q_1 q_2}{r^2}\\hat{r}_{12}$"
        },
        {
          "front": "Value of $\\frac{1}{4\\pi\\varepsilon_0}$?",
          "back": "$k = 8.99 \\times 10^9\\ \\text{N}\\cdot\\text{m}^2/\\text{C}^2$"
        },
        {
          "front": "Permittivity of free space $\\varepsilon_0$?",
          "back": "$\\varepsilon_0 = 8.85 \\times 10^{-12}\\ \\text{C}^2/(\\text{N}\\cdot\\text{m}^2)$"
        },
        {
          "front": "Define **electric field** $\\vec{E}$.",
          "back": "$\\vec{E} = \\frac{\\vec{F}}{q}$. Force per unit charge on a positive test charge."
        },
        {
          "front": "Electric field of a **point charge**?",
          "back": "$\\vec{E} = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q}{r^2}\\hat{r}$"
        },
        {
          "front": "Electric field of a **dipole** (on axis, far field)?",
          "back": "$E \\approx \\frac{1}{4\\pi\\varepsilon_0}\\frac{2p}{r^3}$, where $p = qd$."
        },
        {
          "front": "Electric field of a dipole (perpendicular bisector, far field)?",
          "back": "$E \\approx \\frac{1}{4\\pi\\varepsilon_0}\\frac{p}{r^3}$"
        },
        {
          "front": "Define **electric dipole moment** $\\vec{p}$.",
          "back": "$\\vec{p} = q\\vec{d}$, directed from $-q$ to $+q$."
        },
        {
          "front": "Torque on a dipole in electric field?",
          "back": "$\\vec{\\tau} = \\vec{p} \\times \\vec{E}$"
        },
        {
          "front": "Potential energy of dipole in $\\vec{E}$?",
          "back": "$U = -\\vec{p} \\cdot \\vec{E}$"
        },
        {
          "front": "Electric field due to a **continuous charge distribution**?",
          "back": "$\\vec{E} = \\frac{1}{4\\pi\\varepsilon_0}\\int \\frac{dq}{r^2}\\hat{r}$"
        },
        {
          "front": "Linear charge density?",
          "back": "$\\lambda = dq/dx$ (C/m)."
        },
        {
          "front": "Surface charge density?",
          "back": "$\\sigma = dq/dA$ (C/m²)."
        },
        {
          "front": "Volume charge density?",
          "back": "$\\rho = dq/dV$ (C/m³)."
        },
        {
          "front": "Electric field of an **infinite line of charge**?",
          "back": "$E = \\frac{\\lambda}{2\\pi\\varepsilon_0 r}$, radially outward from line."
        },
        {
          "front": "Electric field of an **infinite sheet of charge**?",
          "back": "$E = \\frac{\\sigma}{2\\varepsilon_0}$, perpendicular to sheet, independent of distance."
        },
        {
          "front": "Electric field between two oppositely charged parallel plates?",
          "back": "$E = \\frac{\\sigma}{\\varepsilon_0}$, uniform, directed from + to -."
        },
        {
          "front": "Electric field inside a **conductor** in electrostatic equilibrium?",
          "back": "Zero."
        },
        {
          "front": "Properties of a conductor in electrostatic equilibrium?",
          "back": "$E=0$ inside, charge resides on surface, $E$ perpendicular to surface, $E = \\sigma/\\varepsilon_0$ just outside."
        },
        {
          "front": "Define **electric flux** $\\Phi_E$.",
          "back": "$\\Phi_E = \\int \\vec{E} \\cdot d\\vec{A}$"
        },
        {
          "front": "State **Gauss's Law**.",
          "back": "$\\oint \\vec{E} \\cdot d\\vec{A} = \\frac{q_{\\text{enc}}}{\\varepsilon_0}$"
        },
        {
          "front": "Gauss's Law: field inside a uniformly charged spherical shell ($r < R$)?",
          "back": "$E = 0$"
        },
        {
          "front": "Gauss's Law: field outside a uniformly charged spherical shell ($r > R$)?",
          "back": "$E = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q}{r^2}$ (as point charge)."
        },
        {
          "front": "Gauss's Law: field inside a uniformly charged solid sphere ($\\rho$ constant)?",
          "back": "$E = \\frac{\\rho r}{3\\varepsilon_0}$ (or $E = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q}{R^3}r$)."
        },
        {
          "front": "When is Gauss's Law useful?",
          "back": "High-symmetry cases: spherical, cylindrical, planar symmetry."
        },
        {
          "front": "Define **electric potential energy** $U$ for two point charges.",
          "back": "$U = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q_1 q_2}{r}$"
        },
        {
          "front": "Define **electric potential** $V$.",
          "back": "$V = \\frac{U}{q}$. Scalar potential energy per unit charge. SI unit: Volt (V) = J/C."
        },
        {
          "front": "Potential due to a point charge?",
          "back": "$V = \\frac{1}{4\\pi\\varepsilon_0}\\frac{q}{r}$, with $V = 0$ at $r \\to \\infty$."
        },
        {
          "front": "Relation between $\\vec{E}$ and $V$?",
          "back": "$\\vec{E} = -\\nabla V$. In 1D: $E_x = -\\frac{dV}{dx}$."
        },
        {
          "front": "Potential difference from $\\vec{E}$?",
          "back": "$\\Delta V = V_f - V_i = -\\int_i^f \\vec{E} \\cdot d\\vec{\\ell}$"
        },
        {
          "front": "Potential inside a conductor in electrostatic equilibrium?",
          "back": "Constant throughout; surface is equipotential."
        },
        {
          "front": "Work done by $\\vec{E}$ moving charge $q$?",
          "back": "$W_{\\text{field}} = -q\\Delta V = q(V_i - V_f)$"
        },
        {
          "front": "External work to move charge $q$?",
          "back": "$W_{\\text{ext}} = q\\Delta V = q(V_f - V_i)$"
        },
        {
          "front": "Electron-volt (eV) defined?",
          "back": "Energy gained by an electron moving through 1 V. $1\\ \\text{eV} = 1.60 \\times 10^{-19}\\ \\text{J}$."
        }
      ]
    }
  ]
}
