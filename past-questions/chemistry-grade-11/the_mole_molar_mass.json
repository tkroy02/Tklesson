        {
          "step": "Calculate empirical formula mass",
          "calculation": "CH₂O = 12.01 + 2.016 + 16.00 = 30.026 g/mol"
        },
        {
          "step": "Find ratio n = molar mass / empirical mass",
          "calculation": "n = 180.16 ÷ 30.026 = 6.00"
        },
        {
          "step": "Multiply empirical formula by n",
          "calculation": "(CH₂O)₆ = C₆H₁₂O₆"
