      "step_by_step": [
        {
          "step": "Find molar mass of H₂O",
          "calculation": "H₂O = (2 × 1.008) + 16.00 = 18.016 g/mol"
        },
        {
          "step": "Use conversion: mass = moles × molar mass",
          "calculation": "mass = 3.00 mol × 18.016 g/mol = 54.048 g"
        }
      ],
      "final_answer": "$54.0$ g"
    },
    {
      "number": 9,
      "problem": "How many molecules are in 36.0 g of water (H₂O)?",
