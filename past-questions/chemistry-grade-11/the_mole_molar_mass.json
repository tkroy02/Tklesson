{
  "course": "Chemistry Grade 11",
  "topic": "Unit 7: The Mole & Molar Mass",
  "description": "Avogadro's number, mole concept, conversions between mass, moles, and number of particles, and an introduction to empirical formulas.",
  "problems": [
    {
      "number": 1,
      "problem": "What is a mole? State Avogadro's number.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define the mole",
          "explanation": "A mole is the amount of substance containing the same number of particles as there are atoms in exactly 12 grams of carbon-12."
        },
        {
          "step": "State Avogadro's number",
          "calculation": "$6.022 \\times 10^{23}$ particles per mole"
        }
      ],
      "final_answer": "A mole is $6.022 \\times 10^{23}$ particles (Avogadro's number) of a substance."
    },
    {
      "number": 2,
      "problem": "How many atoms are in 2.50 moles of carbon?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Avogadro's number",
          "explanation": "$1 \\text{ mol} = 6.022 \\times 10^{23}$ atoms",
          "calculation": "$2.50 \\text{ mol} \\times 6.022 \\times 10^{23} \\text{ atoms/mol} = 1.5055 \\times 10^{24}$ atoms"
        }
      ],
      "final_answer": "$1.51 \\times 10^{24}$ atoms"
    },
    {
      "number": 3,
      "problem": "How many moles are in $3.01 \\times 10^{23}$ molecules of water?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Avogadro's number",
          "explanation": "$1 \\text{ mol} = 6.022 \\times 10^{23}$ molecules",
          "calculation": "$3.01 \\times 10^{23} \\text{ molecules} \\times \\frac{1 \\text{ mol}}{6.022 \\times 10^{23} \\text{ molecules}} = 0.500$ mol"
        }
      ],
      "final_answer": "$0.500$ mol"
    },
    {
      "number": 4,
      "problem": "Calculate the molar mass of sodium chloride (NaCl).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find atomic masses",
          "calculation": "Na = 22.99 g/mol, Cl = 35.45 g/mol"
        },
        {
          "step": "Add them together",
          "calculation": "22.99 + 35.45 = 58.44 g/mol"
        }
      ],
      "final_answer": "$58.44$ g/mol"
    },
    {
      "number": 5,
      "problem": "Calculate the molar mass of calcium hydroxide, Ca(OH)₂.",
      "image": null,
      "step_by_step": [
        {
          "step": "Find atomic masses",
          "calculation": "Ca = 40.08 g/mol, O = 16.00 g/mol, H = 1.008 g/mol"
        },
        {
          "step": "Calculate contributions",
          "calculation": "Ca: 40.08 × 1 = 40.08\nO: 16.00 × 2 = 32.00\nH: 1.008 × 2 = 2.016"
        },
        {
          "step": "Sum",
          "calculation": "40.08 + 32.00 + 2.016 = 74.096 g/mol"
        }
      ],
      "final_answer": "$74.10$ g/mol (rounded)"
    },
    {
      "number": 6,
      "problem": "Calculate the molar mass of glucose (C₆H₁₂O₆).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find atomic masses",
          "calculation": "C = 12.01 g/mol, H = 1.008 g/mol, O = 16.00 g/mol"
        },
        {
          "step": "Calculate contributions",
          "calculation": "C: 12.01 × 6 = 72.06\nH: 1.008 × 12 = 12.096\nO: 16.00 × 6 = 96.00"
        },
        {
          "step": "Sum",
          "calculation": "72.06 + 12.096 + 96.00 = 180.156 g/mol"
        }
      ],
      "final_answer": "$180.16$ g/mol"
    },
    {
      "number": 7,
      "problem": "How many moles are in 25.0 g of sodium chloride (NaCl)?",
      "image": null,
      "step_by_step": [
        {
          "step": "Find molar mass of NaCl",
          "calculation": "NaCl = 22.99 + 35.45 = 58.44 g/mol"
        },
        {
          "step": "Use conversion formula: moles = mass / molar mass",
          "calculation": "moles = 25.0 g ÷ 58.44 g/mol = 0.428 mol"
        }
      ],
      "final_answer": "$0.428$ mol"
    },
    {
      "number": 8,
      "problem": "What is the mass of 3.00 moles of water (H₂O)?",
