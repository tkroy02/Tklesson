    {
      "number": 14,
      "problem": "A compound contains 40.0% carbon, 6.7% hydrogen, and 53.3% oxygen by mass. Find its empirical formula.",
      "image": null,
      "step_by_step": [
        {
          "step": "Assume 100 g sample",
          "calculation": "C: 40.0 g, H: 6.7 g, O: 53.3 g"
        },
        {
          "step": "Convert to moles",
          "calculation": "C: 40.0 ÷ 12.01 = 3.33 mol\nH: 6.7 ÷ 1.008 = 6.65 mol\nO: 53.3 ÷ 16.00 = 3.33 mol"
        },
        {
          "step": "Divide by smallest mole value",
          "calculation": "C: 3.33 ÷ 3.33 = 1\nH: 6.65 ÷ 3.33 = 2.00\nO: 3.33 ÷ 3.33 = 1"
        },
        {
          "step": "Write empirical formula",
          "calculation": "CH₂O"
        }
      ],
      "final_answer": "CH₂O"
    },
    {
      "number": 15,
      "problem": "A compound contains 92.3% carbon and 7.7% hydrogen. Find its empirical formula.",
      "image": null,
      "step_by_step": [
