      "problem": "Name the following binary ionic compound (multivalent metal): FeCl₂",
      "image": null,
      "step_by_step": [
        {
          "step": "Determine charge of iron",
          "explanation": "Cl⁻ has charge -1; two Cl⁻ give total -2, so Fe must be +2."
        },
        {
          "step": "Identify element with charge",
          "calculation": "Iron(II)"
        },
        {
          "step": "Identify the anion",
          "explanation": "Cl⁻ is chloride."
        },
        {
          "step": "Combine names",
          "calculation": "Iron(II) chloride"
