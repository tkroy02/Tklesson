      "problem": "Write the formula for: sodium sulfide",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify ions",
          "explanation": "Sodium (Na⁺), sulfide (S²⁻)."
        },
        {
          "step": "Balance charges",
          "calculation": "Two Na⁺ are needed to balance one S²⁻."
        },
        {
          "step": "Write formula",
          "calculation": "Na₂S"
        }
      ],
      "final_answer": "Na₂S"
    },
    {
      "number": 13,
      "problem": "Write the formula for: aluminum oxide",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify ions",
          "explanation": "Aluminum (Al³⁺), oxide (O²⁻)."
        },
        {
          "step": "Find lowest common multiple of charges",
          "calculation": "LCM of 3 and 2 is 6. Need two Al³⁺ (total +6) and three O²⁻ (total -6)."
        },
        {
          "step": "Write formula",
          "calculation": "Al₂O₃"
        }
      ],
      "final_answer": "Al₂O₃"
