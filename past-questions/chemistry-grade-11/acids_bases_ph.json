      "image": null,
      "step_by_step": [
        {
          "step": "Define Arrhenius acid",
          "explanation": "An Arrhenius acid is a substance that produces $\\text{H}^+$ ions (protons) when dissolved in water."
        },
        {
          "step": "Define Arrhenius base",
          "explanation": "An Arrhenius base is a substance that produces $\\text{OH}^-$ ions when dissolved in water."
        }
      ],
      "final_answer": "Acid: produces $\\text{H}^+$ in water; Base: produces $\\text{OH}^-$ in water."
    },
