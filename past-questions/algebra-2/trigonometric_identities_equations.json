      "problem": "Find $\\sin 75^\\circ$ using the sum formula $\\sin(A + B) = \\sin A \\cos B + \\cos A \\sin B$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Write $75^\\circ = 45^\\circ + 30^\\circ$",
