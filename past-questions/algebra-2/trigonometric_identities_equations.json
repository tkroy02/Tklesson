      "number": 1,
      "problem": "Verify the identity $\\sin^2 x + \\cos^2 x = 1$ for $x = 45^\\circ$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute $\\sin 45^\\circ$ and $\\cos 45^\\circ$",
          "calculation": "$\\sin 45^\\circ = \\cos 45^\\circ = \\frac{\\sqrt{2}}{2}$"
        },
        {
          "step": "Compute LHS",
          "calculation": "$(\\sqrt{2}/2)^2 + (\\sqrt{2}/2)^2 = 1/2 + 1/2 = 1$"
        }
      ],
      "final_answer": "Verified"
    },
    {
