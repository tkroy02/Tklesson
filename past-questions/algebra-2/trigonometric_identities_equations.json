        },
        {
          "step": "Solve for argument",
          "calculation": "$\\frac{\\pi}{15}t = \\frac{\\pi}{6}$ or $\\frac{5\\pi}{6}$ (first two positive solutions)"
        },
        {
          "step": "Solve for $t$",
