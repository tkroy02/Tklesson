    {
      "number": 20,
      "problem": "Use mathematical induction to prove that $1 + 2 + 3 + \\dots + n = \\frac{n(n+1)}{2}$ for all positive integers $n$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Base case: $n = 1$",
          "calculation": "$1 = \\frac{1(2)}{2} = 1$, true"
        },
        {
          "step": "Inductive hypothesis",
          "explanation": "Assume true for $n = k$: $1 + 2 + \\dots + k = \\frac{k(k+1)}{2}$"
        },
        {
          "step": "Prove for $n = k+1$",
          "calculation": "$1 + 2 + \\dots + k + (k+1) = \\frac{k(k+1)}{2} + (k+1)$"
        },
        {
          "step": "Simplify",
          "calculation": "$= (k+1)\\left(\\frac{k}{2} + 1\\right) = (k+1)\\left(\\frac{k+2}{2}\\right) = \\frac{(k+1)(k+2)}{2}$"
        },
        {
          "step": "Conclusion",
          "explanation": "True for $n = k+1$, so true for all positive integers $n$"
        }
      ],
      "final_answer": "Formula proven by induction"
    }
