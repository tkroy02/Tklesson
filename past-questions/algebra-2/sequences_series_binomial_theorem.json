      "problem": "A ball is dropped from a height of 10 feet. Each bounce reaches $\\frac{3}{4}$ of the previous height. Find the total vertical distance traveled by the ball until it stops bouncing.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify distances",
          "calculation": "First drop: 10 ft\nFirst bounce up: $10 \\cdot \\frac{3}{4} = 7.5$ ft\nFirst bounce down: 7.5 ft\nSecond bounce up: $7.5 \\cdot \\frac{3}{4} = 5.625$ ft, etc."
        },
        {
          "step": "Set up infinite series",
          "calculation": "Total = $10 + 2(7.5 + 5.625 + \\dots)$"
        },
        {
          "step": "Sum the geometric series inside",
          "calculation": "$7.5 + 5.625 + \\dots = \\frac{7.5}{1 - 3/4} = \\frac{7.5}{1/4} = 30$"
        },
        {
          "step": "Calculate total",
          "calculation": "$10 + 2(30) = 10 + 60 = 70$ feet"
        }
      ],
      "final_answer": "$70$ feet"
