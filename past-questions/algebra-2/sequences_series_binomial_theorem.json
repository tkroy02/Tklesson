      "number": 16,
      "problem": "Expand $(x - 2)^4$ using the binomial theorem.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use binomial theorem",
          "calculation": "$(x - 2)^4 = \\sum_{k=0}^4 \\binom{4}{k} x^{4-k} (-2)^k$"
        },
        {
          "step": "Expand each term",
          "calculation": "$k=0: \\binom{4}{0} x^4 (-2)^0 = 1 \\cdot x^4 \\cdot 1 = x^4$\n$k=1: \\binom{4}{1} x^3 (-2)^1 = 4 \\cdot x^3 \\cdot (-2) = -8x^3$\n$k=2: \\binom{4}{2} x^2 (-2)^2 = 6 \\cdot x^2 \\cdot 4 = 24x^2$\n$k=3: \\binom{4}{3} x^1 (-2)^3 = 4 \\cdot x \\cdot (-8) = -32x$\n$k=4: \\binom{4}{4} x^0 (-2)^4 = 1 \\cdot 1 \\cdot 16 = 16$"
        }
      ],
      "final_answer": "$x^4 - 8x^3 + 24x^2 - 32x + 16$"
    },
