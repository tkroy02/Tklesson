      "image": null,
      "step_by_step": [
        {
          "step": "Use decay model $V(t) = V_0 (1 - r)^t$",
          "explanation": "Where $V_0 = 20000$, $r = 0.05$"
        },
        {
          "step": "Write model",
          "calculation": "$V(t) = 20000 (0.95)^t$"
        }
      ],
      "final_answer": "$V(t) = 20000 (0.95)^t$"
