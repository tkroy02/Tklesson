    {
      "number": 13,
      "problem": "If \\$1000 is invested at 6% annual interest compounded quarterly, what is the balance after 5 years?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use compound interest formula",
          "calculation": "$A = P\\left(1 + \\frac{r}{n}\\right)^{nt}$"
        },
        {
          "step": "Substitute values",
          "calculation": "$P = 1000$, $r = 0.06$, $n = 4$, $t = 5$"
        },
        {
          "step": "Compute",
          "calculation": "$A = 1000\\left(1 + \\frac{0.06}{4}\\right)^{20} = 1000(1.015)^{20}$"
        },
        {
          "step": "Approximate",
          "calculation": "$1.015^{20} \\approx 1.3469$, $A \\approx 1346.86$"
        }
      ],
      "final_answer": "Approximately \\$1,346.86"
