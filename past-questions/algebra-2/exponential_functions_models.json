  "topic": "Exponential Functions & Models",
  "problems": [
    {
      "number": 1,
      "problem": "Simplify $2^3 \\cdot 2^4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the law of exponents: $a^m \\cdot a^n = a^{m+n}$",
          "calculation": "$2^3 \\cdot 2^4 = 2^{3+4} = 2^7$"
        }
      ],
      "final_answer": "$2^7$"
    },
    {
      "number": 2,
      "problem": "Simplify $\\frac{5^6}{5^2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the law of exponents: $\\frac{a^m}{a^n} = a^{m-n}$",
          "calculation": "$\\frac{5^6}{5^2} = 5^{6-2} = 5^4$"
        }
      ],
      "final_answer": "$5^4$"
    },
    {
      "number": 3,
      "problem": "Simplify $(3^2)^4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the law of exponents: $(a^m)^n = a^{m\\cdot n}$",
          "calculation": "$(3^2)^4 = 3^{2\\cdot4} = 3^8$"
        }
      ],
      "final_answer": "$3^8$"
    },
    {
      "number": 4,
      "problem": "Solve $2^x = 16$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite 16 as a power of 2",
          "calculation": "$16 = 2^4$"
        },
        {
          "step": "Set exponents equal",
          "calculation": "$x = 4$"
        }
      ],
      "final_answer": "$x = 4$"
    },
    {
      "number": 5,
      "problem": "Solve $5^{2x} = 125$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite 125 as a power of 5",
          "calculation": "$125 = 5^3$"
        },
        {
          "step": "Set exponents equal",
          "calculation": "$2x = 3 \\Rightarrow x = \\frac{3}{2}$"
        }
      ],
      "final_answer": "$x = \\frac{3}{2}$"
    },
    {
      "number": 6,
      "problem": "Simplify $e^{\\ln 7}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use property $e^{\\ln a} = a$",
          "calculation": "$e^{\\ln 7} = 7$"
        }
      ],
      "final_answer": "$7$"
    },
    {
      "number": 7,
      "problem": "Solve $3^{x+1} = 27$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite 27 as $3^3$",
          "calculation": "$3^{x+1} = 3^3$"
        },
        {
          "step": "Set exponents equal",
          "calculation": "$x+1 = 3 \\Rightarrow x = 2$"
        }
      ],
      "final_answer": "$x = 2$"
    },
    {
      "number": 8,
      "problem": "Solve $10^{2x-1} = 1000$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite 1000 as $10^3$",
          "calculation": "$10^{2x-1} = 10^3$"
        },
        {
          "step": "Set exponents equal",
          "calculation": "$2x - 1 = 3 \\Rightarrow 2x = 4 \\Rightarrow x = 2$"
        }
      ],
      "final_answer": "$x = 2$"
    },
    {
      "number": 9,
      "problem": "Model: A bacteria population doubles every 3 hours. If the initial population is 100, write an exponential model for population $P(t)$ after $t$ hours.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use general formula $P(t) = P_0 \\cdot b^{t/k}$",
          "explanation": "Where $P_0 = 100$, doubling every 3 hours $\\Rightarrow b = 2$, $k = 3$"
        },
        {
          "step": "Write model",
          "calculation": "$P(t) = 100 \\cdot 2^{t/3}$"
        }
      ],
      "final_answer": "$P(t) = 100 \\cdot 2^{t/3}$"
    },
    {
