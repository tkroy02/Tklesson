        {
          "step": "Use product property",
          "explanation": "$\\log_a b + \\log_a c = \\log_a (bc)$"
        },
        {
          "step": "Combine",
          "calculation": "$\\log_3 (27 \\cdot 9) = \\log_3 243$"
