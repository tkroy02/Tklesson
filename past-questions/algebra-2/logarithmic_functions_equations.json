  "problems": [
    {
      "number": 1,
      "problem": "Simplify $\\log_2 8$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite 8 as a power of 2",
          "calculation": "$8 = 2^3$"
        },
        {
          "step": "Use property $\\log_b b^x = x$",
          "calculation": "$\\log_2 8 = \\log_2 2^3 = 3$"
        }
      ],
      "final_answer": "$3$"
    },
    {
