    {
      "number": 5,
      "problem": "Solve $\\log_4 x + \\log_4 2 = 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use product property",
          "calculation": "$\\log_4 (2x) = 3$"
        },
        {
          "step": "Rewrite in exponential form",
          "calculation": "$4^3 = 2x \\Rightarrow 64 = 2x$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x = 32$"
        }
      ],
      "final_answer": "$x = 32$"
    },
    {
      "number": 6,
      "problem": "Solve $\\log_5 (x^2) = 4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite in exponential form",
          "calculation": "$x^2 = 5^4 = 625$"
        },
        {
          "step": "Take square root",
          "calculation": "$x = \\pm 25$"
        }
      ],
      "final_answer": "$x = \\pm 25$"
    },
    {
      "number": 7,
      "problem": "Solve $\\ln (2x - 1) = 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite in exponential form using $e$",
          "calculation": "$2x - 1 = e^3$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$2x = e^3 + 1 \\Rightarrow x = \\frac{e^3 + 1}{2}$"
        }
      ],
      "final_answer": "$x = \\frac{e^3 + 1}{2}$"
    },
    {
      "number": 8,
      "problem": "Solve $\\log_2 (x - 3) + \\log_2 (x + 1) = 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Combine logs using product property",
          "calculation": "$\\log_2 ((x - 3)(x + 1)) = 3$"
        },
        {
          "step": "Rewrite in exponential form",
          "calculation": "$(x - 3)(x + 1) = 2^3 = 8$"
        },
        {
          "step": "Expand and solve quadratic",
          "calculation": "$x^2 - 2x - 3 = 8 \\Rightarrow x^2 - 2x - 11 = 0$"
        },
        {
          "step": "Use quadratic formula",
          "calculation": "$x = \\frac{2 \\pm \\sqrt{4 + 44}}{2} = 1 \\pm 2\\sqrt{3}$"
        },
        {
          "step": "Check domain restrictions",
          "explanation": "$x - 3 > 0 \\Rightarrow x > 3$, $x + 1 > 0 \\Rightarrow x > -1$"
        },
        {
          "step": "Select valid solution",
          "calculation": "$x = 1 + 2\\sqrt{3}$ (since $1 - 2\\sqrt{3} \\approx -2.46$ is invalid)"
        }
      ],
      "final_answer": "$x = 1 + 2\\sqrt{3}$"
    },
    {
      "number": 9,
      "problem": "Simplify $\\log_3 81 - \\log_3 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Simplify each log",
          "calculation": "$\\log_3 81 = 4$, $\\log_3 3 = 1$"
        },
        {
          "step": "Subtract",
          "calculation": "$4 - 1 = 3$"
        }
      ],
      "final_answer": "$3$"
    },
    {
      "number": 10,
      "problem": "Solve $2\\log x - \\log 3 = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use power property",
          "calculation": "$\\log x^2 - \\log 3 = 1$"
        },
        {
          "step": "Combine logs using quotient property",
          "calculation": "$\\log \\frac{x^2}{3} = 1$"
        },
        {
          "step": "Rewrite in exponential form",
          "calculation": "$\\frac{x^2}{3} = 10^1 = 10$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x^2 = 30 \\Rightarrow x = \\pm \\sqrt{30}$"
        },
        {
          "step": "Check domain",
          "explanation": "$x > 0$ for $\\log x$ to be defined"
        }
      ],
      "final_answer": "$x = \\sqrt{30}$"
    },
    {
      "number": 11,
      "problem": "Use the change of base formula to evaluate $\\log_5 10$ to three decimal places.",
      "image": null,
      "step_by_step": [
        {
          "step": "Apply change of base formula",
          "calculation": "$\\log_5 10 = \\frac{\\log 10}{\\log 5}$"
        },
        {
          "step": "Use common logarithms",
          "calculation": "$\\log 10 = 1$, $\\log 5 \\approx 0.6990$"
        },
        {
          "step": "Divide",
          "calculation": "$1 / 0.6990 \\approx 1.4307$"
        }
      ],
      "final_answer": "$\\log_5 10 \\approx 1.431$"
    },
    {
      "number": 12,
      "problem": "Expand $\\log_3 \\left(\\frac{9x^2}{y}\\right)$ using properties of logarithms.",
      "image": null,
      "step_by_step": [
        {
          "step": "Apply quotient property",
          "calculation": "$\\log_3 (9x^2) - \\log_3 y$"
        },
        {
          "step": "Apply product property to first term",
          "calculation": "$\\log_3 9 + \\log_3 x^2 - \\log_3 y$"
        },
        {
          "step": "Apply power property",
          "calculation": "$\\log_3 9 + 2\\log_3 x - \\log_3 y$"
        },
        {
          "step": "Simplify $\\log_3 9 = 2$",
          "calculation": "$2 + 2\\log_3 x - \\log_3 y$"
        }
      ],
      "final_answer": "$2 + 2\\log_3 x - \\log_3 y$"
    },
    {
      "number": 13,
      "problem": "Condense $3\\ln x + 2\\ln y - \\ln z$ into a single logarithm.",
      "image": null,
      "step_by_step": [
        {
          "step": "Apply power property",
          "calculation": "$\\ln x^3 + \\ln y^2 - \\ln z$"
        },
        {
          "step": "Apply product property",
          "calculation": "$\\ln (x^3 y^2) - \\ln z$"
        },
        {
          "step": "Apply quotient property",
          "calculation": "$\\ln \\left(\\frac{x^3 y^2}{z}\\right)$"
        }
      ],
      "final_answer": "$\\ln \\left(\\frac{x^3 y^2}{z}\\right)$"
    },
    {
      "number": 14,
      "problem": "Solve $3^{x} = 20$ using logarithms. Round to three decimal places.",
      "image": null,
      "step_by_step": [
        {
          "step": "Take the log of both sides",
          "calculation": "$\\log 3^{x} = \\log 20$"
        },
        {
          "step": "Apply power property",
          "calculation": "$x \\log 3 = \\log 20$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x = \\frac{\\log 20}{\\log 3}$"
        },
        {
          "step": "Approximate",
          "calculation": "$\\log 20 \\approx 1.3010$, $\\log 3 \\approx 0.4771$, $x \\approx 2.7268$"
        }
      ],
      "final_answer": "$x \\approx 2.727$"
    },
    {
      "number": 15,
      "problem": "Solve $2^{x+1} = 5^{x}$ using logarithms.",
      "image": null,
      "step_by_step": [
        {
          "step": "Take the log of both sides",
          "calculation": "$\\log 2^{x+1} = \\log 5^{x}$"
        },
        {
          "step": "Apply power property",
          "calculation": "$(x+1)\\log 2 = x \\log 5$"
        },
        {
          "step": "Distribute",
          "calculation": "$x\\log 2 + \\log 2 = x\\log 5$"
        },
        {
          "step": "Collect $x$ terms",
          "calculation": "$\\log 2 = x\\log 5 - x\\log 2 = x(\\log 5 - \\log 2)$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x = \\frac{\\log 2}{\\log 5 - \\log 2} = \\frac{\\log 2}{\\log (5/2)}$"
        }
      ],
      "final_answer": "$x = \\frac{\\log 2}{\\log (5/2)}$"
    },
    {
      "number": 16,
      "problem": "The pH of a solution is given by $\\text{pH} = -\\log[H^+]$, where $[H^+]$ is the hydrogen ion concentration. If the pH of a solution is 4.5, find $[H^+]$.",
      "image": null,
