    {
      "number": 4,
      "problem": "Solve $\\log_2 (x - 1) = 5$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite in exponential form",
          "calculation": "$2^5 = x - 1$"
        },
        {
          "step": "Simplify",
          "calculation": "$32 = x - 1 \\Rightarrow x = 33$"
        }
      ],
      "final_answer": "$x = 33$"
