    {
      "number": 3,
      "problem": "Solve $\\log_3 x = 4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Rewrite in exponential form: $b^y = x$",
          "calculation": "$3^4 = x$"
        },
        {
          "step": "Simplify",
          "calculation": "$x = 81$"
        }
      ],
      "final_answer": "$x = 81$"
