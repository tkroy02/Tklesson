        },
        {
          "step": "Rewrite in exponential form",
          "calculation": "$[H^+] = 10^{-4.5}$"
        },
        {
          "step": "Simplify",
          "calculation": "$[H^+] = 3.16 \\times 10^{-5}$"
        }
      ],
      "final_answer": "$[H^+] = 10^{-4.5} \\approx 3.16 \\times 10^{-5}$ M"
    },
    {
      "number": 17,
      "problem": "A radioactive substance has a half-life of 8 days. If the initial amount is 200 grams, how much remains after 20 days? Use the model $A(t) = A_0 \\left(\\frac{1}{2}\\right)^{t/h}$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify values",
          "calculation": "$A_0 = 200$, $h = 8$, $t = 20$"
        },
        {
          "step": "Substitute into formula",
          "calculation": "$A(20) = 200 \\left(\\frac{1}{2}\\right)^{20/8} = 200 \\left(\\frac{1}{2}\\right)^{2.5}$"
        },
        {
          "step": "Simplify",
          "calculation": "$\\left(\\frac{1}{2}\\right)^{2.5} = 2^{-2.5} = \\frac{1}{2^{2.5}} = \\frac{1}{4 \\cdot \\sqrt{2}} \\approx \\frac{1}{5.6569} \\approx 0.1768$"
        },
        {
          "step": "Multiply",
          "calculation": "$200 \\times 0.1768 \\approx 35.36$ grams"
        }
      ],
      "final_answer": "Approximately $35.4$ grams"
    },
    {
      "number": 18,
      "problem": "A cup of coffee cools according to Newton's Law of Cooling: $T(t) = T_a + (T_0 - T_a)e^{-kt}$, where $T_a = 70^\\circ$F is room temperature. If initial temperature $T_0 = 200^\\circ$F and after 5 minutes $T = 150^\\circ$F, find $k$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Substitute known values",
          "calculation": "$150 = 70 + (200 - 70)e^{-5k}$"
        },
        {
          "step": "Simplify",
          "calculation": "$150 = 70 + 130e^{-5k}$"
        },
        {
          "step": "Subtract 70",
          "calculation": "$80 = 130e^{-5k}$"
        },
        {
          "step": "Divide by 130",
          "calculation": "$\\frac{80}{130} = e^{-5k} \\Rightarrow \\frac{8}{13} = e^{-5k}$"
        },
        {
          "step": "Take natural log",
          "calculation": "$\\ln\\left(\\frac{8}{13}\\right) = -5k$"
        },
        {
          "step": "Solve for $k$",
          "calculation": "$k = -\\frac{1}{5}\\ln\\left(\\frac{8}{13}\\right) = \\frac{1}{5}\\ln\\left(\\frac{13}{8}\\right)$"
        }
      ],
      "final_answer": "$k = \\frac{1}{5}\\ln\\left(\\frac{13}{8}\\right) \\approx 0.0971$"
    },
    {
      "number": 19,
      "problem": "Compare the growth rates: For $x = 10$, calculate $f(x) = x^2$, $g(x) = 2^x$, and $h(x) = \\log_2 x$. Which is largest?",
      "image": null,
      "step_by_step": [
        {
          "step": "Calculate each value",
          "calculation": "$f(10) = 10^2 = 100$\n$g(10) = 2^{10} = 1024$\n$h(10) = \\log_2 10 \\approx 3.32$"
        },
        {
          "step": "Compare",
          "explanation": "$2^x$ (exponential) is largest, then $x^2$ (quadratic), then $\\log_2 x$ (logarithmic)"
        }
      ],
      "final_answer": "$g(10) = 1024$ is largest"
    },
    {
      "number": 20,
      "problem": "The Richter scale magnitude $M$ is given by $M = \\log\\left(\\frac{I}{I_0}\\right)$, where $I$ is the earthquake intensity and $I_0$ is a reference intensity. If an earthquake measures 6.5 on the Richter scale, how many times more intense is it than a magnitude 4.5 earthquake?",
      "image": null,
      "step_by_step": [
        {
          "step": "Set up ratio of intensities",
          "calculation": "$M_1 = \\log\\left(\\frac{I_1}{I_0}\\right)$, $M_2 = \\log\\left(\\frac{I_2}{I_0}\\right)$"
        },
        {
          "step": "Subtract equations",
          "calculation": "$M_1 - M_2 = \\log\\left(\\frac{I_1}{I_2}\\right)$"
        },
        {
          "step": "Substitute values",
          "calculation": "$6.5 - 4.5 = 2 = \\log\\left(\\frac{I_1}{I_2}\\right)$"
        },
        {
          "step": "Rewrite in exponential form",
          "calculation": "$\\frac{I_1}{I_2} = 10^2 = 100$"
        }
      ],
      "final_answer": "100 times more intense"
    }
  ]
