      "number": 16,
      "problem": "Describe the transformation of $f(x) = 2\\sqrt{x + 3} - 1$ from the parent function $\\sqrt{x}$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify each transformation",
          "calculation": "$\\sqrt{x + 3}$ shifts left 3 units\n$2\\sqrt{x + 3}$ stretches vertically by factor 2\n$-1$ shifts down 1 unit"
        }
      ],
      "final_answer": "Left 3, vertical stretch by 2, down 1"
    },
    {
      "number": 17,
      "problem": "Verify that $f(x) = \\sqrt{x - 2}$ and $g(x) = x^2 + 2$, $x \\ge 0$, are inverses using composition.",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute $f(g(x))$",
          "calculation": "$f(g(x)) = \\sqrt{(x^2 + 2) - 2} = \\sqrt{x^2} = x$ (since $x \\ge 0$)"
        },
        {
          "step": "Compute $g(f(x))$",
          "calculation": "$g(f(x)) = (\\sqrt{x - 2})^2 + 2 = x - 2 + 2 = x$"
        },
        {
          "step": "Conclude",
          "explanation": "$f(g(x)) = x$ and $g(f(x)) = x$, so they are inverses"
        }
      ],
      "final_answer": "Yes, they are inverses"
    },
    {
      "number": 18,
      "problem": "Simplify: $\\frac{\\sqrt{6}}{\\sqrt{3} + \\sqrt{2}}$ by rationalizing the denominator.",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply by conjugate of denominator",
          "calculation": "$\\frac{\\sqrt{6}}{\\sqrt{3} + \\sqrt{2}} \\cdot \\frac{\\sqrt{3} - \\sqrt{2}}{\\sqrt{3} - \\sqrt{2}}$"
        },
        {
          "step": "Multiply numerator",
          "calculation": "$\\sqrt{6}(\\sqrt{3} - \\sqrt{2}) = \\sqrt{18} - \\sqrt{12} = 3\\sqrt{2} - 2\\sqrt{3}$"
        },
        {
          "step": "Multiply denominator",
          "calculation": "$(\\sqrt{3})^2 - (\\sqrt{2})^2 = 3 - 2 = 1$"
        }
      ],
      "final_answer": "$3\\sqrt{2} - 2\\sqrt{3}$"
    },
    {
      "number": 19,
      "problem": "Find the inverse of $f(x) = \\frac{2x}{x - 3}$ and state the domain of the inverse.",
      "image": null,
      "step_by_step": [
        {
          "step": "Replace $f(x)$ with $y$",
          "calculation": "$y = \\frac{2x}{x - 3}$"
        },
        {
          "step": "Swap $x$ and $y$",
          "calculation": "$x = \\frac{2y}{y - 3}$"
        },
        {
          "step": "Solve for $y$",
          "calculation": "$x(y - 3) = 2y \\Rightarrow xy - 3x = 2y \\Rightarrow xy - 2y = 3x \\Rightarrow y(x - 2) = 3x \\Rightarrow y = \\frac{3x}{x - 2}$"
        },
        {
          "step": "Determine domain of inverse",
          "explanation": "Denominator cannot be zero: $x \\neq 2$"
        }
      ],
      "final_answer": "$f^{-1}(x) = \\frac{3x}{x - 2}$, domain: $x \\neq 2$"
    },
    {
      "number": 20,
      "problem": "The period of a pendulum is given by $T = 2\\pi \\sqrt{\\frac{L}{g}}$, where $L$ is length and $g = 32$ ft/s². If the period is 2 seconds, find the length of the pendulum.",
      "image": null,
      "step_by_step": [
        {
          "step": "Substitute known values",
          "calculation": "$2 = 2\\pi \\sqrt{\\frac{L}{32}}$"
        },
        {
          "step": "Divide both sides by $2\\pi$",
          "calculation": "$\\frac{1}{\\pi} = \\sqrt{\\frac{L}{32}}$"
        },
        {
          "step": "Square both sides",
          "calculation": "$\\frac{1}{\\pi^2} = \\frac{L}{32}$"
        },
        {
          "step": "Solve for $L$",
          "calculation": "$L = \\frac{32}{\\pi^2} \\approx \\frac{32}{9.87} \\approx 3.24$ feet"
        }
      ],
      "final_answer": "$L = \\frac{32}{\\pi^2}$ feet (approximately $3.24$ feet)"
    }
  ]
