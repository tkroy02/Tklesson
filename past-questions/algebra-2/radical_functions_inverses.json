{
  "course": "Algebra 2",
  "topic": "Radical Functions & Inverses",
  "problems": [
    {
      "number": 1,
      "problem": "Simplify $\\sqrt{50}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor 50 into perfect square times remaining factor",
          "calculation": "$50 = 25 \\cdot 2$"
        },
        {
          "step": "Take square root",
          "calculation": "$\\sqrt{50} = \\sqrt{25} \\cdot \\sqrt{2} = 5\\sqrt{2}$"
        }
      ],
      "final_answer": "$5\\sqrt{2}$"
    },
    {
      "number": 2,
      "problem": "Simplify $\\sqrt[3]{16}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor 16 as perfect cube times remaining factor",
          "calculation": "$16 = 8 \\cdot 2$"
        },
        {
          "step": "Take cube root",
          "calculation": "$\\sqrt[3]{16} = \\sqrt[3]{8} \\cdot \\sqrt[3]{2} = 2\\sqrt[3]{2}$"
        }
      ],
      "final_answer": "$2\\sqrt[3]{2}$"
    },
    {
      "number": 3,
      "problem": "Rationalize the denominator: $\\frac{3}{\\sqrt{5}}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply numerator and denominator by $\\sqrt{5}$",
          "calculation": "$\\frac{3}{\\sqrt{5}} \\cdot \\frac{\\sqrt{5}}{\\sqrt{5}} = \\frac{3\\sqrt{5}}{5}$"
        }
      ],
      "final_answer": "$\\frac{3\\sqrt{5}}{5}$"
    },
    {
      "number": 4,
      "problem": "Simplify $\\sqrt{72} - \\sqrt{8}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Simplify each radical",
          "calculation": "$\\sqrt{72} = \\sqrt{36 \\cdot 2} = 6\\sqrt{2}$, $\\sqrt{8} = \\sqrt{4 \\cdot 2} = 2\\sqrt{2}$"
        },
        {
          "step": "Subtract",
          "calculation": "$6\\sqrt{2} - 2\\sqrt{2} = 4\\sqrt{2}$"
        }
      ],
      "final_answer": "$4\\sqrt{2}$"
    },
    {
      "number": 5,
      "problem": "Find the inverse of $f(x) = x^2 + 3$, $x \\ge 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Replace $f(x)$ with $y$",
          "calculation": "$y = x^2 + 3$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x^2 = y - 3 \\Rightarrow x = \\sqrt{y - 3}$"
        },
        {
          "step": "Swap $x$ and $y$ to get inverse",
          "calculation": "$f^{-1}(x) = \\sqrt{x - 3}$"
        }
      ],
      "final_answer": "$f^{-1}(x) = \\sqrt{x - 3}$"
    },
    {
      "number": 6,
      "problem": "Solve $\\sqrt{x + 2} = 5$",
      "image": null,
      "step_by_step": [
        {
          "step": "Square both sides",
          "calculation": "$x + 2 = 25$"
        },
        {
          "step": "Subtract 2",
          "calculation": "$x = 23$"
        }
      ],
      "final_answer": "$x = 23$"
    },
    {
      "number": 7,
      "problem": "Find the inverse of $f(x) = \\sqrt{x - 4}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Replace $f(x)$ with $y$",
          "calculation": "$y = \\sqrt{x - 4}$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$y^2 = x - 4 \\Rightarrow x = y^2 + 4$"
        },
        {
          "step": "Swap $x$ and $y$",
          "calculation": "$f^{-1}(x) = x^2 + 4$"
        }
      ],
      "final_answer": "$f^{-1}(x) = x^2 + 4$"
    },
    {
      "number": 8,
      "problem": "Simplify $\\sqrt{50} + \\sqrt{18}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Simplify each radical",
          "calculation": "$\\sqrt{50} = 5\\sqrt{2}$, $\\sqrt{18} = 3\\sqrt{2}$"
        },
        {
          "step": "Combine like radicals",
          "calculation": "$5\\sqrt{2} + 3\\sqrt{2} = 8\\sqrt{2}$"
        }
      ],
      "final_answer": "$8\\sqrt{2}$"
    },
    {
      "number": 9,
      "problem": "Solve $\\sqrt{2x - 1} - 3 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add 3 to both sides",
          "calculation": "$\\sqrt{2x - 1} = 3$"
        },
        {
          "step": "Square both sides",
          "calculation": "$2x - 1 = 9$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$2x = 10 \\Rightarrow x = 5$"
        }
      ],
      "final_answer": "$x = 5$"
    },
    {
      "number": 10,
      "problem": "Find the inverse of $f(x) = 3\\sqrt{x + 1}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Replace $f(x)$ with $y$",
          "calculation": "$y = 3\\sqrt{x + 1}$"
        },
        {
          "step": "Divide both sides by 3",
          "calculation": "$\\frac{y}{3} = \\sqrt{x + 1}$"
        },
        {
          "step": "Square both sides",
          "calculation": "$\\frac{y^2}{9} = x + 1$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$x = \\frac{y^2}{9} - 1$"
        },
        {
          "step": "Swap $x$ and $y$",
          "calculation": "$f^{-1}(x) = \\frac{x^2}{9} - 1$"
        }
      ],
      "final_answer": "$f^{-1}(x) = \\frac{x^2}{9} - 1$"
    },
    {
      "number": 11,
      "problem": "Rewrite $\\sqrt[3]{x^2}$ using rational exponents",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $\\sqrt[n]{a^m} = a^{m/n}$",
          "calculation": "$\\sqrt[3]{x^2} = x^{2/3}$"
        }
      ],
      "final_answer": "$x^{2/3}$"
    },
    {
      "number": 12,
      "problem": "Simplify $\\sqrt{12x^3}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor into perfect squares",
          "calculation": "$12x^3 = 4 \\cdot 3 \\cdot x^2 \\cdot x$"
        },
        {
          "step": "Take square roots",
          "calculation": "$\\sqrt{4} \\cdot \\sqrt{x^2} \\cdot \\sqrt{3x} = 2x\\sqrt{3x}$"
        }
      ],
      "final_answer": "$2x\\sqrt{3x}$"
    },
    {
      "number": 13,
      "problem": "Multiply: $\\sqrt{6} \\cdot \\sqrt{10}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $\\sqrt{a} \\cdot \\sqrt{b} = \\sqrt{ab}$",
          "calculation": "$\\sqrt{6} \\cdot \\sqrt{10} = \\sqrt{60}$"
        },
        {
          "step": "Simplify",
          "calculation": "$\\sqrt{60} = \\sqrt{4 \\cdot 15} = 2\\sqrt{15}$"
        }
      ],
      "final_answer": "$2\\sqrt{15}$"
    },
    {
      "number": 14,
      "problem": "Solve $\\sqrt{x + 5} = x - 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Square both sides",
          "calculation": "$x + 5 = (x - 1)^2 = x^2 - 2x + 1$"
        },
        {
          "step": "Set equation to zero",
          "calculation": "$0 = x^2 - 3x - 4$"
        },
        {
          "step": "Factor",
          "calculation": "$0 = (x - 4)(x + 1)$"
        },
        {
          "step": "Check for extraneous solutions",
          "calculation": "$x = 4$: $\\sqrt{9} = 3$, $4 - 1 = 3$ ✓\n$x = -1$: $\\sqrt{4} = 2$, $-1 - 1 = -2$ ✗"
        }
      ],
      "final_answer": "$x = 4$"
    },
    {
      "number": 15,
      "problem": "Graph $f(x) = \\sqrt{x - 2}$ and state the domain and range.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify parent function",
          "explanation": "Parent function $y = \\sqrt{x}$ shifted right 2 units"
        },
        {
          "step": "Determine domain",
          "explanation": "Radicand must be non-negative: $x - 2 \\ge 0 \\Rightarrow x \\ge 2$"
        },
        {
          "step": "Determine range",
          "explanation": "Square root outputs non-negative values"
        }
      ],
      "final_answer": "Domain: $x \\ge 2$, Range: $y \\ge 0$"
    },
