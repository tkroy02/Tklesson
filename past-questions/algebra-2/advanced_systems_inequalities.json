      "number": 1,
      "problem": "Solve the system: $\\begin{cases} 2x + y = 7 \\\\ x - y = 1 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve second equation for $x$",
          "calculation": "$x = y + 1$"
        },
        {
          "step": "Substitute into first equation",
          "calculation": "$2(y + 1) + y = 7 \\Rightarrow 2y + 2 + y = 7 \\Rightarrow 3y + 2 = 7$"
        },
        {
          "step": "Solve for $y$",
          "calculation": "$3y = 5 \\Rightarrow y = 5/3$"
        },
        {
          "step": "Find $x$",
          "calculation": "$x = 5/3 + 1 = 8/3$"
        }
      ],
      "final_answer": "$(x, y) = (8/3, 5/3)$"
    },
