      "number": 11,
      "problem": "Solve the system in three variables: $\\begin{cases} x + y + z = 6 \\\\ 2x - y + z = 3 \\\\ x + 2y - z = 1 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add first and third equations to eliminate $z$",
          "calculation": "$(x + y + z) + (x + 2y - z) = 6 + 1 \\Rightarrow 2x + 3y = 7$"
        },
        {
          "step": "Add first and second equations to eliminate $y$",
          "calculation": "$(x + y + z) + (2x - y + z) = 6 + 3 \\Rightarrow 3x + 2z = 9$"
        },
        {
          "step": "From first equation $z = 6 - x - y$",
          "calculation": "Substitute into $3x + 2(6 - x - y) = 9 \\Rightarrow 3x + 12 - 2x - 2y = 9 \\Rightarrow x - 2y = -3$"
        },
        {
          "step": "Solve the system $2x + 3y = 7$ and $x - 2y = -3$",
          "calculation": "From second: $x = 2y - 3$; substitute: $2(2y - 3) + 3y = 7 \\Rightarrow 4y - 6 + 3y = 7 \\Rightarrow 7y = 13 \\Rightarrow y = 13/7$"
        },
        {
          "step": "Find $x$ and $z$",
          "calculation": "$x = 2(13/7) - 3 = 26/7 - 21/7 = 5/7$\n$z = 6 - 5/7 - 13/7 = 6 - 18/7 = 42/7 - 18/7 = 24/7$"
        }
      ],
      "final_answer": "$(x, y, z) = (5/7, 13/7, 24/7)$"
