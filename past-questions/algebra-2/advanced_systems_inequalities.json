      "problem": "Solve the nonlinear system: $\\begin{cases} x^2 + y^2 = 25 \\\\ x - y = 1 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve linear equation for $x$",
          "calculation": "$x = y + 1$"
        },
        {
          "step": "Substitute into circle equation",
          "calculation": "$(y + 1)^2 + y^2 = 25 \\Rightarrow y^2 + 2y + 1 + y^2 = 25 \\Rightarrow 2y^2 + 2y - 24 = 0$"
