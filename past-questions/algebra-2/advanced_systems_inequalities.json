        {
          "step": "Divide by 2 and factor",
          "calculation": "$y^2 + y - 12 = 0 \\Rightarrow (y + 4)(y - 3) = 0 \\Rightarrow y = -4$ or $y = 3$"
        },
        {
          "step": "Find corresponding $x$ values",
          "calculation": "$y = -4 \\Rightarrow x = -3$; $y = 3 \\Rightarrow x = 4$"
        }
      ],
      "final_answer": "$(x, y) = (-3, -4)$ and $(4, 3)$"
