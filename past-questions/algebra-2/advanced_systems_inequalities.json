      "number": 2,
      "problem": "Solve the system: $\\begin{cases} 3x - 2y = 6 \\\\ 2x + y = 4 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve second equation for $y$",
          "calculation": "$y = 4 - 2x$"
        },
        {
          "step": "Substitute into first equation",
          "calculation": "$3x - 2(4 - 2x) = 6 \\Rightarrow 3x - 8 + 4x = 6$"
        },
        {
          "step": "Combine terms and solve for $x$",
          "calculation": "$7x - 8 = 6 \\Rightarrow 7x = 14 \\Rightarrow x = 2$"
        },
        {
          "step": "Find $y$",
          "calculation": "$y = 4 - 2(2) = 0$"
        }
      ],
      "final_answer": "$(x, y) = (2, 0)$"
