    {
      "number": 5,
      "problem": "How many ways can 3 students be arranged in a line from a group of 5?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use permutation formula $P(n,r) = \\frac{n!}{(n-r)!}$",
          "calculation": "$P(5,3) = \\frac{5!}{2!} = \\frac{120}{2} = 60$"
        }
      ],
      "final_answer": "$60$"
    },
    {
      "number": 6,
      "problem": "How many 3-letter combinations can be made from letters A, B, C, D, E if order does not matter?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use combination formula $C(n,r) = \\frac{n!}{r!(n-r)!}$",
          "calculation": "$C(5,3) = \\frac{5!}{3!2!} = \\frac{120}{6 \\cdot 2} = 10$"
        }
      ],
      "final_answer": "$10$"
