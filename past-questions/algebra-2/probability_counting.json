    {
      "number": 18,
      "problem": "A fair coin is flipped 5 times. Find the probability of getting exactly 3 heads using binomial probability.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use binomial probability formula $P(k) = C(n,k) p^k (1-p)^{n-k}$",
          "calculation": "$n = 5$, $k = 3$, $p = \\frac{1}{2}$"
        },
        {
          "step": "Calculate",
          "calculation": "$P(3) = C(5,3) \\left(\\frac{1}{2}\\right)^3 \\left(\\frac{1}{2}\\right)^2 = 10 \\cdot \\frac{1}{8} \\cdot \\frac{1}{4} = 10 \\cdot \\frac{1}{32} = \\frac{10}{32} = \\frac{5}{16}$"
        }
      ],
      "final_answer": "$\\frac{5}{16}$"
    },
    {
      "number": 19,
      "problem": "A game costs $5 to play. You roll a die. If you roll a 6, you win $20. Otherwise, you win nothing. Find the expected value of the game.",
      "image": null,
      "step_by_step": [
        {
          "step": "List outcomes and probabilities",
          "calculation": "Roll 6: net gain = $20 - 5 = 15$, $P = \\frac{1}{6}$\nNot 6: net gain = $-5$, $P = \\frac{5}{6}$"
        },
        {
          "step": "Calculate expected value",
          "calculation": "$E = 15 \\cdot \\frac{1}{6} + (-5) \\cdot \\frac{5}{6} = \\frac{15}{6} - \\frac{25}{6} = -\\frac{10}{6} = -\\frac{5}{3} \\approx -1.67$"
        }
      ],
      "final_answer": "$-\\$1.67$ (expected loss of about $1.67 per game)"
    },
    {
      "number": 20,
      "problem": "In a survey, 60% of people like coffee, 40% like tea, and 20% like both. Given a person likes coffee, what is the probability they also like tea?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use conditional probability formula $P(T|C) = \\frac{P(T \\cap C)}{P(C)}$",
          "calculation": "$P(C) = 0.60$, $P(T \\cap C) = 0.20$"
        },
        {
          "step": "Compute",
          "calculation": "$P(T|C) = \\frac{0.20}{0.60} = \\frac{1}{3} \\approx 0.333$"
        }
      ],
      "final_answer": "$\\frac{1}{3}$"
    }
