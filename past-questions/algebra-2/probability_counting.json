    {
      "number": 12,
      "problem": "A card is drawn from a standard deck. Find the probability it is a king or a heart.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Addition Rule: $P(A \\cup B) = P(A) + P(B) - P(A \\cap B)$",
          "calculation": "$P(\\text{king}) = \\frac{4}{52}$, $P(\\text{heart}) = \\frac{13}{52}$, $P(\\text{king of hearts}) = \\frac{1}{52}$"
        },
        {
          "step": "Compute",
          "calculation": "$P = \\frac{4}{52} + \\frac{13}{52} - \\frac{1}{52} = \\frac{16}{52} = \\frac{4}{13}$"
        }
      ],
      "final_answer": "$\\frac{4}{13}$"
    },
    {
      "number": 13,
      "problem": "A bag contains 5 red and 3 blue marbles. Two marbles are drawn without replacement. Find the probability both are red.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Multiplication Rule for dependent events",
          "calculation": "$P(\\text{first red}) = \\frac{5}{8}$"
        },
        {
          "step": "Probability second red given first red",
          "calculation": "$P(\\text{second red} | \\text{first red}) = \\frac{4}{7}$"
        },
        {
          "step": "Multiply",
          "calculation": "$P = \\frac{5}{8} \\cdot \\frac{4}{7} = \\frac{20}{56} = \\frac{5}{14}$"
        }
      ],
      "final_answer": "$\\frac{5}{14}$"
    },
    {
      "number": 14,
      "problem": "Two dice are rolled. Find the probability the sum is 7.",
      "image": null,
      "step_by_step": [
        {
          "step": "Number of favorable outcomes",
          "calculation": "Pairs summing to 7: (1,6), (2,5), (3,4), (4,3), (5,2), (6,1) → 6 outcomes"
        },
        {
          "step": "Total possible outcomes",
          "calculation": "$6 \\times 6 = 36$"
        },
        {
          "step": "Calculate probability",
          "calculation": "$P = \\frac{6}{36} = \\frac{1}{6}$"
        }
      ],
      "final_answer": "$\\frac{1}{6}$"
    },
    {
      "number": 15,
      "problem": "In a class of 20 students, 12 play soccer and 8 play basketball. If 5 play both, what is the probability a randomly selected student plays at least one sport?",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Inclusion-Exclusion",
          "calculation": "$P(\\text{soccer} \\cup \\text{basketball}) = P(\\text{soccer}) + P(\\text{basketball}) - P(\\text{both})$"
        },
        {
          "step": "Substitute",
          "calculation": "$P = \\frac{12}{20} + \\frac{8}{20} - \\frac{5}{20} = \\frac{15}{20} = \\frac{3}{4}$"
        }
      ],
      "final_answer": "$\\frac{3}{4}$"
    },
