{
  "course": "Algebra 2",
  "topic": "Conic Sections & Parametric Equations",
  "problems": [
    {
      "number": 1,
      "problem": "Identify the conic: $x^2 + y^2 = 25$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compare with standard forms",
          "calculation": "Equation matches $x^2 + y^2 = r^2$"
        },
        {
          "step": "Conclude type",
          "calculation": "This is a circle with radius $r = 5$"
        }
      ],
      "final_answer": "Circle, radius $5$"
    },
    {
      "number": 2,
      "problem": "Identify the conic: $\\frac{x^2}{9} - \\frac{y^2}{16} = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compare with standard forms",
          "calculation": "Equation matches $\\frac{x^2}{a^2} - \\frac{y^2}{b^2} = 1$"
        },
        {
          "step": "Conclude type",
          "calculation": "This is a hyperbola"
        }
      ],
      "final_answer": "Hyperbola"
    },
    {
      "number": 3,
      "problem": "Identify the conic: $y^2 = 8x$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compare with standard forms",
          "calculation": "Equation matches $y^2 = 4px$"
        },
        {
          "step": "Compute $p$",
          "calculation": "$4p = 8 \\Rightarrow p = 2$"
        }
      ],
      "final_answer": "Parabola, $p = 2$"
    },
    {
      "number": 4,
      "problem": "Identify the conic: $\\frac{x^2}{16} + \\frac{y^2}{9} = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compare with standard forms",
          "calculation": "Equation matches $\\frac{x^2}{a^2} + \\frac{y^2}{b^2} = 1$"
        },
        {
          "step": "Conclude type",
          "calculation": "This is an ellipse"
        }
      ],
      "final_answer": "Ellipse"
    },
    {
      "number": 5,
      "problem": "Convert parametric equations $x = 2t + 1, y = 3t - 2$ to rectangular form",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve for $t$ in terms of $x$",
          "calculation": "$x = 2t + 1 \\Rightarrow t = (x-1)/2$"
        },
        {
          "step": "Substitute into $y$",
          "calculation": "$y = 3((x-1)/2) - 2 = \\frac{3x - 3}{2} - 2 = \\frac{3x - 3 - 4}{2} = \\frac{3x - 7}{2}$"
        }
      ],
      "final_answer": "$y = \\frac{3x - 7}{2}$"
    },
    {
      "number": 6,
      "problem": "Find $x$ and $y$ for $t = 2$ in $x = t^2, y = t + 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Substitute $t = 2$",
          "calculation": "$x = 2^2 = 4, y = 2 + 1 = 3$"
        }
      ],
      "final_answer": "$(x, y) = (4, 3)$"
    },
    {
      "number": 7,
      "problem": "Eliminate the parameter in $x = 3\\cos t, y = 4\\sin t$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Pythagorean identity",
          "calculation": "$\\frac{x^2}{9} + \\frac{y^2}{16} = \\cos^2 t + \\sin^2 t = 1$"
        }
      ],
      "final_answer": "$\\frac{x^2}{9} + \\frac{y^2}{16} = 1$"
    },
    {
      "number": 8,
      "problem": "Convert parametric equations $x = 1 + t, y = 2 - 3t$ to rectangular form",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve for $t$ in terms of $x$",
          "calculation": "$x = 1 + t \\Rightarrow t = x - 1$"
        },
        {
          "step": "Substitute into $y$",
          "calculation": "$y = 2 - 3(x - 1) = 2 - 3x + 3 = 5 - 3x$"
        }
      ],
      "final_answer": "$y = 5 - 3x$"
    },
    {
      "number": 9,
      "problem": "Find the vertex of parabola $y^2 = 12x$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compare with standard form $y^2 = 4px$",
          "calculation": "$4p = 12 \\Rightarrow p = 3$"
        },
        {
          "step": "Vertex of $y^2 = 4px$ is at origin",
          "calculation": "Vertex: $(0, 0)$"
        }
      ],
      "final_answer": "Vertex: $(0, 0)$"
    },
    {
      "number": 10,
      "problem": "Find the foci of ellipse $\\frac{x^2}{25} + \\frac{y^2}{9} = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute $c = \\sqrt{a^2 - b^2}$",
          "calculation": "$a^2 = 25, b^2 = 9 \\Rightarrow c = \\sqrt{25 - 9} = \\sqrt{16} = 4$"
        },
        {
          "step": "Foci along x-axis at $(\\pm c, 0)$",
          "calculation": "Foci: $(\\pm4, 0)$"
        }
      ],
      "final_answer": "Foci: $(4, 0)$ and $(-4, 0)$"
    },
    {
      "number": 11,
      "problem": "Write the equation of a parabola with vertex at the origin and focus at $(0, 4)$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify orientation",
          "explanation": "Focus on y-axis means parabola opens up or down. Vertex at origin, focus at $(0,4)$ means opens up."
        },
        {
          "step": "Use standard form $x^2 = 4py$",
          "calculation": "$p = 4 \\Rightarrow x^2 = 16y$"
        }
      ],
      "final_answer": "$x^2 = 16y$"
    },
    {
      "number": 12,
      "problem": "Find the center, vertices, and foci of ellipse $\\frac{(x-2)^2}{16} + \\frac{(y+1)^2}{9} = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify center",
          "calculation": "Center = $(2, -1)$"
        },
        {
          "step": "Find $a$ and $b$",
          "calculation": "$a^2 = 16 \\Rightarrow a = 4$, $b^2 = 9 \\Rightarrow b = 3$"
        },
        {
          "step": "Find vertices (along major axis, horizontal)",
          "calculation": "Vertices: $(2 \\pm 4, -1) = (6, -1)$ and $(-2, -1)$"
        },
        {
          "step": "Find $c$",
          "calculation": "$c = \\sqrt{a^2 - b^2} = \\sqrt{16 - 9} = \\sqrt{7}$"
        },
        {
          "step": "Find foci",
          "calculation": "Foci: $(2 \\pm \\sqrt{7}, -1)$"
        }
      ],
      "final_answer": "Center: $(2, -1)$, Vertices: $(6, -1)$ and $(-2, -1)$, Foci: $(2 \\pm \\sqrt{7}, -1)$"
    },
    {
      "number": 13,
      "problem": "Find the center, vertices, foci, and asymptotes of hyperbola $\\frac{x^2}{9} - \\frac{y^2}{16} = 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify center",
          "calculation": "Center = $(0, 0)$"
        },
        {
          "step": "Find $a$ and $b$",
          "calculation": "$a^2 = 9 \\Rightarrow a = 3$, $b^2 = 16 \\Rightarrow b = 4$"
        },
        {
          "step": "Find vertices",
          "calculation": "Vertices: $(\\pm 3, 0)$"
        },
        {
          "step": "Find $c$",
          "calculation": "$c = \\sqrt{a^2 + b^2} = \\sqrt{9 + 16} = 5$"
        },
        {
          "step": "Find foci",
          "calculation": "Foci: $(\\pm 5, 0)$"
        },
        {
          "step": "Find asymptotes",
          "calculation": "Asymptotes: $y = \\pm \\frac{b}{a}x = \\pm \\frac{4}{3}x$"
        }
      ],
      "final_answer": "Center: $(0,0)$, Vertices: $(\\pm3,0)$, Foci: $(\\pm5,0)$, Asymptotes: $y = \\pm \\frac{4}{3}x$"
    },
    {
      "number": 14,
      "problem": "Write the general form equation of a circle with center $(3, -2)$ and radius $4$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use standard form $(x - h)^2 + (y - k)^2 = r^2$",
          "calculation": "$(x - 3)^2 + (y + 2)^2 = 16$"
        },
        {
          "step": "Expand to general form",
          "calculation": "$x^2 - 6x + 9 + y^2 + 4y + 4 = 16 \\Rightarrow x^2 + y^2 - 6x + 4y - 3 = 0$"
        }
      ],
      "final_answer": "$x^2 + y^2 - 6x + 4y - 3 = 0$"
    },
    {
      "number": 15,
      "problem": "Identify the conic from general form: $x^2 + 4y^2 - 6x + 8y - 3 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Complete the square for $x$ and $y$",
          "calculation": "$(x^2 - 6x) + 4(y^2 + 2y) = 3$"
        },
        {
          "step": "Complete squares",
          "calculation": "$(x - 3)^2 - 9 + 4[(y + 1)^2 - 1] = 3$"
        },
        {
          "step": "Simplify",
          "calculation": "$(x - 3)^2 + 4(y + 1)^2 - 13 = 3 \\Rightarrow (x - 3)^2 + 4(y + 1)^2 = 16$"
        },
        {
          "step": "Divide by 16",
          "calculation": "$\\frac{(x - 3)^2}{16} + \\frac{(y + 1)^2}{4} = 1$"
        },
        {
          "step": "Identify conic",
          "calculation": "Ellipse with center $(3, -1)$"
        }
      ],
      "final_answer": "Ellipse"
    },
    {
      "number": 16,
      "problem": "A projectile is launched with parametric equations $x = 20t$, $y = -16t^2 + 40t + 5$. Find when it hits the ground and the horizontal distance traveled.",
      "image": null,
      "step_by_step": [
        {
          "step": "Set $y = 0$ to find time of impact",
          "calculation": "$-16t^2 + 40t + 5 = 0$"
        },
        {
          "step": "Use quadratic formula",
          "calculation": "$t = \\frac{-40 \\pm \\sqrt{1600 + 320}}{-32} = \\frac{-40 \\pm \\sqrt{1920}}{-32} = \\frac{-40 \\pm 8\\sqrt{30}}{-32}$"
        },
        {
          "step": "Take positive solution",
          "calculation": "$t = \\frac{-40 - 8\\sqrt{30}}{-32} \\approx \\frac{-40 - 43.82}{-32} \\approx 2.62$ seconds"
        },
        {
          "step": "Find horizontal distance",
          "calculation": "$x = 20(2.62) \\approx 52.4$ units"
        }
      ],
      "final_answer": "$t \\approx 2.62$ seconds, $x \\approx 52.4$ units"
    },
    {
      "number": 17,
      "problem": "Convert the rectangular equation $x^2 + y^2 = 9$ to polar form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use polar conversions $x = r\\cos\\theta$, $y = r\\sin\\theta$",
          "calculation": "$r^2\\cos^2\\theta + r^2\\sin^2\\theta = 9$"
        },
        {
          "step": "Simplify",
          "calculation": "$r^2(\\cos^2\\theta + \\sin^2\\theta) = r^2 = 9 \\Rightarrow r = 3$"
        }
      ],
      "final_answer": "$r = 3$"
    },
    {
      "number": 18,
      "problem": "Convert the polar equation $r = 4\\sin\\theta$ to rectangular form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply both sides by $r$",
          "calculation": "$r^2 = 4r\\sin\\theta$"
        },
        {
          "step": "Substitute $r^2 = x^2 + y^2$ and $r\\sin\\theta = y$",
          "calculation": "$x^2 + y^2 = 4y$"
        },
        {
          "step": "Complete the square",
          "calculation": "$x^2 + y^2 - 4y = 0 \\Rightarrow x^2 + (y - 2)^2 = 4$"
        }
      ],
      "final_answer": "$x^2 + (y - 2)^2 = 4$ (circle centered at $(0,2)$ with radius $2$)"
    },
    {
      "number": 19,
      "problem": "Classify the conic: $x^2 + 2xy + y^2 - 4x + 6y - 3 = 0$ (introduction to rotated conics)",
      "image": null,
      "step_by_step": [
        {
          "step": "Look at $B^2 - 4AC$ discriminant",
          "calculation": "$A = 1$, $B = 2$, $C = 1$"
        },
        {
          "step": "Compute discriminant",
          "calculation": "$B^2 - 4AC = 4 - 4 = 0$"
        },
        {
          "step": "Interpret",
          "explanation": "When $B^2 - 4AC = 0$, the conic is a parabola (or degenerate)"
        }
      ],
      "final_answer": "Parabola (rotated)"
    },
    {
      "number": 20,
      "problem": "A particle moves along a path given by $x = t^2$, $y = 2t$ for $t \\ge 0$. Eliminate the parameter and identify the curve.",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve for $t$ in terms of $y$",
          "calculation": "$y = 2t \\Rightarrow t = y/2$"
        },
        {
          "step": "Substitute into $x$",
          "calculation": "$x = (y/2)^2 = y^2/4$"
        },
        {
          "step": "Rewrite",
          "calculation": "$y^2 = 4x$"
        },
        {
          "step": "Identify conic",
          "explanation": "This is a parabola opening to the right"
        }
      ],
      "final_answer": "$y^2 = 4x$ (parabola)"
    }
  ]
}
