      "problem": "Simplify: $\\frac{3x^2y}{6xy^2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Simplify coefficients and variables",
          "calculation": "$\\frac{3}{6} \\cdot \\frac{x^2}{x} \\cdot \\frac{y}{y^2} = \\frac{1}{2} \\cdot x \\cdot \\frac{1}{y} = \\frac{x}{2y}$"
        }
      ],
      "final_answer": "$\\frac{x}{2y}$"
    },
    {
