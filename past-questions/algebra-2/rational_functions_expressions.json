      "problem": "Solve the rational inequality: $\\frac{x - 2}{x + 1} > 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Find critical points",
          "calculation": "$x - 2 = 0 \\Rightarrow x = 2$, $x + 1 = 0 \\Rightarrow x = -1$"
        },
        {
          "step": "Create sign chart",
          "explanation": "Test intervals: $(-\\infty, -1)$, $(-1, 2)$, $(2, \\infty)$"
        },
        {
          "step": "Test each interval",
          "calculation": "Test $x = -2$: $\\frac{-4}{-1} = 4 > 0$ (true)\nTest $x = 0$: $\\frac{-2}{1} = -2 > 0$ (false)\nTest $x = 3$: $\\frac{1}{4} > 0$ (true)"
        }
      ],
      "final_answer": "$x < -1$ or $x > 2$"
