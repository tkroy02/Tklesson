    {
      "number": 16,
      "problem": "A worker can complete a task in 6 hours, and a second worker can complete the same task in 4 hours. How long will it take them working together?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define rates",
          "explanation": "Worker 1 rate = $\\frac{1}{6}$ task per hour, Worker 2 rate = $\\frac{1}{4}$ task per hour"
        },
        {
          "step": "Combined rate equation",
          "calculation": "$\\frac{1}{6} + \\frac{1}{4} = \\frac{1}{t}$"
        },
        {
          "step": "Find common denominator",
          "calculation": "$\\frac{2}{12} + \\frac{3}{12} = \\frac{5}{12} = \\frac{1}{t}$"
        },
        {
          "step": "Solve for $t$",
          "calculation": "$t = \\frac{12}{5} = 2.4$ hours"
        }
      ],
      "final_answer": "$2.4$ hours"
