  "problems": [
    {
      "number": 1,
      "problem": "Simplify: $\\frac{x^2 - 9}{x - 3}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor numerator as difference of squares",
          "calculation": "$x^2 - 9 = (x - 3)(x + 3)$"
        },
        {
          "step": "Cancel common factor",
          "calculation": "$\\frac{(x - 3)(x + 3)}{x - 3} = x + 3$"
        }
      ],
      "final_answer": "$x + 3$"
    },
    {
      "number": 2,
      "problem": "Simplify: $\\frac{x^2 - 4x + 4}{x - 2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor numerator as perfect square",
          "calculation": "$x^2 - 4x + 4 = (x - 2)^2$"
        },
        {
          "step": "Cancel common factor",
          "calculation": "$\\frac{(x - 2)^2}{x - 2} = x - 2$"
        }
      ],
      "final_answer": "$x - 2$"
    },
    {
