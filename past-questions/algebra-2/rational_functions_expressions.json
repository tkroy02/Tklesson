      "problem": "Solve: $\\frac{2}{x - 1} = \\frac{3}{x + 2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Cross multiply",
          "calculation": "$2(x + 2) = 3(x - 1)$"
        },
        {
          "step": "Expand and solve",
          "calculation": "$2x + 4 = 3x - 3 \\Rightarrow 4 + 3 = 3x - 2x \\Rightarrow x = 7$"
        },
        {
          "step": "Check for extraneous solutions",
          "explanation": "Neither denominator is zero at $x = 7$"
        }
      ],
      "final_answer": "$x = 7$"
