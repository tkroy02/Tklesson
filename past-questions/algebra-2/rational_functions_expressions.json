      "problem": "Multiply: $\\frac{x - 1}{x + 2} \\cdot \\frac{x + 2}{x - 3}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Cancel common factor",
          "calculation": "$\\frac{x - 1}{\\cancel{x + 2}} \\cdot \\frac{\\cancel{x + 2}}{x - 3} = \\frac{x - 1}{x - 3}$"
        }
      ],
      "final_answer": "$\\frac{x - 1}{x - 3}$"
    },
    {
      "number": 7,
      "problem": "Divide: $\\frac{x^2 - 1}{x + 1} \\div \\frac{x - 1}{2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor numerator",
          "calculation": "$x^2 - 1 = (x - 1)(x + 1)$"
        },
        {
          "step": "Rewrite division as multiplication",
          "calculation": "$\\frac{(x - 1)(x + 1)}{x + 1} \\cdot \\frac{2}{x - 1}$"
        },
        {
          "step": "Cancel common factors",
          "calculation": "$2$"
        }
      ],
      "final_answer": "$2$"
    },
    {
