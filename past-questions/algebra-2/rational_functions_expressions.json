      "problem": "Simplify: $\\frac{x^2 + 5x + 6}{x + 2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor numerator",
          "calculation": "$x^2 + 5x + 6 = (x + 2)(x + 3)$"
        },
        {
          "step": "Cancel common factor",
          "calculation": "$\\frac{(x + 2)(x + 3)}{x + 2} = x + 3$"
        }
      ],
      "final_answer": "$x + 3$"
    },
    {
