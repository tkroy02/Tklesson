    {
      "number": 20,
      "problem": "A car travels 120 miles at a speed of $x$ mph. If the speed is increased by 10 mph, the trip takes 30 minutes less. Find $x$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Write time equations",
          "calculation": "Time at speed $x$: $t_1 = \\frac{120}{x}$\nTime at speed $x + 10$: $t_2 = \\frac{120}{x + 10}$"
        },
        {
          "step": "Set up equation for 30 minutes less",
          "calculation": "$\\frac{120}{x} - \\frac{120}{x + 10} = \\frac{1}{2}$"
        },
        {
          "step": "Multiply by $2x(x + 10)$",
          "calculation": "$240(x + 10) - 240x = x(x + 10)$"
        },
        {
          "step": "Simplify",
          "calculation": "$2400 = x^2 + 10x$"
        },
        {
          "step": "Solve quadratic",
          "calculation": "$x^2 + 10x - 2400 = 0$\n$(x + 50)(x - 48) = 0$\n$x = 48$ (positive speed)"
        }
      ],
      "final_answer": "$x = 48$ mph"
    }
