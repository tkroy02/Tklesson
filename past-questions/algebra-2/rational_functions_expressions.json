        {
          "step": "Find common denominator $x^2$",
          "calculation": "$\\frac{3x}{x^2} + \\frac{2}{x^2} = \\frac{3x + 2}{x^2}$"
        }
      ],
      "final_answer": "$\\frac{3x + 2}{x^2}$"
    },
    {
