      "problem": "Solve the inequality: $-2x + 5 \\leq 11$",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract 5 from both sides",
          "calculation": "$-2x \\leq 6$"
        },
        {
          "step": "Divide both sides by $-2$ and reverse inequality",
          "calculation": "$x \\geq -3$"
        }
      ],
      "final_answer": "$x \\geq -3$"
