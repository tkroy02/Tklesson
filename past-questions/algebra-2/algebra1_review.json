      "problem": "Solve the system by graphing: $\\begin{cases} y = x + 2 \\\\ y = -2x + 5 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Graph both lines",
          "explanation": "First line: slope 1, y-intercept 2. Second line: slope -2, y-intercept 5."
        },
        {
          "step": "Find intersection point",
          "calculation": "Set $x + 2 = -2x + 5 \\Rightarrow 3x = 3 \\Rightarrow x = 1$, then $y = 1 + 2 = 3$"
