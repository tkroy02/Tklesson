      "number": 13,
      "problem": "Graph the inequality: $y > 2x - 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Graph boundary line $y = 2x - 3$",
          "explanation": "Use dashed line because inequality is strict ($>$)"
        },
        {
          "step": "Test a point",
          "calculation": "Test $(0,0)$: $0 > -3$ is true, so shade above the line"
        }
      ],
      "final_answer": "Dashed line through $(0,-3)$ with slope 2; shade above the line"
    },
    {
      "number": 14,
      "problem": "Multiply: $(3x - 2)(2x + 5)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use distributive property (FOIL)",
          "calculation": "$3x \\cdot 2x = 6x^2$, $3x \\cdot 5 = 15x$, $-2 \\cdot 2x = -4x$, $-2 \\cdot 5 = -10$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$6x^2 + 15x - 4x - 10 = 6x^2 + 11x - 10$"
        }
      ],
      "final_answer": "$6x^2 + 11x - 10$"
    },
    {
      "number": 15,
      "problem": "Factor completely: $4x^2 - 25$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize as difference of squares",
          "calculation": "$4x^2 - 25 = (2x)^2 - 5^2$"
        },
        {
          "step": "Factor",
          "calculation": "$(2x - 5)(2x + 5)$"
        }
      ],
      "final_answer": "$(2x - 5)(2x + 5)$"
    },
    {
      "number": 16,
      "problem": "Find the vertex of $f(x) = x^2 - 6x + 5$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $x_v = -b/(2a)$",
          "calculation": "$x_v = -(-6)/(2 \\cdot 1) = 6/2 = 3$"
        },
        {
          "step": "Find $y$-coordinate",
          "calculation": "$y_v = (3)^2 - 6(3) + 5 = 9 - 18 + 5 = -4$"
        }
      ],
      "final_answer": "Vertex: $(3, -4)$"
    },
    {
      "number": 17,
      "problem": "Solve by factoring: $x^2 - 7x + 12 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor the quadratic",
          "calculation": "$x^2 - 7x + 12 = (x - 3)(x - 4)$"
        },
        {
          "step": "Set each factor equal to zero",
          "calculation": "$x - 3 = 0 \\Rightarrow x = 3$, $x - 4 = 0 \\Rightarrow x = 4$"
        }
      ],
      "final_answer": "$x = 3$ or $x = 4$"
    },
    {
      "number": 18,
      "problem": "Simplify: $\\frac{3x^2}{6x}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Cancel common factors",
          "calculation": "$\\frac{3x^2}{6x} = \\frac{3 \\cdot x \\cdot x}{3 \\cdot 2 \\cdot x} = \\frac{x}{2}$"
        }
      ],
      "final_answer": "$\\frac{x}{2}$"
    },
