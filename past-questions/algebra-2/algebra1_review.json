      "step_by_step": [
        {
          "step": "Identify restriction",
          "explanation": "Denominator cannot be zero: $x - 5 \\neq 0$"
        },
        {
          "step": "Solve for excluded value",
          "calculation": "$x \\neq 5$"
        }
      ],
      "final_answer": "All real numbers except $x = 5$"
