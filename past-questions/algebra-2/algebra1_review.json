  "problems": [
    {
      "number": 1,
      "problem": "Solve for $x$: $3x - 7 = 11$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add 7 to both sides",
          "calculation": "$3x = 11 + 7 = 18$"
        },
        {
          "step": "Divide both sides by 3",
          "calculation": "$x = 18 / 3 = 6$"
        }
      ],
      "final_answer": "$x = 6$"
    },
    {
      "number": 2,
      "problem": "Factor completely: $x^2 + 5x + 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Find two numbers that multiply to 6 and add to 5",
          "calculation": "$2$ and $3$"
        },
        {
          "step": "Write as factors",
          "calculation": "$(x + 2)(x + 3)$"
        }
      ],
      "final_answer": "$(x + 2)(x + 3)$"
    },
    {
      "number": 3,
      "problem": "Simplify $\\sqrt{32}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor 32 into perfect square times remaining factor",
          "calculation": "$32 = 16 \\cdot 2$"
        },
        {
          "step": "Take square root",
          "calculation": "$\\sqrt{32} = \\sqrt{16} \\cdot \\sqrt{2} = 4\\sqrt{2}$"
        }
      ],
      "final_answer": "$4\\sqrt{2}$"
    },
    {
      "number": 4,
      "problem": "Solve for $x$: $\\frac{x}{4} + 5 = 9$",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract 5 from both sides",
          "calculation": "$x/4 = 9 - 5 = 4$"
        },
        {
          "step": "Multiply both sides by 4",
          "calculation": "$x = 4 \\cdot 4 = 16$"
        }
      ],
      "final_answer": "$x = 16$"
    },
    {
      "number": 5,
      "problem": "Write the equation of a line with slope 2 and passing through $(1,3)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use point-slope form $y - y_1 = m(x - x_1)$",
          "calculation": "$y - 3 = 2(x - 1)$"
        },
        {
          "step": "Simplify to slope-intercept form",
          "calculation": "$y - 3 = 2x - 2 \\Rightarrow y = 2x + 1$"
        }
      ],
      "final_answer": "$y = 2x + 1$"
    },
    {
      "number": 6,
      "problem": "Find the mean of the data set $4, 7, 9, 10, 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add all numbers",
          "calculation": "$4 + 7 + 9 + 10 + 6 = 36$"
        },
        {
          "step": "Divide by number of values",
          "calculation": "$36 / 5 = 7.2$"
        }
      ],
      "final_answer": "Mean = $7.2$"
    },
    {
      "number": 7,
      "problem": "Solve the system: $\\begin{cases} x + y = 10 \\\\ x - y = 4 \\end{cases}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add the two equations",
          "calculation": "$x + y + x - y = 10 + 4 \\Rightarrow 2x = 14 \\Rightarrow x = 7$"
        },
        {
          "step": "Substitute $x$ into first equation to find $y$",
          "calculation": "$7 + y = 10 \\Rightarrow y = 3$"
        }
      ],
      "final_answer": "$x = 7, y = 3$"
    },
    {
      "number": 8,
      "problem": "Simplify: $2(3x - 4) - (x + 5)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute",
          "calculation": "$2(3x - 4) = 6x - 8$, $-(x + 5) = -x - 5$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$6x - x = 5x$, $-8 - 5 = -13$"
        }
      ],
      "final_answer": "$5x - 13$"
    },
    {
      "number": 9,
      "problem": "Factor completely: $x^2 - 9$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize as difference of squares",
          "calculation": "$x^2 - 9 = x^2 - 3^2$"
        },
        {
          "step": "Factor",
          "calculation": "$(x - 3)(x + 3)$"
        }
      ],
      "final_answer": "$(x - 3)(x + 3)$"
    },
    {
      "number": 10,
      "problem": "Simplify $\\frac{\\sqrt{18}}{\\sqrt{2}}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use property $\\sqrt{a}/\\sqrt{b} = \\sqrt{a/b}$",
          "calculation": "$\\frac{\\sqrt{18}}{\\sqrt{2}} = \\sqrt{18 / 2} = \\sqrt{9}$"
        },
        {
          "step": "Simplify square root",
          "calculation": "$\\sqrt{9} = 3$"
        }
      ],
      "final_answer": "$3$"
    },
    {
