      "problem": "A population starts at 1000 and grows by 8% each year. Write the exponential growth model.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify initial value",
          "calculation": "$P_0 = 1000$"
        },
        {
          "step": "Identify growth factor",
          "explanation": "8% growth means multiply by $1.08$ each year",
