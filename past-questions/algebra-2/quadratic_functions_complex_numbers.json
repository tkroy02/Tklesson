{
  "course": "Algebra 2",
  "topic": "Quadratic Functions & Complex Numbers",
  "problems": [
    {
      "number": 1,
      "problem": "Solve $x^2 + 4 = 0$ over the complex numbers",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract 4 from both sides",
          "calculation": "$x^2 = -4$"
        },
        {
          "step": "Take the square root of both sides",
          "calculation": "$x = \\pm\\sqrt{-4} = \\pm 2i$"
        }
      ],
      "final_answer": "$x = \\pm 2i$"
    },
    {
      "number": 2,
      "problem": "Solve $x^2 - 2x + 5 = 0$ using the quadratic formula",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify $a = 1, b = -2, c = 5$",
          "calculation": "Quadratic formula: $x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}$"
        },
        {
          "step": "Compute discriminant",
          "calculation": "$b^2 - 4ac = (-2)^2 - 4(1)(5) = 4 - 20 = -16$"
        },
        {
          "step": "Compute solutions",
          "calculation": "$x = \\frac{2 \\pm \\sqrt{-16}}{2} = \\frac{2 \\pm 4i}{2} = 1 \\pm 2i$"
        }
      ],
      "final_answer": "$x = 1 \\pm 2i$"
    },
    {
      "number": 3,
      "problem": "Find the vertex of $f(x) = x^2 + 6x + 10$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $x_v = -b/(2a)$",
          "calculation": "$x_v = -6 / (2 \\cdot 1) = -3$"
        },
        {
          "step": "Compute $y$ at vertex",
          "calculation": "$y_v = (-3)^2 + 6(-3) + 10 = 9 - 18 + 10 = 1$"
        }
      ],
      "final_answer": "Vertex = $(-3, 1)$"
    },
    {
      "number": 4,
      "problem": "Factor $x^2 + 2x + 5$ over the complex numbers",
      "image": null,
      "step_by_step": [
        {
          "step": "Use quadratic formula to find roots",
          "calculation": "$x = \\frac{-2 \\pm \\sqrt{2^2 - 4(1)(5)}}{2} = \\frac{-2 \\pm \\sqrt{-16}}{2} = -1 \\pm 2i$"
        },
        {
          "step": "Write as factors",
          "calculation": "$(x + 1 - 2i)(x + 1 + 2i)$"
        }
      ],
      "final_answer": "$(x + 1 - 2i)(x + 1 + 2i)$"
    },
    {
      "number": 5,
      "problem": "Solve $x^2 + x + 1 = 0$ over the complex numbers",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute discriminant",
          "calculation": "$b^2 - 4ac = 1 - 4(1)(1) = -3$"
        },
        {
          "step": "Use quadratic formula",
          "calculation": "$x = \\frac{-1 \\pm \\sqrt{-3}}{2} = \\frac{-1 \\pm i\\sqrt{3}}{2}$"
        }
      ],
      "final_answer": "$x = \\frac{-1 \\pm i\\sqrt{3}}{2}$"
    },
    {
      "number": 6,
      "problem": "Determine the axis of symmetry for $f(x) = 2x^2 - 8x + 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use formula $x = -b/(2a)$",
          "calculation": "$x = -(-8)/(2 \\cdot 2) = 8/4 = 2$"
        }
      ],
      "final_answer": "Axis of symmetry: $x = 2$"
    },
    {
      "number": 7,
      "problem": "Express $x^2 - 4x + 13$ in vertex form",
      "image": null,
      "step_by_step": [
        {
          "step": "Complete the square",
          "calculation": "$x^2 - 4x + 4 + 13 - 4$"
        },
        {
          "step": "Simplify",
          "calculation": "$(x - 2)^2 + 9$"
        }
      ],
      "final_answer": "$f(x) = (x - 2)^2 + 9$"
    },
    {
      "number": 8,
      "problem": "Find the roots of $x^2 + 1 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract 1",
          "calculation": "$x^2 = -1$"
        },
        {
          "step": "Take square root",
          "calculation": "$x = \\pm i$"
        }
      ],
      "final_answer": "$x = \\pm i$"
    },
    {
      "number": 9,
      "problem": "Solve $x^2 - 6x + 10 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute discriminant",
          "calculation": "$(-6)^2 - 4(1)(10) = 36 - 40 = -4$"
        },
        {
          "step": "Apply quadratic formula",
          "calculation": "$x = \\frac{6 \\pm \\sqrt{-4}}{2} = \\frac{6 \\pm 2i}{2} = 3 \\pm i$"
        }
      ],
      "final_answer": "$x = 3 \\pm i$"
    },
    {
      "number": 10,
      "problem": "Factor $x^2 + 6x + 13$ over complex numbers",
      "image": null,
      "step_by_step": [
        {
          "step": "Find roots using quadratic formula",
          "calculation": "$x = \\frac{-6 \\pm \\sqrt{36 - 52}}{2} = \\frac{-6 \\pm \\sqrt{-16}}{2} = -3 \\pm 2i$"
        },
        {
          "step": "Write as factors",
          "calculation": "$(x + 3 - 2i)(x + 3 + 2i)$"
        }
      ],
      "final_answer": "$(x + 3 - 2i)(x + 3 + 2i)$"
    },
    {
      "number": 11,
      "problem": "Graph $f(x) = -(x - 2)^2 + 5$ and identify the vertex and direction of opening.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify vertex from vertex form",
          "explanation": "$f(x) = a(x - h)^2 + k$ has vertex $(h, k)$",
          "calculation": "Vertex = $(2, 5)$"
        },
        {
          "step": "Determine direction",
          "explanation": "$a = -1 < 0$, so parabola opens downward"
        }
      ],
      "final_answer": "Vertex $(2, 5)$, opens downward"
    },
    {
      "number": 12,
      "problem": "Compute $(3 + 2i) + (4 - 5i)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Add real parts and imaginary parts separately",
          "calculation": "$(3 + 4) + (2i - 5i) = 7 - 3i$"
        }
      ],
      "final_answer": "$7 - 3i$"
    },
    {
      "number": 13,
      "problem": "Multiply $(2 - 3i)(4 + i)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use FOIL method",
          "calculation": "$2 \\cdot 4 = 8$, $2 \\cdot i = 2i$, $-3i \\cdot 4 = -12i$, $-3i \\cdot i = -3i^2$"
        },
        {
          "step": "Simplify $i^2 = -1$",
          "calculation": "$-3(-1) = 3$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$8 + 3 + (2i - 12i) = 11 - 10i$"
        }
      ],
      "final_answer": "$11 - 10i$"
    },
    {
      "number": 14,
      "problem": "Divide $\\frac{5 + 3i}{1 - i}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply numerator and denominator by the conjugate of denominator",
          "calculation": "$\\frac{5 + 3i}{1 - i} \\cdot \\frac{1 + i}{1 + i}$"
        },
        {
          "step": "Multiply numerator",
          "calculation": "$(5 + 3i)(1 + i) = 5 + 5i + 3i + 3i^2 = 5 + 8i - 3 = 2 + 8i$"
        },
        {
          "step": "Multiply denominator",
          "calculation": "$(1 - i)(1 + i) = 1 - i^2 = 1 + 1 = 2$"
        },
        {
          "step": "Simplify",
          "calculation": "$\\frac{2 + 8i}{2} = 1 + 4i$"
        }
      ],
      "final_answer": "$1 + 4i$"
    },
    {
      "number": 15,
      "problem": "Use the discriminant to determine the nature of the roots of $x^2 + 4x + 5 = 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Compute discriminant",
          "calculation": "$b^2 - 4ac = 16 - 4(1)(5) = 16 - 20 = -4$"
        },
        {
          "step": "Interpret",
          "explanation": "$\\Delta < 0$, so two complex conjugate roots"
        }
      ],
      "final_answer": "Two complex conjugate roots"
    },
    {
      "number": 16,
      "problem": "A ball is thrown upward from a height of 5 feet with initial velocity 64 ft/s. Its height is $h(t) = -16t^2 + 64t + 5$. Find the maximum height.",
      "image": null,
      "step_by_step": [
        {
          "step": "Vertex gives maximum since $a < 0$",
          "calculation": "$t_v = -b/(2a) = -64/(2 \\cdot -16) = -64/-32 = 2$ seconds"
        },
        {
          "step": "Find height at $t = 2$",
          "calculation": "$h(2) = -16(4) + 64(2) + 5 = -64 + 128 + 5 = 69$ feet"
        }
      ],
      "final_answer": "Maximum height = $69$ feet"
    },
    {
      "number": 17,
      "problem": "Solve the quadratic inequality $x^2 - 5x + 6 > 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor the quadratic",
          "calculation": "$(x - 2)(x - 3) > 0$"
        },
        {
          "step": "Find critical points",
          "calculation": "$x = 2$ and $x = 3$"
        },
        {
          "step": "Test intervals",
          "explanation": "Test $x = 0$: $(0-2)(0-3) = 6 > 0$ (true)\nTest $x = 2.5$: $(0.5)(-0.5) = -0.25 > 0$ (false)\nTest $x = 4$: $(2)(1) = 2 > 0$ (true)"
        }
      ],
      "final_answer": "$x < 2$ or $x > 3$"
    },
    {
      "number": 18,
      "problem": "Find the complex conjugate of $3 - 4i$ and compute the product $z \\cdot \\bar{z}$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Complex conjugate changes sign of imaginary part",
          "calculation": "$\\bar{z} = 3 + 4i$"
        },
        {
          "step": "Multiply",
          "calculation": "$(3 - 4i)(3 + 4i) = 9 + 12i - 12i - 16i^2 = 9 + 16 = 25$"
        }
      ],
      "final_answer": "Conjugate: $3 + 4i$, Product: $25$"
    },
    {
      "number": 19,
      "problem": "Write $f(x) = 2x^2 + 12x + 5$ in vertex form by completing the square.",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor out $a$ from first two terms",
          "calculation": "$f(x) = 2(x^2 + 6x) + 5$"
        },
        {
          "step": "Complete the square inside parentheses",
          "calculation": "$x^2 + 6x + 9 = (x + 3)^2$"
        },
        {
          "step": "Adjust for adding $9$ inside",
          "calculation": "$f(x) = 2(x^2 + 6x + 9) + 5 - 18 = 2(x + 3)^2 - 13$"
        }
      ],
      "final_answer": "$f(x) = 2(x + 3)^2 - 13$"
    },
    {
      "number": 20,
      "problem": "A rectangular garden is to be fenced on three sides (the fourth side is a barn). If 100 feet of fencing is available, find the dimensions that maximize the area.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let $x$ = width (perpendicular to barn), $y$ = length (parallel to barn)"
        },
        {
          "step": "Write fencing equation",
          "calculation": "$2x + y = 100 \\Rightarrow y = 100 - 2x$"
        },
        {
          "step": "Write area function",
          "calculation": "$A(x) = x(100 - 2x) = -2x^2 + 100x$"
        },
        {
          "step": "Find vertex (maximum)",
          "calculation": "$x_v = -b/(2a) = -100/(2 \\cdot -2) = -100/-4 = 25$"
        },
        {
          "step": "Find $y$",
          "calculation": "$y = 100 - 2(25) = 50$"
        }
      ],
      "final_answer": "Dimensions: width = $25$ ft, length = $50$ ft"
    }
  ]
}
