{
  "course": "Algebra 2",
  "topic": "Polynomial Functions",
  "problems": [
    {
      "number": 1,
      "problem": "Add: $(2x^3 + 3x^2 - x) + (x^3 - 2x^2 + 4x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Combine like terms",
          "calculation": "$2x^3 + x^3 = 3x^3$, $3x^2 - 2x^2 = x^2$, $-x + 4x = 3x$"
        }
      ],
      "final_answer": "$3x^3 + x^2 + 3x$"
    },
    {
      "number": 2,
      "problem": "Subtract: $(5x^4 - 3x^2 + 2) - (2x^4 + x^2 - 5)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute negative and combine like terms",
          "calculation": "$5x^4 - 2x^4 = 3x^4$, $-3x^2 - x^2 = -4x^2$, $2 - (-5) = 7$"
        }
      ],
      "final_answer": "$3x^4 - 4x^2 + 7$"
    },
    {
      "number": 3,
      "problem": "Multiply: $(x + 3)(x^2 - x + 2)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $x$",
          "calculation": "$x(x^2 - x + 2) = x^3 - x^2 + 2x$"
        },
        {
          "step": "Distribute $3$",
          "calculation": "$3(x^2 - x + 2) = 3x^2 - 3x + 6$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^3 - x^2 + 2x + 3x^2 - 3x + 6 = x^3 + 2x^2 - x + 6$"
        }
      ],
      "final_answer": "$x^3 + 2x^2 - x + 6$"
    },
    {
      "number": 4,
      "problem": "Factor $x^3 - 6x^2 + 11x - 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use Rational Root Theorem to test $x=1$",
          "calculation": "$1 - 6 + 11 - 6 = 0 \\Rightarrow x - 1$ is a factor"
        },
        {
          "step": "Perform synthetic division to factor further",
          "calculation": "$x^3 - 6x^2 + 11x - 6 = (x - 1)(x^2 - 5x + 6) = (x - 1)(x - 2)(x - 3)$"
        }
      ],
      "final_answer": "$(x - 1)(x - 2)(x - 3)$"
    },
    {
      "number": 5,
      "problem": "Evaluate $f(x) = 2x^3 - x^2 + 4$ at $x = 2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Substitute $x = 2$",
          "calculation": "$f(2) = 2(2)^3 - (2)^2 + 4 = 16 - 4 + 4$"
        },
        {
          "step": "Simplify",
          "calculation": "$16 - 4 + 4 = 16$"
        }
      ],
      "final_answer": "$16$"
    },
    {
      "number": 6,
      "problem": "Divide: $(2x^3 + 3x^2 - x) \\div x$",
      "image": null,
      "step_by_step": [
        {
          "step": "Divide each term by $x$",
          "calculation": "$2x^3 / x = 2x^2$, $3x^2 / x = 3x$, $-x / x = -1$"
        }
      ],
      "final_answer": "$2x^2 + 3x - 1$"
    },
    {
      "number": 7,
      "problem": "Determine the degree and leading coefficient of $4x^5 - 3x^3 + x - 7$",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify highest power of $x$",
          "calculation": "Degree = 5"
        },
        {
          "step": "Identify coefficient of highest power",
          "calculation": "Leading coefficient = 4"
        }
      ],
      "final_answer": "Degree = $5$, Leading coefficient = $4$"
    },
    {
      "number": 8,
      "problem": "Find all zeros of $x^2 - 5x + 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor quadratic",
          "calculation": "$x^2 - 5x + 6 = (x - 2)(x - 3)$"
        },
        {
          "step": "Set each factor equal to zero",
          "calculation": "$x - 2 = 0 \\Rightarrow x = 2$, $x - 3 = 0 \\Rightarrow x = 3$"
        }
      ],
      "final_answer": "$x = 2, 3$"
    },
    {
      "number": 9,
      "problem": "Simplify: $\\frac{x^2 - 4}{x - 2}$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor numerator as difference of squares",
          "calculation": "$x^2 - 4 = (x - 2)(x + 2)$"
        },
        {
          "step": "Cancel common factor",
          "calculation": "$\\frac{(x - 2)(x + 2)}{x - 2} = x + 2$"
        }
      ],
      "final_answer": "$x + 2$"
    },
    {
      "number": 10,
      "problem": "Multiply: $(x - 1)(x^2 + x + 1)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $x$",
          "calculation": "$x(x^2 + x + 1) = x^3 + x^2 + x$"
        },
        {
          "step": "Distribute $-1$",
          "calculation": "$-1(x^2 + x + 1) = -x^2 - x - 1$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^3 + x^2 - x^2 + x - x - 1 = x^3 - 1$"
        }
      ],
      "final_answer": "$x^3 - 1$"
    },
    {
      "number": 11,
      "problem": "Describe the end behavior of $f(x) = -2x^4 + 3x^2 - 5$",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify degree and leading coefficient",
          "calculation": "Degree = 4 (even), Leading coefficient = -2 (negative)"
        },
        {
          "step": "Apply end behavior rules",
          "explanation": "Even degree, negative leading coefficient → both ends point down"
        }
      ],
      "final_answer": "As $x \\to \\infty$, $f(x) \\to -\\infty$; as $x \\to -\\infty$, $f(x) \\to -\\infty$"
    },
    {
      "number": 12,
      "problem": "Use synthetic division to divide $x^3 - 4x^2 + 5x - 2$ by $x - 2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Set up synthetic division with $c = 2$",
          "calculation": "Coefficients: 1, -4, 5, -2"
        },
        {
          "step": "Bring down leading coefficient",
          "calculation": "1"
        },
        {
          "step": "Multiply and add",
          "calculation": "$1 \\cdot 2 = 2$, $-4 + 2 = -2$; $-2 \\cdot 2 = -4$, $5 + (-4) = 1$; $1 \\cdot 2 = 2$, $-2 + 2 = 0$"
        }
      ],
      "final_answer": "Quotient: $x^2 - 2x + 1$, Remainder: $0$"
    },
    {
      "number": 13,
      "problem": "Use the Factor Theorem to determine if $x - 3$ is a factor of $x^3 - 5x^2 + 2x + 12$",
      "image": null,
      "step_by_step": [
        {
          "step": "Evaluate $f(3)$",
          "calculation": "$f(3) = 27 - 45 + 6 + 12 = 0$"
        },
        {
          "step": "Apply Factor Theorem",
          "explanation": "Since $f(3) = 0$, $x - 3$ is a factor"
        }
      ],
      "final_answer": "Yes, $x - 3$ is a factor"
    },
    {
      "number": 14,
      "problem": "Find all rational roots of $2x^3 - 5x^2 - 4x + 12 = 0$ using the Rational Root Theorem",
      "image": null,
      "step_by_step": [
        {
          "step": "List factors of constant term and leading coefficient",
          "calculation": "Factors of 12: $\\pm 1, \\pm 2, \\pm 3, \\pm 4, \\pm 6, \\pm 12$\nFactors of 2: $\\pm 1, \\pm 2$"
        },
        {
          "step": "List all possible rational roots",
          "calculation": "$\\pm 1, \\pm 2, \\pm 3, \\pm 4, \\pm 6, \\pm 12, \\pm \\frac{1}{2}, \\pm \\frac{3}{2}$"
        },
        {
          "step": "Test $x = 2$",
          "calculation": "$2(8) - 5(4) - 4(2) + 12 = 16 - 20 - 8 + 12 = 0$"
        }
      ],
      "final_answer": "$x = 2$ is a rational root"
    },
    {
      "number": 15,
      "problem": "Write a polynomial function of degree 3 with zeros $x = 2$, $x = -1$, and $x = 4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use factored form with given zeros",
          "calculation": "$f(x) = a(x - 2)(x + 1)(x - 4)$"
        },
        {
          "step": "Choose $a = 1$ for simplest form",
          "calculation": "$f(x) = (x - 2)(x + 1)(x - 4)$"
        },
        {
          "step": "Expand",
          "calculation": "$(x - 2)(x + 1) = x^2 - x - 2$\n$(x^2 - x - 2)(x - 4) = x^3 - 4x^2 - x^2 + 4x - 2x + 8 = x^3 - 5x^2 + 2x + 8$"
        }
      ],
      "final_answer": "$f(x) = x^3 - 5x^2 + 2x + 8$"
    },
    {
      "number": 16,
      "problem": "Find the zeros of $f(x) = (x - 1)^2(x + 2)$ and state their multiplicities",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify each factor and its exponent",
          "calculation": "$(x - 1)^2$ gives zero $x = 1$ with multiplicity 2\n$(x + 2)$ gives zero $x = -2$ with multiplicity 1"
        }
      ],
      "final_answer": "$x = 1$ (multiplicity 2), $x = -2$ (multiplicity 1)"
    },
    {
      "number": 17,
      "problem": "Solve $x^3 - 2x^2 - 5x + 6 > 0$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor the polynomial",
          "calculation": "$x^3 - 2x^2 - 5x + 6 = (x - 1)(x + 2)(x - 3)$"
        },
        {
          "step": "Find critical points",
          "calculation": "$x = -2, 1, 3$"
        },
        {
          "step": "Test intervals",
          "explanation": "Test $x = -3$: $(-4)(-1)(-6) = -24 < 0$\nTest $x = 0$: $(-1)(2)(-3) = 6 > 0$\nTest $x = 2$: $(1)(4)(-1) = -4 < 0$\nTest $x = 4$: $(3)(6)(1) = 18 > 0$"
        }
      ],
      "final_answer": "$-2 < x < 1$ or $x > 3$"
    },
    {
      "number": 18,
      "problem": "Apply Descartes' Rule of Signs to determine the possible number of positive and negative real zeros of $f(x) = x^4 - 3x^3 + 2x^2 - 4x + 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Count sign changes for $f(x)$",
          "calculation": "$+ \\to -$ (change), $- \\to +$ (change), $+ \\to -$ (change), $- \\to +$ (change) → 4 sign changes"
        },
        {
          "step": "Possible positive real zeros",
          "calculation": "4, 2, or 0"
        },
        {
          "step": "Count sign changes for $f(-x)$",
          "calculation": "$f(-x) = x^4 + 3x^3 + 2x^2 + 4x + 1$ → 0 sign changes"
        }
      ],
      "final_answer": "Positive real zeros: 4, 2, or 0; Negative real zeros: 0"
    },
    {
      "number": 19,
      "problem": "Find all complex zeros of $x^3 - x^2 + 4x - 4$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor by grouping",
          "calculation": "$x^2(x - 1) + 4(x - 1) = (x - 1)(x^2 + 4)$"
        },
        {
          "step": "Set each factor equal to zero",
          "calculation": "$x - 1 = 0 \\Rightarrow x = 1$\n$x^2 + 4 = 0 \\Rightarrow x^2 = -4 \\Rightarrow x = \\pm 2i$"
        }
      ],
      "final_answer": "$x = 1, x = 2i, x = -2i$"
    },
    {
      "number": 20,
      "problem": "Write a polynomial function of degree 3 with real coefficients given zeros $2$ and $1 - 3i$",
      "image": null,
      "step_by_step": [
        {
          "step": "Complex zeros come in conjugate pairs",
          "explanation": "If $1 - 3i$ is a zero, then $1 + 3i$ is also a zero"
        },
        {
          "step": "Write factored form",
          "calculation": "$f(x) = a(x - 2)(x - (1 - 3i))(x - (1 + 3i))$"
        },
        {
          "step": "Multiply the complex factors",
          "calculation": "$(x - (1 - 3i))(x - (1 + 3i)) = (x - 1 + 3i)(x - 1 - 3i) = (x - 1)^2 - (3i)^2 = (x - 1)^2 + 9 = x^2 - 2x + 10$"
        },
        {
          "step": "Multiply by $(x - 2)$ and choose $a = 1$",
          "calculation": "$f(x) = (x - 2)(x^2 - 2x + 10) = x^3 - 2x^2 + 10x - 2x^2 + 4x - 20 = x^3 - 4x^2 + 14x - 20$"
        }
      ],
      "final_answer": "$f(x) = x^3 - 4x^2 + 14x - 20$"
    }
  ]
}
