      "image": null,
      "step_by_step": [
        {
          "step": "Multiply the coefficient of $x^2$ and the constant: $2 \\cdot 3 = 6$",
          "explanation": "Find two numbers that multiply to 6 and add to 7"
        },
        {
          "step": "Split the middle term",
          "calculation": "$2x^2 + 6x + x + 3$"
        },
        {
          "step": "Factor by grouping",
          "calculation": "$(2x^2 + 6x) + (x + 3) = 2x(x + 3) + 1(x + 3)$"
        },
        {
          "step": "Factor out the common binomial",
          "calculation": "$(2x + 1)(x + 3)$"
        }
      ],
      "final_answer": "$(2x + 1)(x + 3)$"
