      "problem": "Simplify: $6^5 \\div 6^2$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the quotient rule of exponents",
          "explanation": "$a^m \\div a^n = a^{m-n}$"
        },
        {
          "step": "Subtract exponents",
          "calculation": "$6^5 \\div 6^2 = 6^{5-2} = 6^3$"
        }
      ],
      "final_answer": "$6^3$"
    },
