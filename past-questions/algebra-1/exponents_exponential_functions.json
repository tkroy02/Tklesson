  "problems": [
    {
      "number": 1,
      "problem": "Simplify the expression: $3^4 \\times 3^2$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the product rule of exponents",
          "explanation": "When multiplying powers with the same base, add the exponents: $a^m \\times a^n = a^{m+n}$."
        },
        {
          "step": "Add exponents",
          "calculation": "$3^4 \\times 3^2 = 3^{4+2} = 3^6$"
        }
      ],
      "final_answer": "$3^6$"
    },
    {
      "number": 2,
      "problem": "Simplify: $(5^3)^2$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use the power of a power rule",
          "explanation": "$(a^m)^n = a^{m\\cdot n}$"
        },
        {
          "step": "Multiply exponents",
          "calculation": "$(5^3)^2 = 5^{3\\cdot 2} = 5^6$"
        }
      ],
      "final_answer": "$5^6$"
    },
    {
      "number": 3,
      "problem": "Write $\\frac{1}{8}$ using a negative exponent.",
      "image": null,
      "step_by_step": [
        {
          "step": "Express 8 as a power of 2",
          "calculation": "$8 = 2^3$"
        },
        {
          "step": "Use negative exponent rule",
          "explanation": "$1/a^n = a^{-n}$"
        },
        {
          "step": "Write the expression",
          "calculation": "$\\frac{1}{8} = 1/2^3 = 2^{-3}$"
        }
      ],
      "final_answer": "$2^{-3}$"
    },
    {
      "number": 4,
      "problem": "Write $0.00032$ in scientific notation.",
      "image": null,
      "step_by_step": [
        {
          "step": "Move decimal to create a number between 1 and 10",
          "calculation": "$0.00032 \\rightarrow 3.2$"
        },
        {
          "step": "Count decimal places moved",
          "calculation": "Decimal moved 4 places to the right → exponent = $-4$"
        },
        {
          "step": "Write in scientific notation",
          "calculation": "$0.00032 = 3.2 \\times 10^{-4}$"
        }
      ],
      "final_answer": "$3.2 \\times 10^{-4}$"
    },
    {
      "number": 5,
      "problem": "Simplify: $10^{-3}$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use negative exponent rule",
          "explanation": "$a^{-n} = 1 / a^n$"
        },
        {
          "step": "Apply to $10^{-3}$",
          "calculation": "$10^{-3} = 1 / 10^3 = 1 / 1000 = 0.001$"
        }
      ],
      "final_answer": "$0.001$"
    },
    {
