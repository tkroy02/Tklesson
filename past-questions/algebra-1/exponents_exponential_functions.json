      "problem": "A population of 1200 decreases by 8% each year. Write the exponential decay model and predict the population after 3 years.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify initial value",
          "calculation": "$P_0 = 1200$"
        },
        {
          "step": "Find decay factor",
          "explanation": "8% decrease means 92% remains: $1 - 0.08 = 0.92$"
        },
        {
          "step": "Write the model",
          "calculation": "$P(t) = 1200 \\times 0.92^t$"
        },
        {
          "step": "Evaluate at $t = 3$",
          "calculation": "$P(3) = 1200 \\times 0.92^3 = 1200 \\times 0.778688 = 934.4256$"
