    {
      "number": 15,
      "problem": "A boat traveled 120 miles downstream in 4 hours and the same distance upstream in 6 hours. Find the speed of the boat in still water and the speed of the current.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let b = speed of boat in still water (mph), c = speed of current (mph)"
        },
        {
          "step": "Write equations",
          "explanation": "Downstream: b + c = distance/time = 120/4 = 30\nUpstream: b − c = 120/6 = 20",
          "calculation": "b + c = 30\nb − c = 20"
        },
        {
          "step": "Add the equations",
          "calculation": "2b = 50 → b = 25"
        },
        {
          "step": "Substitute to find c",
          "calculation": "25 + c = 30 → c = 5"
        }
      ],
      "final_answer": "Boat speed = 25 mph, current speed = 5 mph."
