    {
      "number": 20,
      "problem": "A rectangle has a perimeter of 56 inches. The length is 4 inches less than twice the width. Find the length and width.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let l = length, w = width"
        },
        {
          "step": "Write equations",
          "calculation": "2l + 2w = 56\nl = 2w − 4"
        },
        {
          "step": "Simplify perimeter",
          "calculation": "l + w = 28"
        },
        {
          "step": "Substitute l",
          "calculation": "(2w − 4) + w = 28 → 3w − 4 = 28"
        },
        {
          "step": "Solve for w",
          "calculation": "3w = 32 → w = 32/3"
        },
        {
          "step": "Find l",
          "calculation": "l = 2(32/3) − 4 = 64/3 − 12/3 = 52/3"
        }
      ],
      "final_answer": "Width = 32/3 inches, length = 52/3 inches."
    }
