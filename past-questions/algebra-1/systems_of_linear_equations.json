        {
          "step": "Define variables",
          "explanation": "Let x = first number, y = second number"
        },
        {
          "step": "Write equations",
          "calculation": "x + y = 24\nx − y = 6"
        },
        {
          "step": "Add the equations",
          "calculation": "2x = 30 → x = 15"
        },
        {
          "step": "Substitute to find y",
