    {
      "number": 17,
      "problem": "A test has 20 questions worth a total of 80 points. Each multiple-choice question is worth 3 points and each free-response question is worth 5 points. How many of each type of question are on the test?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let m = number of multiple-choice questions, f = number of free-response questions"
        },
        {
          "step": "Write equations",
          "calculation": "m + f = 20\n3m + 5f = 80"
        },
        {
          "step": "Multiply first equation by 3",
          "calculation": "3m + 3f = 60"
        },
        {
          "step": "Subtract from the second equation",
          "calculation": "(3m + 5f) − (3m + 3f) = 80 − 60 → 2f = 20 → f = 10"
        },
        {
          "step": "Substitute to find m",
          "calculation": "m + 10 = 20 → m = 10"
        }
      ],
      "final_answer": "10 multiple-choice and 10 free-response questions."
