    {
      "number": 18,
      "problem": "A movie theater sold 250 tickets for a showing. Adult tickets cost \\$12 and child tickets cost \\$8. The total ticket sales were \\$2400. How many adult tickets and how many child tickets were sold?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let a = number of adult tickets, c = number of child tickets"
        },
        {
          "step": "Write equations",
          "calculation": "a + c = 250\n12a + 8c = 2400"
        },
        {
          "step": "Multiply first equation by 8",
          "calculation": "8a + 8c = 2000"
        },
        {
          "step": "Subtract from the second equation",
          "calculation": "(12a + 8c) − (8a + 8c) = 2400 − 2000 → 4a = 400 → a = 100"
        },
        {
          "step": "Substitute to find c",
          "calculation": "100 + c = 250 → c = 150"
        }
      ],
      "final_answer": "100 adult tickets and 150 child tickets."
