    {
      "number": 7,
      "problem": "Solve the system using elimination:\n\n1) 5x + 4y = 32\n2) 5x − 2y = 2",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract the second equation from the first",
          "calculation": "(5x + 4y) − (5x − 2y) = 32 − 2 → 6y = 30"
        },
        {
          "step": "Solve for y",
          "calculation": "y = 5"
        },
        {
          "step": "Substitute into 5x − 2y = 2",
          "calculation": "5x − 10 = 2 → 5x = 12 → x = 12/5"
        }
      ],
      "final_answer": "(12/5, 5)"
