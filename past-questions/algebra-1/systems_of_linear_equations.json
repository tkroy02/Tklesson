    {
      "number": 19,
      "problem": "Two angles are supplementary. One angle is 30 degrees less than twice the other. Find both angles.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let x = first angle, y = second angle"
        },
        {
          "step": "Write equations",
          "explanation": "Supplementary angles sum to 180°",
          "calculation": "x + y = 180\nx = 2y − 30"
        },
        {
          "step": "Substitute x into the first equation",
          "calculation": "(2y − 30) + y = 180 → 3y − 30 = 180"
        },
        {
          "step": "Solve for y",
          "calculation": "3y = 210 → y = 70"
        },
        {
          "step": "Find x",
          "calculation": "x = 2(70) − 30 = 140 − 30 = 110"
        }
      ],
      "final_answer": "The angles are 110° and 70°."
