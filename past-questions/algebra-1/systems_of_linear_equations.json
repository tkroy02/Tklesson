    {
      "number": 9,
      "problem": "Solve the system:\n\n1) x − 4y = −6\n2) 3x + y = 17",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply the second equation by 4 to eliminate y",
          "calculation": "4(3x + y) = 4(17) → 12x + 4y = 68"
        },
        {
          "step": "Add with the first equation",
          "calculation": "(x − 4y) + (12x + 4y) = −6 + 68 → 13x = 62"
        },
        {
          "step": "Solve for x",
          "calculation": "x = 62/13"
        },
        {
          "step": "Substitute x = 62/13 into 3x + y = 17",
          "calculation": "3(62/13) + y = 17 → 186/13 + y = 17 → y = 17 − 186/13 = (221 − 186)/13 = 35/13"
        }
      ],
      "final_answer": "(62/13, 35/13)"
    },
    {
      "number": 10,
      "problem": "Solve the system:\n\n1) 2x + 3y = 4\n2) −x + y = 7",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply second equation by 2 to eliminate x",
          "calculation": "−2x + 2y = 14"
        },
        {
          "step": "Add equations",
          "calculation": "(2x + 3y) + (−2x + 2y) = 4 + 14 → 5y = 18"
        },
        {
          "step": "Solve for y",
          "calculation": "y = 18/5"
        },
        {
          "step": "Substitute into −x + y = 7",
          "calculation": "−x + 18/5 = 7 → −x = 7 − 18/5 = (35 − 18)/5 = 17/5 → x = −17/5"
        }
      ],
      "final_answer": "(-17/5, 18/5)"
    },
