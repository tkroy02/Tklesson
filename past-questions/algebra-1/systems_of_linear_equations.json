  "problems": [
    {
      "number": 1,
      "problem": "Solve the system using substitution:\n\n1) y = 3x − 4\n2) 2x + y = 11",
      "image": null,
      "step_by_step": [
        {
          "step": "Substitute y into the second equation",
          "calculation": "2x + (3x − 4) = 11 → 5x − 4 = 11"
        },
        {
          "step": "Solve for x",
          "calculation": "5x = 15 → x = 3"
        },
        {
          "step": "Plug x = 3 back into y = 3x − 4",
          "calculation": "y = 3(3) − 4 = 5"
        }
      ],
      "final_answer": "(3, 5)"
    },
    {
      "number": 2,
      "problem": "Solve the system using elimination:\n\n1) 4x − y = 9\n2) 2x + y = 1",
      "image": null,
      "step_by_step": [
        {
          "step": "Add the equations to eliminate y",
          "calculation": "(4x − y) + (2x + y) = 9 + 1 → 6x = 10"
        },
        {
          "step": "Solve for x",
          "calculation": "x = 10/6 = 5/3"
        },
        {
          "step": "Substitute x = 5/3 into 2x + y = 1",
          "calculation": "2(5/3) + y = 1 → 10/3 + y = 1 → y = 1 − 10/3 = −7/3"
        }
      ],
      "final_answer": "(5/3, −7/3)"
    },
    {
      "number": 3,
      "problem": "Solve the system:\n\n1) x + 2y = 8\n2) x − y = 2",
      "image": null,
      "step_by_step": [
        {
          "step": "Subtract the second equation from the first",
          "calculation": "(x + 2y) − (x − y) = 8 − 2 → 3y = 6"
        },
        {
          "step": "Solve for y",
          "calculation": "y = 2"
        },
        {
          "step": "Substitute y = 2 into x − y = 2",
          "calculation": "x − 2 = 2 → x = 4"
        }
      ],
      "final_answer": "(4, 2)"
    },
