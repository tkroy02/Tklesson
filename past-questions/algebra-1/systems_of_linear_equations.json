    {
      "number": 12,
      "problem": "A total of 80 tickets were sold for a school concert. Adult tickets cost \\$8 each and student tickets cost \\$5 each. The total revenue was \\$520. How many adult tickets and how many student tickets were sold?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let a = number of adult tickets, s = number of student tickets"
        },
        {
          "step": "Write equations",
          "calculation": "a + s = 80\n8a + 5s = 520"
        },
        {
          "step": "Multiply first equation by 5",
          "calculation": "5a + 5s = 400"
        },
        {
          "step": "Subtract from the second equation",
          "calculation": "(8a + 5s) − (5a + 5s) = 520 − 400 → 3a = 120 → a = 40"
        },
        {
          "step": "Substitute to find s",
          "calculation": "40 + s = 80 → s = 40"
        }
      ],
      "final_answer": "40 adult tickets and 40 student tickets."
    },
    {
      "number": 13,
      "problem": "The perimeter of a rectangle is 40 meters. The length is 4 meters more than the width. Find the length and width.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let l = length, w = width"
        },
        {
          "step": "Write equations",
          "calculation": "2l + 2w = 40\nl = w + 4"
        },
        {
          "step": "Substitute l into the first equation",
          "calculation": "2(w + 4) + 2w = 40 → 2w + 8 + 2w = 40 → 4w + 8 = 40"
        },
        {
          "step": "Solve for w",
          "calculation": "4w = 32 → w = 8"
        },
        {
          "step": "Find l",
          "calculation": "l = 8 + 4 = 12"
        }
      ],
      "final_answer": "Length = 12 meters, width = 8 meters."
    },
    {
      "number": 14,
      "problem": "A store sells apples for \\$2 per pound and oranges for \\$3 per pound. If a customer buys 8 pounds of fruit for a total of \\$20, how many pounds of apples and how many pounds of oranges did they buy?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let a = pounds of apples, r = pounds of oranges"
        },
        {
          "step": "Write equations",
          "calculation": "a + r = 8\n2a + 3r = 20"
        },
        {
          "step": "Multiply first equation by 2",
          "calculation": "2a + 2r = 16"
        },
        {
          "step": "Subtract from the second equation",
          "calculation": "(2a + 3r) − (2a + 2r) = 20 − 16 → r = 4"
        },
        {
          "step": "Substitute to find a",
          "calculation": "a + 4 = 8 → a = 4"
        }
      ],
      "final_answer": "4 pounds of apples and 4 pounds of oranges."
