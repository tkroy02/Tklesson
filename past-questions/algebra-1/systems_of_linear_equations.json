    {
      "number": 16,
      "problem": "A pet store has a total of 32 birds and fish. The number of fish is 5 more than twice the number of birds. How many birds and how many fish are there?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let b = number of birds, f = number of fish"
        },
        {
          "step": "Write equations",
          "calculation": "b + f = 32\nf = 2b + 5"
        },
        {
          "step": "Substitute f into the first equation",
          "calculation": "b + (2b + 5) = 32 → 3b + 5 = 32"
        },
        {
          "step": "Solve for b",
          "calculation": "3b = 27 → b = 9"
        },
        {
          "step": "Find f",
          "calculation": "f = 2(9) + 5 = 18 + 5 = 23"
        }
      ],
      "final_answer": "9 birds and 23 fish."
