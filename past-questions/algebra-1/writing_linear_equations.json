{
  "course": "Algebra 1",
  "topic": "Writing Linear Equations",
  "problems": [
    {
      "number": 1,
      "problem": "Write the equation of a line with slope 5 and y-intercept −3.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use slope-intercept form",
          "explanation": "y = mx + b, where m = 5 and b = -3"
        },
        {
          "step": "Substitute values",
          "calculation": "y = 5x - 3"
        }
      ],
      "final_answer": "y = 5x - 3"
    },
    {
      "number": 2,
      "problem": "Write the equation of a line that passes through (4, 7) with slope −2.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use point-slope form",
          "explanation": "y − y₁ = m(x − x₁)"
        },
        {
          "step": "Substitute values",
          "calculation": "y − 7 = −2(x − 4)"
        },
        {
          "step": "Convert to slope-intercept",
          "calculation": "y − 7 = −2x + 8 → y = −2x + 15"
        }
      ],
      "final_answer": "y = −2x + 15"
    },
    {
      "number": 3,
      "problem": "Find the equation of the line passing through (−1, 3) and (5, −9).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find slope",
          "calculation": "m = (−9 − 3) / (5 − (−1)) = −12 / 6 = −2"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y − 3 = −2(x + 1)"
        },
        {
          "step": "Convert to slope-intercept",
          "calculation": "y − 3 = −2x − 2 → y = −2x + 1"
        }
      ],
      "final_answer": "y = −2x + 1"
    },
    {
      "number": 4,
      "problem": "Write the equation of a line parallel to y = 3x + 6 that passes through (2, −5).",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify slope",
          "explanation": "Parallel lines have same slope → m = 3"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y + 5 = 3(x − 2)"
        },
        {
          "step": "Simplify",
          "calculation": "y + 5 = 3x − 6 → y = 3x − 11"
        }
      ],
      "final_answer": "y = 3x − 11"
    },
    {
      "number": 5,
      "problem": "Write the equation of a line perpendicular to y = 1/2 x − 4 and passing through (6, 1).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find perpendicular slope",
          "explanation": "Slope of given line is 1/2, so perpendicular slope is −2"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y − 1 = −2(x − 6)"
        },
        {
          "step": "Simplify",
          "calculation": "y − 1 = −2x + 12 → y = −2x + 13"
        }
      ],
      "final_answer": "y = −2x + 13"
    },
    {
      "number": 6,
      "problem": "Write the equation of a line with x-intercept 4 and y-intercept −2.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify intercept points",
          "calculation": "(4,0) and (0,−2)"
        },
        {
          "step": "Find slope",
          "calculation": "m = (−2 − 0) / (0 − 4) = −2 / −4 = 1/2"
        },
        {
          "step": "Use slope-intercept form",
          "calculation": "Line crosses y-axis at −2 → y = (1/2)x − 2"
        }
      ],
      "final_answer": "y = (1/2)x − 2"
    },
    {
      "number": 7,
      "problem": "Write the equation of the line passing through (0, 5) and (3, 5).",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize horizontal line",
          "explanation": "Both points have y = 5"
        }
      ],
      "final_answer": "y = 5"
    },
    {
      "number": 8,
      "problem": "Write the equation of the line passing through (−3, 1) and having an undefined slope.",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize vertical line",
          "explanation": "Undefined slope means x = constant"
        }
      ],
      "final_answer": "x = −3"
    },
    {
      "number": 9,
      "problem": "Find the equation in standard form of the line with slope −4 and passing through (−2, 7).",
      "image": null,
      "step_by_step": [
        {
          "step": "Start with point-slope",
          "calculation": "y − 7 = −4(x + 2)"
        },
        {
          "step": "Expand",
          "calculation": "y − 7 = −4x − 8"
        },
        {
          "step": "Put into Ax + By = C",
          "calculation": "4x + y = −1"
        }
      ],
      "final_answer": "4x + y = −1"
    },
    {
      "number": 10,
      "problem": "Determine the equation of the line whose slope is 0 and which passes through (9, −6).",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify horizontal line",
          "explanation": "Slope 0 → y = constant"
        },
        {
          "step": "Write equation",
          "calculation": "y = −6"
        }
      ],
      "final_answer": "y = −6"
    },
    {
      "number": 11,
      "problem": "Write the equation of a line through (0, −3) with slope 4.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use slope-intercept form",
          "explanation": "y = mx + b, with m = 4 and b = −3"
        },
        {
          "step": "Write equation",
          "calculation": "y = 4x − 3"
        }
      ],
      "final_answer": "y = 4x − 3"
    },
    {
      "number": 12,
      "problem": "Find the equation of the line through (−4, 2) and (2, −4).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find slope",
          "calculation": "m = (−4 − 2) / (2 − (−4)) = −6 / 6 = −1"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y − 2 = −1(x + 4)"
        },
        {
          "step": "Simplify",
          "calculation": "y − 2 = −x − 4 → y = −x − 2"
        }
      ],
      "final_answer": "y = −x − 2"
    },
    {
      "number": 13,
      "problem": "Write the equation of a line parallel to y = −2x + 7 that passes through (−1, 3).",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify slope",
          "explanation": "Parallel lines have same slope → m = −2"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y − 3 = −2(x + 1)"
        },
        {
          "step": "Simplify",
          "calculation": "y − 3 = −2x − 2 → y = −2x + 1"
        }
      ],
      "final_answer": "y = −2x + 1"
    },
    {
      "number": 14,
      "problem": "Write the equation of a line perpendicular to y = −3x + 2 that passes through (4, 5).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find perpendicular slope",
          "explanation": "Slope of given line is −3, so perpendicular slope is 1/3"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y − 5 = (1/3)(x − 4)"
        },
        {
          "step": "Simplify",
          "calculation": "y − 5 = (1/3)x − 4/3 → y = (1/3)x + 11/3"
        }
      ],
      "final_answer": "y = (1/3)x + 11/3"
    },
    {
      "number": 15,
      "problem": "Find the equation of the line with x-intercept −2 and y-intercept 6.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify intercept points",
          "calculation": "(−2,0) and (0,6)"
        },
        {
          "step": "Find slope",
          "calculation": "m = (6 − 0) / (0 − (−2)) = 6 / 2 = 3"
        },
        {
          "step": "Use slope-intercept form",
          "calculation": "Line crosses y-axis at 6 → y = 3x + 6"
        }
      ],
      "final_answer": "y = 3x + 6"
    },
