      ],
      "final_answer": "x = 2"
    },
    {
      "number": 17,
      "problem": "Write the equation of the line passing through (−2, −4) and (3, −4).",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize horizontal line",
          "explanation": "Both points have y = −4"
        }
      ],
      "final_answer": "y = −4"
    },
    {
      "number": 18,
      "problem": "Find the equation in standard form of the line through (1, −2) and (3, 4).",
      "image": null,
      "step_by_step": [
        {
          "step": "Find slope",
          "calculation": "m = (4 − (−2)) / (3 − 1) = 6 / 2 = 3"
        },
        {
          "step": "Use point-slope form",
          "calculation": "y + 2 = 3(x − 1)"
        },
        {
          "step": "Expand",
          "calculation": "y + 2 = 3x − 3 → y = 3x − 5"
        },
        {
          "step": "Convert to standard form",
          "calculation": "3x − y = 5"
        }
      ],
      "final_answer": "3x − y = 5"
    },
    {
      "number": 19,
      "problem": "Write the equation of a line with slope −2/3 and y-intercept 4.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use slope-intercept form",
          "explanation": "y = mx + b, where m = −2/3 and b = 4"
        },
        {
          "step": "Substitute values",
          "calculation": "y = (−2/3)x + 4"
        }
      ],
      "final_answer": "y = (−2/3)x + 4"
    },
    {
      "number": 20,
      "problem": "Write the equation of a line perpendicular to x = 7 that passes through (2, 5).",
