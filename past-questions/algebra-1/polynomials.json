  "topic": "Polynomials",
  "problems": [
    {
      "number": 1,
      "problem": "Simplify: $(3x^2 + 5x) + (4x^2 - 2x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Combine like terms",
          "calculation": "$(3x^2 + 4x^2) + (5x - 2x) = 7x^2 + 3x$"
        }
      ],
      "final_answer": "$7x^2 + 3x$"
    },
    {
      "number": 2,
      "problem": "Simplify: $(2x^3 - x) - (x^3 + 4x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute negative sign to the second polynomial",
          "calculation": "$(2x^3 - x) - x^3 - 4x = 2x^3 - x - x^3 - 4x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$(2x^3 - x^3) + (-x - 4x) = x^3 - 5x$"
        }
      ],
      "final_answer": "$x^3 - 5x$"
    },
    {
      "number": 3,
      "problem": "Multiply: $(x + 3)(x - 2)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use distributive property (FOIL)",
          "calculation": "$x\\cdot x + x\\cdot (-2) + 3\\cdot x + 3\\cdot (-2)$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$x^2 - 2x + 3x - 6$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^2 + x - 6$"
        }
      ],
      "final_answer": "$x^2 + x - 6$"
    },
    {
      "number": 4,
      "problem": "Multiply: $(2x - 5)(3x + 4)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use distributive property",
          "calculation": "$2x\\cdot 3x + 2x\\cdot 4 + (-5)\\cdot 3x + (-5)\\cdot 4$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$6x^2 + 8x - 15x - 20$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$6x^2 - 7x - 20$"
        }
      ],
      "final_answer": "$6x^2 - 7x - 20$"
    },
        {
      "number": 5,
      "problem": "Multiply: $(x + 2)(x^2 - 3x + 4)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $x$ to each term in the trinomial",
          "calculation": "$x \\cdot x^2 = x^3$, $x \\cdot (-3x) = -3x^2$, $x \\cdot 4 = 4x$"
        },
        {
          "step": "Distribute $2$ to each term in the trinomial",
          "calculation": "$2 \\cdot x^2 = 2x^2$, $2 \\cdot (-3x) = -6x$, $2 \\cdot 4 = 8$"
        },
        {
          "step": "Combine all terms",
          "calculation": "$x^3 - 3x^2 + 4x + 2x^2 - 6x + 8$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^3 + (-3x^2 + 2x^2) + (4x - 6x) + 8 = x^3 - x^2 - 2x + 8$"
        }
      ],
      "final_answer": "$x^3 - x^2 - 2x + 8$"
    },
        {
      "number": 6,
      "problem": "Multiply: $(x^2 + 2x - 3)(x^2 - x + 4)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $x^2$ to each term in the second trinomial",
          "calculation": "$x^2 \\cdot x^2 = x^4$, $x^2 \\cdot (-x) = -x^3$, $x^2 \\cdot 4 = 4x^2$"
        },
        {
          "step": "Distribute $2x$ to each term in the second trinomial",
          "calculation": "$2x \\cdot x^2 = 2x^3$, $2x \\cdot (-x) = -2x^2$, $2x \\cdot 4 = 8x$"
        },
        {
          "step": "Distribute $-3$ to each term in the second trinomial",
          "calculation": "$-3 \\cdot x^2 = -3x^2$, $-3 \\cdot (-x) = 3x$, $-3 \\cdot 4 = -12$"
        },
        {
          "step": "Combine all terms",
          "calculation": "$x^4 - x^3 + 4x^2 + 2x^3 - 2x^2 + 8x - 3x^2 + 3x - 12$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^4 + (-x^3 + 2x^3) + (4x^2 - 2x^2 - 3x^2) + (8x + 3x) - 12$"
        },
        {
          "step": "Simplify",
          "calculation": "$x^4 + x^3 - x^2 + 11x - 12$"
        }
      ],
      "final_answer": "$x^4 + x^3 - x^2 + 11x - 12$"
    },
        {
      "number": 7,
      "problem": "Simplify: $(2x + 3y - 4)^2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recall the formula for square of a trinomial",
          "explanation": "$(a + b + c)^2 = a^2 + b^2 + c^2 + 2ab + 2ac + 2bc$"
        },
        {
          "step": "Identify $a$, $b$, and $c$",
          "calculation": "$a = 2x$, $b = 3y$, $c = -4$"
        },
        {
          "step": "Apply the formula",
          "calculation": "$(2x)^2 + (3y)^2 + (-4)^2 + 2(2x)(3y) + 2(2x)(-4) + 2(3y)(-4)$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$4x^2 + 9y^2 + 16 + 12xy - 16x - 24y$"
        }
      ],
      "final_answer": "$4x^2 + 9y^2 + 16 + 12xy - 16x - 24y$"
    },
        {
      "number": 8,
      "problem": "Simplify: $(4p^2q - 3pq^2)(2p + 5q)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $4p^2q$ to both terms in the second binomial",
          "calculation": "$4p^2q \\cdot 2p = 8p^3q$\n$4p^2q \\cdot 5q = 20p^2q^2$"
        },
        {
          "step": "Distribute $-3pq^2$ to both terms in the second binomial",
          "calculation": "$-3pq^2 \\cdot 2p = -6p^2q^2$\n$-3pq^2 \\cdot 5q = -15pq^3$"
        },
        {
          "step": "Combine all terms",
          "calculation": "$8p^3q + 20p^2q^2 - 6p^2q^2 - 15pq^3$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$8p^3q + (20p^2q^2 - 6p^2q^2) - 15pq^3 = 8p^3q + 14p^2q^2 - 15pq^3$"
        }
      ],
      "final_answer": "$8p^3q + 14p^2q^2 - 15pq^3$"
    },
        {
      "number": 9,
      "problem": "Simplify: $(3x + 7y)^2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use square of a binomial formula",
          "explanation": "$(a + b)^2 = a^2 + 2ab + b^2$"
        },
        {
          "step": "Identify $a$ and $b$",
          "calculation": "$a = 3x$, $b = 7y$"
        },
        {
          "step": "Apply the formula",
          "calculation": "$(3x)^2 + 2(3x)(7y) + (7y)^2$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$9x^2 + 42xy + 49y^2$"
        }
      ],
      "final_answer": "$9x^2 + 42xy + 49y^2$"
    },
        {
      "number": 10,
      "problem": "Simplify: $12x^2 - 9y^3 + (2x - 3y)^2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Expand $(2x - 3y)^2$",
          "explanation": "Use square of a binomial formula: $(a - b)^2 = a^2 - 2ab + b^2$",
          "calculation": "$(2x)^2 - 2(2x)(3y) + (3y)^2 = 4x^2 - 12xy + 9y^2$"
        },
        {
          "step": "Substitute back into the expression",
          "calculation": "$12x^2 - 9y^3 + (4x^2 - 12xy + 9y^2)$"
        },
        {
          "step": "Remove parentheses",
          "calculation": "$12x^2 - 9y^3 + 4x^2 - 12xy + 9y^2$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$(12x^2 + 4x^2) - 12xy + 9y^2 - 9y^3 = 16x^2 - 12xy + 9y^2 - 9y^3$"
        },
        {
          "step": "Write in standard form (descending powers of $x$ and $y$)",
          "calculation": "$16x^2 - 12xy + 9y^2 - 9y^3$"
        }
      ],
      "final_answer": "$16x^2 - 12xy + 9y^2 - 9y^3$"
    },
    {
      "number": 11,
      "problem": "Simplify: $(4x^3 - 2x^2 + 5x) - (x^3 + 3x^2 - 2x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute negative sign",
          "calculation": "$4x^3 - 2x^2 + 5x - x^3 - 3x^2 + 2x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$(4x^3 - x^3) + (-2x^2 - 3x^2) + (5x + 2x) = 3x^3 - 5x^2 + 7x$"
        }
      ],
      "final_answer": "$3x^3 - 5x^2 + 7x$"
    },
    {
      "number": 12,
      "problem": "Multiply: $(3x - 2)(x^2 + 4x - 1)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $3x$ to each term in second polynomial",
          "calculation": "$3x \\cdot x^2 = 3x^3$, $3x \\cdot 4x = 12x^2$, $3x \\cdot (-1) = -3x$"
        },
        {
          "step": "Distribute $-2$ to each term in second polynomial",
          "calculation": "$-2 \\cdot x^2 = -2x^2$, $-2 \\cdot 4x = -8x$, $-2 \\cdot (-1) = 2$"
        },
        {
          "step": "Combine all terms",
          "calculation": "$3x^3 + 12x^2 - 3x - 2x^2 - 8x + 2$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$3x^3 + (12x^2 - 2x^2) + (-3x - 8x) + 2 = 3x^3 + 10x^2 - 11x + 2$"
        }
      ],
      "final_answer": "$3x^3 + 10x^2 - 11x + 2$"
    },
        {
      "number": 13,
      "problem": "Simplify: $(m^2 + 7)(m^2 - 7)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize difference of squares pattern",
          "explanation": "$(a + b)(a - b) = a^2 - b^2$"
        },
        {
          "step": "Identify $a$ and $b$",
          "calculation": "$a = m^2$, $b = 7$"
        },
        {
          "step": "Apply the formula",
          "calculation": "$(m^2)^2 - (7)^2$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$m^4 - 49$"
        }
      ],
      "final_answer": "$m^4 - 49$"
    },
        {
      "number": 14,
      "problem": "Simplify $(3x^2 - 4x + 7) \\div (x - 2)$. Is there a remainder?",
      "image": null,
      "step_by_step": [
        {
          "step": "Set up polynomial long division",
          "calculation": "Divide $3x^2 - 4x + 7$ by $x - 2$"
        },
        {
          "step": "Divide the first term",
          "explanation": "$3x^2 \\div x = 3x$",
          "calculation": "Write $3x$ as the first term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$3x(x - 2) = 3x^2 - 6x$\n$(3x^2 - 4x + 7) - (3x^2 - 6x) = 2x + 7$"
        },
        {
          "step": "Divide the next term",
          "explanation": "$2x \\div x = 2$",
          "calculation": "Write $+2$ as the next term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$2(x - 2) = 2x - 4$\n$(2x + 7) - (2x - 4) = 11$"
        },
        {
          "step": "Interpret the result",
          "calculation": "Quotient = $3x + 2$, Remainder = $11$"
        }
      ],
      "final_answer": "Quotient: $3x + 2$, Remainder: $11$"
    },
    {
      "number": 15,
      "problem": "A rectangular garden has length $x + 4$ meters and width $x + 2$ meters. Write an expression for the area in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Area formula",
          "explanation": "Area = length Ă— width"
        },
        {
          "step": "Multiply polynomials",
          "calculation": "$(x + 4)(x + 2) = x^2 + 2x + 4x + 8 = x^2 + 6x + 8$"
        }
      ],
      "final_answer": "$x^2 + 6x + 8$ square meters"
    },
    {
      "number": 16,
      "problem": "A rectangle has length $2x - 1$ and width $x + 3$. Find the perimeter of the rectangle.",
      "image": null,
      "step_by_step": [
        {
          "step": "Perimeter formula",
          "explanation": "$P = 2l + 2w$"
        },
        {
          "step": "Substitute expressions",
          "calculation": "$P = 2(2x - 1) + 2(x + 3)$"
        },
        {
          "step": "Distribute",
          "calculation": "$P = 4x - 2 + 2x + 6$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$P = 6x + 4$"
        }
      ],
      "final_answer": "$6x + 4$ units"
    },
    {
      "number": 17,
      "problem": "A square has side length $3x + 2$. Write an expression for its area in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Area of square",
