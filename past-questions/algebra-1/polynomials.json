        {
      "number": 18,
      "problem": "Divide $(2x^3 - 5x^2 - 4x + 12) \\div (x - 2)$ using polynomial long division.",
      "image": null,
      "step_by_step": [
        {
          "step": "Divide the first term",
          "explanation": "$2x^3 \\div x = 2x^2$",
          "calculation": "Write $2x^2$ as the first term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$2x^2(x - 2) = 2x^3 - 4x^2$\n$(2x^3 - 5x^2 - 4x + 12) - (2x^3 - 4x^2) = -x^2 - 4x + 12$"
        },
        {
          "step": "Divide the next term",
          "explanation": "$-x^2 \\div x = -x$",
          "calculation": "Write $-x$ as the next term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$-x(x - 2) = -x^2 + 2x$\n$(-x^2 - 4x + 12) - (-x^2 + 2x) = -6x + 12$"
        },
        {
          "step": "Divide the next term",
          "explanation": "$-6x \\div x = -6$",
          "calculation": "Write $-6$ as the next term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$-6(x - 2) = -6x + 12$\n$(-6x + 12) - (-6x + 12) = 0$"
        },
        {
          "step": "Write the quotient",
          "calculation": "$2x^2 - x - 6$"
        }
      ],
      "final_answer": "$2x^2 - x - 6$"
    },
    {
      "number": 19,
      "problem": "A box has dimensions: length $x + 5$, width $x$, and height $x - 2$. Write an expression for the volume in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Volume formula",
          "explanation": "$V = l \\times w \\times h$"
        },
        {
          "step": "Multiply length and width first",
          "calculation": "$(x + 5)(x) = x^2 + 5x$"
        },
        {
          "step": "Multiply by height",
          "calculation": "$(x^2 + 5x)(x - 2) = x^3 - 2x^2 + 5x^2 - 10x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^3 + 3x^2 - 10x$"
        }
      ],
      "final_answer": "$x^3 + 3x^2 - 10x$ cubic units"
