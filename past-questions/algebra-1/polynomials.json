  "topic": "Polynomials",
  "problems": [
    {
      "number": 1,
      "problem": "Simplify: $(3x^2 + 5x) + (4x^2 - 2x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Combine like terms",
          "calculation": "$(3x^2 + 4x^2) + (5x - 2x) = 7x^2 + 3x$"
        }
      ],
      "final_answer": "$7x^2 + 3x$"
    },
    {
      "number": 2,
      "problem": "Simplify: $(2x^3 - x) - (x^3 + 4x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute negative sign to the second polynomial",
          "calculation": "$(2x^3 - x) - x^3 - 4x = 2x^3 - x - x^3 - 4x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$(2x^3 - x^3) + (-x - 4x) = x^3 - 5x$"
        }
      ],
      "final_answer": "$x^3 - 5x$"
    },
    {
      "number": 3,
      "problem": "Multiply: $(x + 3)(x - 2)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use distributive property (FOIL)",
          "calculation": "$x\\cdot x + x\\cdot (-2) + 3\\cdot x + 3\\cdot (-2)$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$x^2 - 2x + 3x - 6$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^2 + x - 6$"
        }
      ],
      "final_answer": "$x^2 + x - 6$"
    },
    {
      "number": 4,
      "problem": "Multiply: $(2x - 5)(3x + 4)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use distributive property",
          "calculation": "$2x\\cdot 3x + 2x\\cdot 4 + (-5)\\cdot 3x + (-5)\\cdot 4$"
        },
        {
          "step": "Simplify each term",
          "calculation": "$6x^2 + 8x - 15x - 20$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$6x^2 - 7x - 20$"
        }
      ],
      "final_answer": "$6x^2 - 7x - 20$"
    },
    {
      "number": 5,
      "problem": "Factor completely: $x^2 + 5x + 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Find two numbers that multiply to 6 and add to 5",
          "calculation": "2 and 3"
        },
        {
          "step": "Write as factors",
          "calculation": "$(x + 2)(x + 3)$"
        }
      ],
      "final_answer": "$(x + 2)(x + 3)$"
    },
    {
      "number": 6,
      "problem": "Factor completely: $2x^2 + 7x + 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply coefficient of $x^2$ and constant: $2\\cdot3=6$",
          "explanation": "Find two numbers that multiply to 6 and add to 7"
        },
        {
          "step": "Numbers are 6 and 1",
          "calculation": "Split the middle term: $2x^2 + 6x + x + 3$"
        },
        {
          "step": "Factor by grouping",
          "calculation": "$(2x^2 + 6x) + (x + 3) = 2x(x + 3) + 1(x + 3)$"
        },
        {
          "step": "Factor out common term",
          "calculation": "$(2x + 1)(x + 3)$"
        }
      ],
      "final_answer": "$(2x + 1)(x + 3)$"
    },
    {
      "number": 7,
      "problem": "Simplify: $(x^2y^3)(2xy^2)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply coefficients",
          "calculation": "$1 \\cdot 2 = 2$"
        },
        {
          "step": "Add exponents for like bases",
          "calculation": "$x^2 \\cdot x = x^{2+1} = x^3$; $y^3 \\cdot y^2 = y^{3+2} = y^5$"
        },
        {
          "step": "Combine results",
          "calculation": "$2x^3y^5$"
        }
      ],
      "final_answer": "$2x^3y^5$"
    },
    {
      "number": 8,
      "problem": "Factor completely: $x^2 - 9$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize difference of squares",
          "explanation": "$a^2 - b^2 = (a - b)(a + b)$"
        },
        {
          "step": "Write factors",
          "calculation": "$x^2 - 9 = (x - 3)(x + 3)$"
        }
      ],
      "final_answer": "$(x - 3)(x + 3)$"
    },
    {
      "number": 9,
      "problem": "Simplify: $(x + 2)^2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use square of a binomial formula",
          "explanation": "$(a + b)^2 = a^2 + 2ab + b^2$"
        },
        {
          "step": "Apply formula",
          "calculation": "$(x + 2)^2 = x^2 + 4x + 4$"
        }
      ],
      "final_answer": "$x^2 + 4x + 4$"
    },
    {
      "number": 10,
      "problem": "Factor completely: $x^3 + 8$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize sum of cubes",
          "explanation": "$a^3 + b^3 = (a + b)(a^2 - ab + b^2)$"
        },
        {
          "step": "Write as sum of cubes",
          "calculation": "$x^3 + 8 = x^3 + 2^3$"
        },
        {
          "step": "Factor using formula",
          "calculation": "$(x + 2)(x^2 - 2x + 4)$"
        }
      ],
      "final_answer": "$(x + 2)(x^2 - 2x + 4)$"
    },
    {
      "number": 11,
      "problem": "Simplify: $(4x^3 - 2x^2 + 5x) - (x^3 + 3x^2 - 2x)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute negative sign",
          "calculation": "$4x^3 - 2x^2 + 5x - x^3 - 3x^2 + 2x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$(4x^3 - x^3) + (-2x^2 - 3x^2) + (5x + 2x) = 3x^3 - 5x^2 + 7x$"
        }
      ],
      "final_answer": "$3x^3 - 5x^2 + 7x$"
    },
    {
      "number": 12,
      "problem": "Multiply: $(3x - 2)(x^2 + 4x - 1)$",
      "image": null,
      "step_by_step": [
        {
          "step": "Distribute $3x$ to each term in second polynomial",
          "calculation": "$3x \\cdot x^2 = 3x^3$, $3x \\cdot 4x = 12x^2$, $3x \\cdot (-1) = -3x$"
        },
        {
          "step": "Distribute $-2$ to each term in second polynomial",
          "calculation": "$-2 \\cdot x^2 = -2x^2$, $-2 \\cdot 4x = -8x$, $-2 \\cdot (-1) = 2$"
        },
        {
          "step": "Combine all terms",
          "calculation": "$3x^3 + 12x^2 - 3x - 2x^2 - 8x + 2$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$3x^3 + (12x^2 - 2x^2) + (-3x - 8x) + 2 = 3x^3 + 10x^2 - 11x + 2$"
        }
      ],
      "final_answer": "$3x^3 + 10x^2 - 11x + 2$"
    },
    {
      "number": 13,
      "problem": "Factor completely: $x^2 - 10x + 25$",
      "image": null,
      "step_by_step": [
        {
          "step": "Recognize perfect square trinomial",
          "explanation": "$a^2 - 2ab + b^2 = (a - b)^2$"
        },
        {
          "step": "Write as perfect square",
          "calculation": "$x^2 - 10x + 25 = (x - 5)^2$"
        }
      ],
      "final_answer": "$(x - 5)^2$"
    },
    {
      "number": 14,
      "problem": "Factor completely: $6x^2 - 13x + 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Multiply $a \\cdot c$: $6 \\cdot 6 = 36$",
          "explanation": "Find two numbers that multiply to 36 and add to $-13$"
        },
        {
          "step": "Numbers are $-9$ and $-4$",
          "calculation": "Split the middle term: $6x^2 - 9x - 4x + 6$"
        },
        {
          "step": "Factor by grouping",
          "calculation": "$(6x^2 - 9x) + (-4x + 6) = 3x(2x - 3) - 2(2x - 3)$"
        },
        {
          "step": "Factor out common term",
          "calculation": "$(3x - 2)(2x - 3)$"
        }
      ],
      "final_answer": "$(3x - 2)(2x - 3)$"
    },
    {
      "number": 15,
      "problem": "A rectangular garden has length $x + 4$ meters and width $x + 2$ meters. Write an expression for the area in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Area formula",
          "explanation": "Area = length Ă— width"
        },
        {
          "step": "Multiply polynomials",
          "calculation": "$(x + 4)(x + 2) = x^2 + 2x + 4x + 8 = x^2 + 6x + 8$"
        }
      ],
      "final_answer": "$x^2 + 6x + 8$ square meters"
    },
    {
      "number": 16,
      "problem": "A rectangle has length $2x - 1$ and width $x + 3$. Find the perimeter of the rectangle.",
      "image": null,
      "step_by_step": [
        {
          "step": "Perimeter formula",
          "explanation": "$P = 2l + 2w$"
        },
        {
          "step": "Substitute expressions",
          "calculation": "$P = 2(2x - 1) + 2(x + 3)$"
        },
        {
          "step": "Distribute",
          "calculation": "$P = 4x - 2 + 2x + 6$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$P = 6x + 4$"
        }
      ],
      "final_answer": "$6x + 4$ units"
    },
    {
      "number": 17,
      "problem": "A square has side length $3x + 2$. Write an expression for its area in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Area of square",
          "explanation": "$A = s^2$"
        },
        {
          "step": "Expand $(3x + 2)^2$",
          "calculation": "$(3x + 2)^2 = 9x^2 + 12x + 4$"
        }
      ],
      "final_answer": "$9x^2 + 12x + 4$ square units"
    },
        {
      "number": 18,
      "problem": "Divide $(2x^3 - 5x^2 - 4x + 12) \\div (x - 2)$ using polynomial long division.",
      "image": null,
      "step_by_step": [
        {
          "step": "Divide the first term",
          "explanation": "$2x^3 \\div x = 2x^2$",
          "calculation": "Write $2x^2$ as the first term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$2x^2(x - 2) = 2x^3 - 4x^2$\n$(2x^3 - 5x^2 - 4x + 12) - (2x^3 - 4x^2) = -x^2 - 4x + 12$"
        },
        {
          "step": "Divide the next term",
          "explanation": "$-x^2 \\div x = -x$",
          "calculation": "Write $-x$ as the next term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$-x(x - 2) = -x^2 + 2x$\n$(-x^2 - 4x + 12) - (-x^2 + 2x) = -6x + 12$"
        },
        {
          "step": "Divide the next term",
          "explanation": "$-6x \\div x = -6$",
          "calculation": "Write $-6$ as the next term of the quotient"
        },
        {
          "step": "Multiply and subtract",
          "calculation": "$-6(x - 2) = -6x + 12$\n$(-6x + 12) - (-6x + 12) = 0$"
        },
        {
          "step": "Write the quotient",
          "calculation": "$2x^2 - x - 6$"
        }
      ],
      "final_answer": "$2x^2 - x - 6$"
    },
    {
      "number": 19,
      "problem": "A box has dimensions: length $x + 5$, width $x$, and height $x - 2$. Write an expression for the volume in standard form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Volume formula",
          "explanation": "$V = l \\times w \\times h$"
        },
        {
          "step": "Multiply length and width first",
          "calculation": "$(x + 5)(x) = x^2 + 5x$"
        },
        {
          "step": "Multiply by height",
          "calculation": "$(x^2 + 5x)(x - 2) = x^3 - 2x^2 + 5x^2 - 10x$"
        },
        {
          "step": "Combine like terms",
          "calculation": "$x^3 + 3x^2 - 10x$"
        }
      ],
      "final_answer": "$x^3 + 3x^2 - 10x$ cubic units"
    },
        {
      "number": 20,
      "problem": "Divide $(x^2 + 7x + 12) \\div (x + 3)$ using long division or factoring.",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor the numerator",
          "explanation": "Find two numbers that multiply to 12 and add to 7",
          "calculation": "$x^2 + 7x + 12 = (x + 3)(x + 4)$"
        },
        {
          "step": "Rewrite the division",
          "calculation": "$\\frac{(x + 3)(x + 4)}{x + 3}$"
        },
        {
          "step": "Cancel common factor",
          "calculation": "$x + 4$"
        }
      ],
      "final_answer": "$x + 4$"
    }
  ]
