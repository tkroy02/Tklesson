    {
      "number": 18,
      "problem": "Determine if the points (1,5), (2,7), and (3,9) lie on the same line. If so, write the equation.",
      "image": null,
      "step_by_step": [
        {
          "step": "Find slope between first two points",
          "calculation": "m = (7 - 5) / (2 - 1) = 2/1 = 2"
        },
        {
          "step": "Find slope between second and third points",
          "calculation": "m = (9 - 7) / (3 - 2) = 2/1 = 2"
        },
        {
          "step": "Slopes are equal",
          "explanation": "All three points are collinear."
        },
        {
          "step": "Find equation using point (1,5)",
          "calculation": "y - 5 = 2(x - 1) → y - 5 = 2x - 2 → y = 2x + 3"
        }
      ],
      "final_answer": "Yes; equation y = 2x + 3"
