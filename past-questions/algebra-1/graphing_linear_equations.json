  "topic": "Graphing Linear Equations",
  "problems": [
    {
      "number": 1,
      "problem": "Graph the line y = 2x + 1. Identify slope and y-intercept.",
      "image": null,
      "step_by_step": [
        {
          "step": "Identify slope and intercept",
          "explanation": "Compare to y = mx + b: slope m = 2, y-intercept b = 1"
        },
        {
          "step": "Plot y-intercept",
          "explanation": "Plot point (0,1) on the coordinate plane"
        },
        {
          "step": "Use slope to find another point",
          "explanation": "From (0,1), rise 2 and run 1 → point (1,3)"
        },
        {
          "step": "Draw the line",
          "explanation": "Draw a straight line through (0,1) and (1,3)"
        }
      ],
      "final_answer": "Slope = 2, y-intercept = 1; line through (0,1) and (1,3)."
    },
    {
      "number": 2,
      "problem": "Find the equation of the line with slope -3 and y-intercept 4.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use slope-intercept form",
          "explanation": "y = mx + b where m = -3 and b = 4"
        },
        {
          "step": "Write equation",
          "calculation": "y = -3x + 4"
        }
      ],
      "final_answer": "y = -3x + 4"
    },
    {
      "number": 3,
      "problem": "Find the slope and equation of the line passing through points (2,5) and (4,9).",
      "image": null,
      "step_by_step": [
        {
          "step": "Calculate slope",
          "calculation": "m = (9 - 5) / (4 - 2) = 4 / 2 = 2"
        },
        {
          "step": "Use point-slope form",
          "explanation": "y - y1 = m(x - x1), use (2,5): y - 5 = 2(x - 2)"
        },
        {
          "step": "Convert to slope-intercept",
          "calculation": "y - 5 = 2x - 4 → y = 2x + 1"
        }
      ],
      "final_answer": "Slope = 2; equation y = 2x + 1"
    },
    {
      "number": 4,
      "problem": "Write the equation of a line parallel to y = (1/2)x - 3 and passing through (0,2).",
      "image": null,
      "step_by_step": [
        {
          "step": "Parallel lines have same slope",
          "explanation": "m = 1/2"
        },
        {
          "step": "Use slope-intercept with given point",
          "explanation": "y = (1/2)x + b; substitute (0,2) to find b"
        },
        {
          "step": "Find intercept b",
          "calculation": "2 = (1/2)(0) + b → b = 2"
        },
        {
          "step": "Write equation",
          "calculation": "y = (1/2)x + 2"
        }
      ],
      "final_answer": "y = (1/2)x + 2"
    },
    {
      "number": 5,
      "problem": "Find the equation of the line perpendicular to y = -4x + 1 that passes through (2,-3).",
      "image": null,
      "step_by_step": [
        {
          "step": "Perpendicular slope",
          "explanation": "Slope of given line m = -4; perpendicular slope m' = 1/4 (negative reciprocal)"
        },
        {
          "step": "Use point-slope form",
          "explanation": "y - (-3) = (1/4)(x - 2)"
        },
        {
          "step": "Simplify to slope-intercept",
          "calculation": "y + 3 = (1/4)x - 1/2 → y = (1/4)x - 1/2 - 3 → y = (1/4)x - 3.5"
        }
      ],
      "final_answer": "y = (1/4)x - 3.5"
    },
    {
      "number": 6,
      "problem": "Determine x- and y-intercepts of 3x + 2y = 12 and graph using intercepts.",
      "image": null,
      "step_by_step": [
        {
          "step": "Find x-intercept (y=0)",
          "calculation": "3x + 2(0) = 12 → x = 4 → (4,0)"
        },
        {
          "step": "Find y-intercept (x=0)",
          "calculation": "3(0) + 2y = 12 → y = 6 → (0,6)"
        },
        {
          "step": "Plot intercepts and draw line",
          "explanation": "Draw line through (4,0) and (0,6)"
        }
      ],
      "final_answer": "x-intercept (4,0); y-intercept (0,6); line through these points."
    },
    {
      "number": 7,
      "problem": "Convert the equation 2x - 5y = 10 to slope-intercept form and identify slope and intercept.",
      "image": null,
      "step_by_step": [
        {
          "step": "Solve for y",
          "calculation": "2x - 5y = 10 → -5y = -2x + 10 → y = (2/5)x - 2"
        },
        {
          "step": "Identify slope and intercept",
          "explanation": "Slope m = 2/5; y-intercept b = -2"
        }
      ],
      "final_answer": "y = (2/5)x - 2; slope 2/5, y-intercept -2"
    },
    {
      "number": 8,
      "problem": "Given the graph with points (-1,4) and (2,-2), write the equation of the line.",
      "image": null,
      "step_by_step": [
        {
          "step": "Calculate slope",
          "calculation": "m = (-2 - 4) / (2 - (-1)) = -6 / 3 = -2"
        },
        {
          "step": "Use point-slope with (-1,4)",
          "explanation": "y - 4 = -2(x + 1)"
        },
        {
          "step": "Simplify",
          "calculation": "y - 4 = -2x - 2 → y = -2x + 2"
        }
      ],
      "final_answer": "y = -2x + 2"
    },
