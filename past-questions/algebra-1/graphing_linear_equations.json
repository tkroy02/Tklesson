      "problem": "Find the slope and equation of the line passing through (-3,7) and (1,3).",
      "image": null,
      "step_by_step": [
        {
          "step": "Calculate slope",
          "calculation": "m = (3 - 7) / (1 - (-3)) = (-4) / 4 = -1"
