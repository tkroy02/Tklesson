    {
      "number": 1,
      "problem": "Classify √81, √80, and ∛-8 into their smallest possible subsets of real numbers. Explain why each classification is tricky and what common error students make with each.",
      "image": null,
      "step_by_step": [
        {
          "step": "Classify √81",
          "calculation": "√81 = 9",
          "explanation": "9 is a Natural number, Whole number, Integer, Rational, and Real. Smallest subset: Natural. Tricky part: Students often stop at 'integer' without simplifying; they may think √81 is irrational because it has a radical symbol."
        },
        {
          "step": "Classify √80",
          "calculation": "√80 = √(16×5) = 4√5",
          "explanation": "4√5 is Irrational (since √5 is irrational). Smallest subset: Irrational. Tricky part: Students may simplify partially but forget that √5 is irrational. Common error: Saying √80 is rational because 80 isn't a perfect square? Actually, common error is thinking it's rational after simplifying to 4√5, or stopping at 'real' without specifying irrational."
        },
        {
          "step": "Classify ∛-8",
          "calculation": "∛-8 = -2",
          "explanation": "-2 is an Integer (and Rational, Real). Smallest subset: Integer. Tricky part: Students forget cube roots of negatives are real. Common error: Saying it's 'not real' or 'imaginary,' or classifying as 'negative natural' incorrectly."
        }
      ],
      "final_answer": "√81: Natural; √80: Irrational; ∛-8: Integer"
    },
    {
      "number": 2,
      "problem": "Create a number that fits each of the following constraints, or prove it's impossible: (a) Real, Rational, but not Integer (b) Real, Irrational, but when squared becomes Rational (c) Real, Integer, but not Whole (d) Real, Whole, but not Natural (e) Real, Natural, but when halved is not Natural",
      "image": null,
      "step_by_step": [
        {
          "step": "Part (a)",
          "explanation": "Need a number that can be written as p/q (q≠1) and is real.",
          "calculation": "Example: 1/2",
          "proof": "1/2 is real, rational (ratio of integers), but not an integer."
        },
        {
          "step": "Part (b)",
          "explanation": "Need an irrational number whose square is rational.",
          "calculation": "Example: √2",
          "proof": "√2 is irrational, but (√2)² = 2, which is rational."
        },
        {
          "step": "Part (c)",
          "explanation": "Need an integer that is negative (since whole numbers are non-negative).",
          "calculation": "Example: -3",
          "proof": "-3 is an integer, but whole numbers are 0, 1, 2, ... so -3 is not whole."
        },
        {
          "step": "Part (d)",
          "explanation": "Need a whole number that is not natural (natural numbers typically start at 1).",
          "calculation": "Example: 0",
          "proof": "0 is whole, but natural numbers are {1, 2, 3, ...} in Algebra 1 context."
        },
        {
          "step": "Part (e)",
          "explanation": "Need a natural number that when divided by 2 is not natural.",
          "calculation": "Example: 3",
          "proof": "3 is natural. Halved = 1.5, which is not natural (not an integer)."
        }
      ],
      "final_answer": "(a) 1/2 (b) √2 (c) -3 (d) 0 (e) 3"
    },
