      "problem": "The ratio of boys to girls in a class is 3:4. If there are 12 boys, how many girls are in the class?",
      "image": null,
      "step_by_step": [
        {
          "step": "Set up the ratio",
          "explanation": "Boys:Girls = 3:4, so boys/girls = 3/4"
        },
        {
          "step": "Substitute the number of boys",
          "calculation": "12/g = 3/4"
        },
        {
          "step": "Cross multiply",
          "calculation": "12 × 4 = 3 × g → 48 = 3g"
        },
        {
          "step": "Divide by 3",
          "calculation": "g = 48/3 = 16"
        }
      ],
      "final_answer": "16 girls"
