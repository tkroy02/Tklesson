{
  "course": "Algebra 1",
  "topic": "Quadratic Functions",
  "problems": [
    {
      "number": 1,
      "problem": "Write the quadratic function in standard form: $f(x) = x^2 + 6x + 8$",
      "image": null,
      "step_by_step": [
        {
          "step": "Check if quadratic is already in standard form",
          "explanation": "Standard form is $f(x) = ax^2 + bx + c$. Here, $a=1, b=6, c=8$."
        }
      ],
      "final_answer": "$f(x) = x^2 + 6x + 8$"
    },
    {
      "number": 2,
      "problem": "Find the vertex of $f(x) = x^2 + 6x + 8$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use vertex formula $x_v = -b/(2a)$",
          "calculation": "$x_v = -6/(2 \\cdot 1) = -3$"
        },
        {
          "step": "Find $y$-coordinate",
          "calculation": "$y_v = f(-3) = (-3)^2 + 6(-3) + 8 = 9 - 18 + 8 = -1$"
        }
      ],
      "final_answer": "Vertex: $(-3, -1)$"
    },
    {
      "number": 3,
      "problem": "Find the axis of symmetry for $f(x) = 2x^2 - 4x + 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use axis formula $x = -b/(2a)$",
          "calculation": "$x = -(-4)/(2 \\cdot 2) = 4/4 = 1$"
        }
      ],
      "final_answer": "Axis of symmetry: $x = 1$"
    },
    {
      "number": 4,
      "problem": "Determine the y-intercept of $f(x) = 3x^2 - 5x + 2$",
      "image": null,
      "step_by_step": [
        {
          "step": "Y-intercept occurs at $x = 0$",
          "calculation": "$f(0) = 3(0)^2 - 5(0) + 2 = 2$"
        }
      ],
      "final_answer": "Y-intercept: $2$"
    },
    {
      "number": 5,
      "problem": "Find the zeros of $f(x) = x^2 - 5x + 6$",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor quadratic",
          "calculation": "$x^2 - 5x + 6 = (x - 2)(x - 3)$"
        },
        {
          "step": "Set each factor equal to zero",
          "calculation": "$x - 2 = 0 \\Rightarrow x = 2$; $x - 3 = 0 \\Rightarrow x = 3$"
        }
      ],
      "final_answer": "Zeros: $x = 2, 3$"
    },
    {
      "number": 6,
      "problem": "Find the vertex of $f(x) = -x^2 + 4x - 1$",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $x_v = -b/(2a)$",
          "calculation": "$x_v = -4/(2 \\cdot -1) = -4/-2 = 2$"
        },
        {
          "step": "Find $y$-coordinate",
          "calculation": "$y_v = f(2) = -(2)^2 + 4(2) - 1 = -4 + 8 - 1 = 3$"
        }
      ],
      "final_answer": "Vertex: $(2, 3)$"
    },
    {
      "number": 7,
      "problem": "Determine if the parabola $f(x) = x^2 + 2x + 5$ opens upward or downward",
      "image": null,
      "step_by_step": [
        {
          "step": "Check coefficient of $x^2$",
          "explanation": "$a = 1 > 0$, so the parabola opens upward"
        }
      ],
      "final_answer": "Opens upward"
    },
    {
      "number": 8,
      "problem": "Find the maximum value of $f(x) = -2x^2 + 8x - 3$",
      "image": null,
      "step_by_step": [
        {
          "step": "Vertex gives maximum since $a < 0$",
          "calculation": "$x_v = -b/(2a) = -8/(2 \\cdot -2) = -8/-4 = 2$"
        },
        {
          "step": "Compute $y$ at vertex",
          "calculation": "$y_v = f(2) = -2(2)^2 + 8(2) - 3 = -8 + 16 - 3 = 5$"
        }
      ],
      "final_answer": "Maximum value: $5$"
    },
    {
      "number": 9,
      "problem": "Write $f(x) = x^2 + 6x + 8$ in vertex form",
      "image": null,
      "step_by_step": [
        {
          "step": "Complete the square",
          "calculation": "$f(x) = x^2 + 6x + 8 = (x^2 + 6x + 9) - 9 + 8 = (x + 3)^2 - 1$"
        }
      ],
      "final_answer": "Vertex form: $f(x) = (x + 3)^2 - 1$"
    },
    {
      "number": 10,
      "problem": "Determine the y-intercept and zeros of $f(x) = x^2 - 2x - 8$",
      "image": null,
      "step_by_step": [
        {
          "step": "Y-intercept occurs at $x=0$",
          "calculation": "$f(0) = 0 - 0 - 8 = -8$"
        },
        {
          "step": "Factor to find zeros",
          "calculation": "$x^2 - 2x - 8 = (x - 4)(x + 2)$"
        },
        {
          "step": "Set each factor equal to zero",
          "calculation": "$x - 4 = 0 \\Rightarrow x = 4$, $x + 2 = 0 \\Rightarrow x = -2$"
        }
      ],
      "final_answer": "Y-intercept: $-8$, Zeros: $x = 4, -2$"
    },
    {
      "number": 11,
      "problem": "Find the discriminant of $f(x) = 2x^2 - 3x + 4$ and determine the number of real zeros.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use discriminant formula $\\Delta = b^2 - 4ac$",
          "calculation": "$\\Delta = (-3)^2 - 4(2)(4) = 9 - 32 = -23$"
        },
        {
          "step": "Interpret discriminant",
          "explanation": "$\\Delta < 0$, so there are no real zeros (two complex roots)"
        }
      ],
      "final_answer": "Discriminant: $-23$; no real zeros"
    },
    {
      "number": 12,
      "problem": "Write the quadratic function with zeros at $x = 3$ and $x = -5$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use factored form $f(x) = a(x - r_1)(x - r_2)$",
          "calculation": "$f(x) = a(x - 3)(x + 5)$"
        },
        {
          "step": "Choose $a = 1$ for simplest form",
          "calculation": "$f(x) = (x - 3)(x + 5) = x^2 + 2x - 15$"
        }
      ],
      "final_answer": "$f(x) = x^2 + 2x - 15$"
    },
    {
      "number": 13,
      "problem": "A ball is thrown upward from a height of 5 feet with initial velocity 32 ft/s. The height is given by $h(t) = -16t^2 + 32t + 5$. Find the maximum height.",
      "image": null,
      "step_by_step": [
        {
          "step": "Vertex gives maximum since $a < 0$",
          "calculation": "$t_v = -b/(2a) = -32/(2 \\cdot -16) = -32/-32 = 1$ second"
        },
        {
          "step": "Compute height at $t = 1$",
          "calculation": "$h(1) = -16(1)^2 + 32(1) + 5 = -16 + 32 + 5 = 21$ feet"
        }
      ],
      "final_answer": "Maximum height: $21$ feet"
    },
    {
      "number": 14,
      "problem": "A rectangle has length 2 feet more than its width. If the area is 35 square feet, find the dimensions.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let $w$ = width, then $l = w + 2$"
        },
        {
          "step": "Write area equation",
          "calculation": "$w(w + 2) = 35 \\rightarrow w^2 + 2w - 35 = 0$"
        },
        {
          "step": "Factor",
          "calculation": "$(w + 7)(w - 5) = 0$"
        },
        {
          "step": "Solve for $w$",
          "calculation": "$w = 5$ (positive solution), $l = 7$"
        }
      ],
      "final_answer": "Width: $5$ ft, Length: $7$ ft"
    },
    {
      "number": 15,
      "problem": "Find the vertex of $f(x) = 3x^2 - 12x + 7$ and state whether it is a minimum or maximum.",
      "image": null,
      "step_by_step": [
        {
          "step": "Use $x_v = -b/(2a)$",
          "calculation": "$x_v = -(-12)/(2 \\cdot 3) = 12/6 = 2$"
        },
        {
          "step": "Find $y$-coordinate",
          "calculation": "$y_v = 3(2)^2 - 12(2) + 7 = 12 - 24 + 7 = -5$"
        },
        {
          "step": "Determine min or max",
          "explanation": "$a = 3 > 0$, so parabola opens upward → vertex is a minimum"
        }
      ],
      "final_answer": "Vertex: $(2, -5)$, minimum"
    },
    {
      "number": 16,
      "problem": "Find the x-intercepts of $f(x) = 2x^2 + 3x - 2$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Set $f(x) = 0$ and factor",
          "calculation": "$2x^2 + 3x - 2 = 0$"
        },
        {
          "step": "Factor",
          "explanation": "Find two numbers that multiply to $-4$ and add to $3$: $4$ and $-1$",
          "calculation": "$2x^2 + 4x - x - 2 = 2x(x + 2) - 1(x + 2) = (2x - 1)(x + 2)$"
        },
        {
          "step": "Solve for $x$",
          "calculation": "$2x - 1 = 0 \\Rightarrow x = 1/2$; $x + 2 = 0 \\Rightarrow x = -2$"
        }
      ],
      "final_answer": "x-intercepts: $x = -2$ and $x = 1/2$"
    },
    {
      "number": 17,
      "problem": "Write $f(x) = 2x^2 - 8x + 5$ in vertex form.",
      "image": null,
      "step_by_step": [
        {
          "step": "Factor out coefficient of $x^2$ from first two terms",
          "calculation": "$f(x) = 2(x^2 - 4x) + 5$"
        },
        {
          "step": "Complete the square inside parentheses",
          "calculation": "$x^2 - 4x = (x^2 - 4x + 4) - 4 = (x - 2)^2 - 4$"
        },
        {
          "step": "Substitute back",
          "calculation": "$f(x) = 2[(x - 2)^2 - 4] + 5 = 2(x - 2)^2 - 8 + 5 = 2(x - 2)^2 - 3$"
        }
      ],
      "final_answer": "$f(x) = 2(x - 2)^2 - 3$"
    },
    {
      "number": 18,
      "problem": "A rocket is launched from the ground with initial velocity 80 ft/s. Its height is $h(t) = -16t^2 + 80t$. When does it hit the ground?",
      "image": null,
      "step_by_step": [
        {
          "step": "Set $h(t) = 0$ to find when it hits ground",
          "calculation": "$-16t^2 + 80t = 0$"
        },
        {
          "step": "Factor",
          "calculation": "$-16t(t - 5) = 0$"
        },
        {
          "step": "Solve for $t$",
          "calculation": "$t = 0$ (launch) or $t = 5$ seconds"
        }
      ],
      "final_answer": "The rocket hits the ground at $t = 5$ seconds"
    },
    {
      "number": 19,
      "problem": "Find the axis of symmetry and vertex of $f(x) = -x^2 + 6x - 5$.",
      "image": null,
      "step_by_step": [
        {
          "step": "Axis of symmetry: $x = -b/(2a)$",
          "calculation": "$x = -6/(2 \\cdot -1) = -6/-2 = 3$"
        },
        {
          "step": "Find $y$-coordinate of vertex",
          "calculation": "$y_v = f(3) = -(3)^2 + 6(3) - 5 = -9 + 18 - 5 = 4$"
        }
      ],
      "final_answer": "Axis of symmetry: $x = 3$, Vertex: $(3, 4)$"
    },
    {
      "number": 20,
      "problem": "A rectangular garden is to be fenced on three sides (the fourth side is a barn). If 100 feet of fencing is available, find the dimensions that maximize the area.",
      "image": null,
      "step_by_step": [
        {
          "step": "Define variables",
          "explanation": "Let $x$ = width (perpendicular to barn), $y$ = length (parallel to barn)"
        },
        {
          "step": "Write fencing equation",
          "calculation": "$2x + y = 100 \\Rightarrow y = 100 - 2x$"
        },
        {
          "step": "Write area function",
          "calculation": "$A(x) = x \\cdot y = x(100 - 2x) = -2x^2 + 100x$"
        },
        {
          "step": "Find vertex (maximum area)",
          "calculation": "$x_v = -b/(2a) = -100/(2 \\cdot -2) = -100/-4 = 25$"
        },
        {
          "step": "Find $y$",
          "calculation": "$y = 100 - 2(25) = 50$"
        }
      ],
      "final_answer": "Dimensions: width = $25$ ft, length = $50$ ft"
    }
  ]
}
