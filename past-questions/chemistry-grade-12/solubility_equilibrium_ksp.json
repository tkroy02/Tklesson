      "number": 1,
      "problem": "Define solubility equilibrium. What is the solubility product constant (Ksp)?",
      "image": null,
      "step_by_step": [
        {
          "step": "Define solubility equilibrium",
          "explanation": "Solubility equilibrium is the dynamic equilibrium between a solid solute and its dissolved ions in a saturated solution."
        },
        {
          "step": "Define Ksp",
          "explanation": "Ksp is the equilibrium constant for the dissolution of a sparingly soluble ionic compound. It equals the product of the ion concentrations raised to their stoichiometric coefficients."
        }
      ],
      "final_answer": "Solubility equilibrium: solid ⇌ ions in saturated solution; Ksp = product of ion concentrations at equilibrium"
    },
    {
      "number": 2,
      "problem": "Write the Ksp expression for the dissolution of calcium fluoride (CaF₂).",
      "image": null,
      "step_by_step": [
        {
          "step": "Write the dissolution equation",
          "calculation": "CaF₂(s) ⇌ Ca²⁺(aq) + 2F⁻(aq)"
        },
        {
          "step": "Write Ksp expression",
          "calculation": "Ksp = [Ca²⁺][F⁻]²"
        }
      ],
      "final_answer": "Ksp = [Ca²⁺][F⁻]²"
    },
